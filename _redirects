# Redirect /auth/callback to the auth callback handler
/auth/callback /auth/callback/index.html 200

# Redirect /auth/confirmed to the email confirmed page
/auth/confirmed /auth/confirmed/index.html 200

# Redirect /auth/confirm to the email confirmation page
/auth/confirm /auth/confirm/index.html 200

# Redirect /auth/reset-password to the password reset page
/auth/reset-password /auth/reset-password/index.html 200

# Redirect all /share/:code URLs to the share handler page
# The share code will be extracted from the URL path by JavaScript
/share/* /share/index.html 200