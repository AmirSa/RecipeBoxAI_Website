  "instructions": [
    {
      "id": "c2b2c3d4-e5f6-7890-abcd-000000000001",
      "stepNumber": 1,
      "instruction": "Toast the bread slices in a toaster or on a griddle until golden brown and crispy on both sides."
    },
    {
      "id": "c2b2c3d4-e5f6-7890-abcd-000000000002",
      "stepNumber": 2,
      "instruction": "While bread is toasting, cut avocados in half, remove pit, and scoop flesh into a bowl."
    },
    {
      "id": "c2b2c3d4-e5f6-7890-abcd-000000000003",
      "stepNumber": 3,
      "instruction": "Mash avocados with a fork, adding lemon juice, salt, and pepper. Mash to desired consistency - chunky or smooth."
    },
    {
      "id": "c2b2c3d4-e5f6-7890-abcd-000000000004",
      "stepNumber": 4,
      "instruction": "Spread the mashed avocado generously on each toast slice, making sure to reach the edges."
    },
    {
      "id": "c2b2c3d4-e5f6-7890-abcd-000000000005",
      "stepNumber": 5,
      "instruction": "Top each toast with halved cherry tomatoes and crumbled feta cheese if using."
    },
    {
      "id": "c2b2c3d4-e5f6-7890-abcd-000000000006",
      "stepNumber": 6,
      "instruction": "Drizzle with olive oil and sprinkle with red pepper flakes for a little kick."
    },
    {
      "id": "c2b2c3d4-e5f6-7890-abcd-000000000007",
      "stepNumber": 7,
      "instruction": "Serve immediately while toast is still warm and crispy. Enjoy!"
    }
  ],
