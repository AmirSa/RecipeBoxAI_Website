  "instructions": [
    {
      "id": "a9b0c1d2-e3f4-5678-3456-789012345678",
      "stepNumber": 1,
      "instruction": "In a large bowl, combine yogurt, lemon juice, garam masala, paprika, and cumin. Add chicken pieces and mix well to coat. Cover and refrigerate for at least 1 hour (or up to 24 hours for best flavor)."
    },
    {
      "id": "b0c1d2e3-f4a5-6789-4567-890123456789",
      "stepNumber": 2,
      "instruction": "Heat a large skillet over medium-high heat. Add marinated chicken in batches and cook until lightly charred and cooked through, about 8-10 minutes. Remove and set aside."
    },
    {
      "id": "c1d2e3f4-a5b6-7890-5678-901234567890",
      "stepNumber": 3,
      "instruction": "In the same skillet, melt butter over medium heat. Add chopped onion and sauté until soft and golden, about 5 minutes."
    },
    {
      "id": "d2e3f4a5-b6c7-8901-6789-012345678901",
      "stepNumber": 4,
      "instruction": "Add minced garlic and grated ginger, stirring constantly for 1 minute until fragrant."
    },
    {
      "id": "e3f4a5b6-c7d8-9012-7890-123456789012",
      "stepNumber": 5,
      "instruction": "Stir in tomato sauce, garam masala, paprika, and salt. Simmer for 10 minutes, stirring occasionally, until sauce thickens slightly."
    },
    {
      "id": "f4a5b6c7-d8e9-0123-8901-234567890123",
      "stepNumber": 6,
      "instruction": "Reduce heat to low and stir in heavy cream until well combined. Return cooked chicken to the pan and simmer for 5 more minutes."
    },
    {
      "id": "a5b6c7d8-e9f0-1234-9012-345678901234",
      "stepNumber": 7,
      "instruction": "Taste and adjust seasoning with salt if needed. Garnish with fresh cilantro and serve hot with basmati rice or naan bread."
    }
  ],
