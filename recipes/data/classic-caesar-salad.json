  "instructions": [
    {
      "id": "c3b2c3d4-e5f6-7890-abcd-000000000001",
      "stepNumber": 1,
      "instruction": "Wash and thoroughly dry the romaine lettuce. Chop into bite-sized pieces and place in a large salad bowl."
    },
    {
      "id": "c3b2c3d4-e5f6-7890-abcd-000000000002",
      "stepNumber": 2,
      "instruction": "In a small bowl, whisk together mayonnaise, lemon juice, minced garlic, Dijon mustard, Worcestershire sauce, and anchovy paste (if using)."
    },
    {
      "id": "c3b2c3d4-e5f6-7890-abcd-000000000003",
      "stepNumber": 3,
      "instruction": "Add grated Parmesan cheese and black pepper to the dressing and whisk until smooth and well combined."
    },
    {
      "id": "c3b2c3d4-e5f6-7890-abcd-000000000004",
      "stepNumber": 4,
      "instruction": "Pour dressing over the chopped lettuce and toss gently until every leaf is coated with dressing."
    },
    {
      "id": "c3b2c3d4-e5f6-7890-abcd-000000000005",
      "stepNumber": 5,
      "instruction": "Add croutons and toss again gently to distribute them throughout the salad."
    },
    {
      "id": "c3b2c3d4-e5f6-7890-abcd-000000000006",
      "stepNumber": 6,
      "instruction": "Top with freshly grated Parmesan cheese and additional black pepper if desired."
    },
    {
      "id": "c3b2c3d4-e5f6-7890-abcd-000000000007",
      "stepNumber": 7,
      "instruction": "Serve immediately to keep the lettuce crisp and croutons crunchy. Enjoy!"
    }
  ],
