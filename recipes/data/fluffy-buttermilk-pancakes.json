  "instructions": [
    {
      "id": "c1b2c3d4-e5f6-7890-abcd-000000000001",
      "stepNumber": 1,
      "instruction": "In a large bowl, whisk together flour, sugar, baking powder, baking soda, and salt until well combined."
    },
    {
      "id": "c1b2c3d4-e5f6-7890-abcd-000000000002",
      "stepNumber": 2,
      "instruction": "In another bowl, beat together buttermilk, eggs, melted butter, and vanilla extract until smooth."
    },
    {
      "id": "c1b2c3d4-e5f6-7890-abcd-000000000003",
      "stepNumber": 3,
      "instruction": "Pour wet ingredients into dry ingredients and stir until just combined. Don't overmix - small lumps are fine. Let batter rest for 5 minutes."
    },
    {
      "id": "c1b2c3d4-e5f6-7890-abcd-000000000004",
      "stepNumber": 4,
      "instruction": "Heat a griddle or large skillet over medium heat (about 350°F). Lightly grease with butter or cooking spray."
    },
    {
      "id": "c1b2c3d4-e5f6-7890-abcd-000000000005",
      "stepNumber": 5,
      "instruction": "Pour 1/4 cup of batter for each pancake onto the hot griddle. Cook until bubbles form on the surface and edges look set, about 2-3 minutes."
    },
    {
      "id": "c1b2c3d4-e5f6-7890-abcd-000000000006",
      "stepNumber": 6,
      "instruction": "Flip pancakes and cook until golden brown on the other side, about 2-3 minutes more."
    },
    {
      "id": "c1b2c3d4-e5f6-7890-abcd-000000000007",
      "stepNumber": 7,
      "instruction": "Serve immediately with warm maple syrup, butter, and fresh berries. Keep cooked pancakes warm in a 200°F oven if making multiple batches."
    }
  ],
