---
interface Props {
  image: string;
  alt: string;
}

const { image, alt } = Astro.props;
---

<div class="hero-card">
  <img src={image} alt={alt} class="hero-image" />
</div>

<style>
  .hero-card {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    background: #1a1a1a;
    box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    line-height: 0;
  }
  
  .hero-image {
    width: 100%;
    height: 420px;
    object-fit: cover;
    display: block;
    border-radius: 20px;
  }
  
  @media (max-width: 768px) {
    .hero-image {
      height: 320px;
    }
  }
</style>
