---
// Floating import tray — the web version of the apps' "recipe processing" bar.
// Mount once on every authenticated page; it renders nothing until an import
// is in flight (state lives in localStorage, see src/lib/imports.ts).
---

<script>
  import { initImportTray } from '@/lib/imports';
  initImportTray();
</script>

<style is:global>
  #rb-import-tray {
    position: fixed;
    right: 20px;
    bottom: 20px;
    z-index: 200;
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-width: min(380px, calc(100vw - 40px));
  }
  .rb-imp {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
    border-radius: 16px;
    background: var(--card);
    border: 1px solid var(--line);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.12);
    font-family: var(--sans);
    animation: rb-imp-in 220ms ease;
  }
  @keyframes rb-imp-in { from { opacity: 0; transform: translateY(8px); } }
  .rb-imp-ico { width: 26px; height: 26px; border-radius: 50%; display: grid; place-items: center; flex-shrink: 0; background: color-mix(in srgb, var(--solid) 8%, transparent); color: var(--ink); }
  .rb-imp-ico.ok { background: #3f8f4f; color: #fff; }
  .rb-imp-ico.warn { background: color-mix(in srgb, #e0853b 18%, transparent); color: #b96a22; }
  .rb-imp-spin { width: 13px; height: 13px; border-radius: 50%; border: 2px solid color-mix(in srgb, var(--ink) 25%, transparent); border-top-color: var(--ink); animation: rb-imp-spin 0.8s linear infinite; }
  @keyframes rb-imp-spin { to { transform: rotate(360deg); } }
  .rb-imp-text { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 1px; }
  .rb-imp-text b { font-size: 13.5px; font-weight: 650; color: var(--ink); letter-spacing: -0.01em; }
  .rb-imp-text small { font-size: 11.5px; color: var(--muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .rb-imp-btn { flex-shrink: 0; display: inline-flex; align-items: center; height: 30px; padding: 0 14px; border-radius: 999px; background: var(--solid); color: var(--on-solid); font-size: 12.5px; font-weight: 600; }
  .rb-imp-btn:hover { background: color-mix(in srgb, var(--solid) 92%, var(--bg)); }
  .rb-imp-x { flex-shrink: 0; width: 26px; height: 26px; border-radius: 50%; border: 0; background: transparent; color: var(--muted); font-size: 17px; line-height: 1; display: grid; place-items: center; }
  .rb-imp-x:hover { background: color-mix(in srgb, var(--ink) 7%, transparent); color: var(--ink); }
  @media (max-width: 760px) {
    #rb-import-tray { right: 12px; bottom: 12px; left: 12px; max-width: none; }
  }
</style>
