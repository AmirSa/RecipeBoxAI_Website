---
interface Nutrient {
  name: string;
  value: string;
  description: string;
  icon?: string;
  color?: 'yellow' | 'red' | 'blue' | 'green';
}

interface Props {
  nutrients: Nutrient[];
}

const { nutrients } = Astro.props;

const colorClasses: Record<string, string> = {
  yellow: 'nutrient-yellow',
  red: 'nutrient-red',
  blue: 'nutrient-blue',
  green: 'nutrient-green',
};
---

<div class="card">
  <h2 class="card-title">Rich in nutrients</h2>
  <div class="nutrients-grid">
    {nutrients.map((nutrient) => (
      <div class={`nutrient-card ${colorClasses[nutrient.color || 'yellow']}`}>
        <div class="nutrient-header">
          <span class="nutrient-icon">{nutrient.icon || '✦'}</span>
          <span class="nutrient-name">{nutrient.name}</span>
        </div>
        <div class="nutrient-value">{nutrient.value}</div>
        <div class="nutrient-desc">{nutrient.description}</div>
      </div>
    ))}
  </div>
</div>

<style>
  .card {
    background: var(--card);
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }

  .card-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 1rem;
  }
  
  .nutrients-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  
  .nutrient-card {
    padding: 1rem;
    border-radius: 12px;
    border-left: 4px solid;
  }
  
  .nutrient-yellow {
    background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
    border-left-color: #f59e0b;
  }
  
  .nutrient-red {
    background: linear-gradient(135deg, #fdf2f8 0%, #fce7f3 100%);
    border-left-color: #ec4899;
  }
  
  .nutrient-blue {
    background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
    border-left-color: #3b82f6;
  }
  
  .nutrient-green {
    background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
    border-left-color: #22c55e;
  }
  
  .nutrient-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }
  
  .nutrient-icon {
    font-size: 0.9rem;
  }
  
  .nutrient-name {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--ink);
  }
  
  .nutrient-value {
    font-size: 0.95rem;
    font-weight: 700;
    margin-top: 0.25rem;
  }
  
  .nutrient-yellow .nutrient-value { color: #d97706; }
  .nutrient-red .nutrient-value { color: #db2777; }
  .nutrient-blue .nutrient-value { color: #2563eb; }
  .nutrient-green .nutrient-value { color: #16a34a; }
  
  .nutrient-desc {
    font-size: 0.8rem;
    color: var(--muted);
    margin-top: 0.25rem;
    line-height: 1.4;
  }

  /* Dark-mode overrides for the pastel nutrient tints (no direct token) */
  :global([data-theme="dark"]) .nutrient-yellow {
    background: linear-gradient(135deg, rgba(245,158,11,0.10) 0%, rgba(245,158,11,0.18) 100%);
  }
  :global([data-theme="dark"]) .nutrient-red {
    background: linear-gradient(135deg, rgba(236,72,153,0.10) 0%, rgba(236,72,153,0.18) 100%);
  }
  :global([data-theme="dark"]) .nutrient-blue {
    background: linear-gradient(135deg, rgba(59,130,246,0.10) 0%, rgba(59,130,246,0.18) 100%);
  }
  :global([data-theme="dark"]) .nutrient-green {
    background: linear-gradient(135deg, rgba(34,197,94,0.10) 0%, rgba(34,197,94,0.18) 100%);
  }
  :global([data-theme="dark"]) .nutrient-yellow .nutrient-value { color: #fbbf24; }
  :global([data-theme="dark"]) .nutrient-red .nutrient-value { color: #f472b6; }
  :global([data-theme="dark"]) .nutrient-blue .nutrient-value { color: #60a5fa; }
  :global([data-theme="dark"]) .nutrient-green .nutrient-value { color: #4ade80; }

  @media (max-width: 600px) {
    .nutrients-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
