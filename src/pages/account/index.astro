---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Account" description="Manage your RecipeBox AI account, tags, and cookbooks.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,800&family=Inter+Tight:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <meta name="robots" content="noindex">

  <nav class="rb-nav">
    <div class="container inner">
      <a class="brand" href="/">
        <img class="app-ico" src="/app-icon.png" alt="">
        RecipeBox AI
      </a>
      <ul>
        <li><a href="/#features">Features</a></li>
        <li><a href="/recipes/">Recipes</a></li>
        <li><a href="/my/recipes/">My Recipes</a></li>
        <li><a class="current" href="/account/">Account</a></li>
      </ul>
      <div class="nav-account" id="nav-account" hidden>
        <span class="who" id="nav-email"></span>
        <button class="signout" id="signout-btn" type="button">Sign out</button>
      </div>
    </div>
  </nav>

  <div class="container">
    <header class="page-head">
      <div class="eyebrow">Your account</div>
      <h1 class="display">Account<br><em>&amp; settings.</em></h1>
    </header>

    <main id="account-body">
      <!-- skeleton -->
      <div class="sk-block" style="height: 150px;"></div>
      <div class="sk-block" style="height: 260px; margin-top: 24px;"></div>
      <div class="sk-block" style="height: 200px; margin-top: 24px;"></div>
    </main>
  </div>

  <footer class="rb-footer">
    <div class="container row">
      <div class="brand"><img class="app-ico" src="/app-icon.png" alt="">RecipeBox AI</div>
      <div class="links">
        <a href="mailto:hello@recipeboxai.app">Support</a>
        <a href="/privacy/">Privacy</a>
        <a href="/terms/">Terms</a>
        <a href="https://twitter.com/RecipeBoxAI">Twitter</a>
      </div>
      <div class="copy">© 2026 RecipeBox AI</div>
    </div>
  </footer>

  <script>
    import {
      requireSession, signOut, escapeHtml, tagHex, TAG_PALETTE, FREE_TIER_LIMIT,
      getAccountSummary, fetchTagsWithCounts, renameTag, recolorTag, deleteTag,
      fetchCookbooksWithCounts,
      type TagWithCount, type CookbookWithCount, type AccountSummary,
    } from '@/lib/account';

    const APP_STORE = 'https://apps.apple.com/gb/app/recipebox-ai/id6752560797';
    const body = document.getElementById('account-body') as HTMLElement;

    const state = {
      summary: null as AccountSummary | null,
      tags: [] as TagWithCount[],
      cookbooks: [] as CookbookWithCount[],
      editingTagId: null as string | null,
    };

    function planCardHtml(s: AccountSummary): string {
      if (s.isPro) {
        return `
          <div class="card plan pro">
            <div class="plan-head">
              <div><div class="plan-eyebrow">Your plan</div><div class="plan-name">RecipeBox <em>Pro</em></div></div>
              <span class="badge pro">PRO</span>
            </div>
            <p class="plan-note">Unlimited recipes, AI transformations, and every premium feature. Thanks for being a Pro member.</p>
          </div>`;
      }
      const used = s.recipeCount;
      const limit = s.limit;
      const pct = Math.min(100, Math.round((used / limit) * 100));
      const atLimit = used >= limit;
      const bonusNote = s.bonusSlots > 0 ? ` (${FREE_TIER_LIMIT} + ${s.bonusSlots} referral bonus)` : '';
      return `
        <div class="card plan">
          <div class="plan-head">
            <div><div class="plan-eyebrow">Your plan</div><div class="plan-name">Free plan</div></div>
            <span class="badge free">FREE</span>
          </div>
          <div class="usage">
            <div class="usage-row">
              <span>Recipes saved</span>
              <span class="usage-num"><b class="${atLimit ? 'full' : ''}">${used}</b> of ${limit}${escapeHtml(bonusNote)}</span>
            </div>
            <div class="meter"><div class="meter-fill ${atLimit ? 'full' : ''}" style="width:${pct}%;"></div></div>
            ${atLimit
              ? `<p class="plan-note">You've reached the free-plan limit. Upgrade to Pro for unlimited recipes.</p>`
              : `<p class="plan-note">${limit - used} more on the free plan. Upgrade any time for unlimited recipes.</p>`}
          </div>
          <div class="plan-cta">
            <a class="btn-primary" href="${APP_STORE}">Upgrade to Pro</a>
            <span class="hint">Upgrading on the web is coming soon.</span>
          </div>
        </div>`;
    }

    function swatchRow(selectedHex: string): string {
      return TAG_PALETTE.map((c) => {
        const on = c.hex.toLowerCase() === selectedHex.toLowerCase();
        return `<button class="swatch ${on ? 'on' : ''}" data-color="${c.hex}" title="${c.name}" aria-label="${c.name}" style="background:${c.hex};"></button>`;
      }).join('');
    }

    function tagRowHtml(t: TagWithCount): string {
      const hex = tagHex(t.color);
      if (state.editingTagId === t.id) {
        return `
          <li class="tag-row editing" data-id="${escapeHtml(t.id)}">
            <div class="tag-edit">
              <input class="tag-name-input" type="text" value="${escapeHtml(t.name)}" maxlength="40" aria-label="Tag name">
              <div class="swatches">${swatchRow(hex)}</div>
              <div class="edit-actions">
                <button class="mini danger" data-act="delete">Delete</button>
                <span class="spacer"></span>
                <button class="mini" data-act="cancel">Cancel</button>
                <button class="mini solid" data-act="save">Save</button>
              </div>
            </div>
          </li>`;
      }
      return `
        <li class="tag-row" data-id="${escapeHtml(t.id)}">
          <span class="tag-chip" style="color:${hex}; border-color:${hex}40; background:${hex}12;">
            <span class="sw" style="background:${hex};"></span>${escapeHtml(t.name)}
          </span>
          <span class="tag-count">${t.count} recipe${t.count === 1 ? '' : 's'}</span>
          <button class="mini" data-act="edit">Edit</button>
        </li>`;
    }

    function cookbookCardHtml(c: CookbookWithCount): string {
      const initial = escapeHtml((c.name || 'C').slice(0, 1).toUpperCase());
      return `
        <a class="cb-card" href="/account/cookbook/?id=${encodeURIComponent(c.id)}">
          <div class="cb-cover">
            ${c.image_url
              ? `<img src="${escapeHtml(c.image_url)}" alt="${escapeHtml(c.name)}" loading="lazy" onerror="this.replaceWith(Object.assign(document.createElement('div'),{className:'cb-ph',textContent:'${initial}'}))">`
              : `<div class="cb-ph">${initial}</div>`}
          </div>
          <div class="cb-body">
            <h3>${escapeHtml(c.name)}</h3>
            <span class="cb-count">${c.count} recipe${c.count === 1 ? '' : 's'}</span>
          </div>
        </a>`;
    }

    function render() {
      const s = state.summary!;
      body.innerHTML = `
        ${planCardHtml(s)}

        <section class="card section">
          <div class="section-head">
            <h2>Manage tags</h2>
            <span class="section-sub">${state.tags.length} tag${state.tags.length === 1 ? '' : 's'} · changes sync to your phone</span>
          </div>
          ${state.tags.length === 0
            ? `<p class="empty-note">No tags yet. Create tags in the app to organize your recipes.</p>`
            : `<ul class="tag-list">${state.tags.map(tagRowHtml).join('')}</ul>`}
        </section>

        <section class="card section">
          <div class="section-head">
            <h2>Cookbooks</h2>
            <span class="section-sub">${state.cookbooks.length} cookbook${state.cookbooks.length === 1 ? '' : 's'}</span>
          </div>
          ${state.cookbooks.length === 0
            ? `<p class="empty-note">No cookbooks yet. Create cookbooks in the app to group recipes — they'll show up here.</p>`
            : `<div class="cb-grid">${state.cookbooks.map(cookbookCardHtml).join('')}</div>`}
        </section>`;
      wireTagList();
    }

    function wireTagList() {
      const list = body.querySelector('.tag-list');
      if (!list) return;
      list.addEventListener('click', onTagListClick);
    }

    async function onTagListClick(e: Event) {
      const btn = (e.target as HTMLElement).closest('button[data-act]') as HTMLElement | null;
      const swatch = (e.target as HTMLElement).closest('.swatch') as HTMLElement | null;
      if (swatch) {
        swatch.parentElement?.querySelectorAll('.swatch').forEach((s) => s.classList.remove('on'));
        swatch.classList.add('on');
        return;
      }
      if (!btn) return;
      const row = btn.closest('.tag-row') as HTMLElement;
      const id = row.dataset.id!;
      const act = btn.dataset.act;

      if (act === 'edit') { state.editingTagId = id; render(); return; }
      if (act === 'cancel') { state.editingTagId = null; render(); return; }

      if (act === 'save') {
        const nameInput = row.querySelector('.tag-name-input') as HTMLInputElement;
        const newName = nameInput.value.trim();
        const selected = (row.querySelector('.swatch.on') as HTMLElement)?.dataset.color;
        const tag = state.tags.find((t) => t.id === id)!;
        if (!newName) { nameInput.focus(); return; }
        setRowBusy(row, true);
        try {
          if (newName !== tag.name) { await renameTag(id, newName); tag.name = newName; }
          if (selected && selected.toLowerCase() !== tagHex(tag.color).toLowerCase()) {
            await recolorTag(id, selected); tag.color = selected;
          }
          state.editingTagId = null;
          render();
        } catch (err) {
          setRowBusy(row, false);
          alert('Could not save the tag: ' + (err instanceof Error ? err.message : 'try again'));
        }
        return;
      }

      if (act === 'delete') {
        const tag = state.tags.find((t) => t.id === id)!;
        const msg = tag.count > 0
          ? `Delete "${tag.name}"? It will be removed from ${tag.count} recipe${tag.count === 1 ? '' : 's'} on all your devices.`
          : `Delete "${tag.name}"?`;
        if (!confirm(msg)) return;
        setRowBusy(row, true);
        try {
          await deleteTag(id);
          state.tags = state.tags.filter((t) => t.id !== id);
          state.editingTagId = null;
          render();
        } catch (err) {
          setRowBusy(row, false);
          alert('Could not delete the tag: ' + (err instanceof Error ? err.message : 'try again'));
        }
      }
    }

    function setRowBusy(row: HTMLElement, busy: boolean) {
      row.querySelectorAll('button, input').forEach((el) => ((el as HTMLButtonElement).disabled = busy));
      row.style.opacity = busy ? '0.6' : '';
    }

    function showError(message: string) {
      body.innerHTML = `<div class="card"><h2 style="font-family:var(--serif);font-weight:500;">Couldn't load your account</h2><p class="empty-note">${escapeHtml(message)}</p><button class="btn-primary" id="retry">Try again</button></div>`;
      document.getElementById('retry')?.addEventListener('click', () => location.reload());
    }

    async function load() {
      const session = await requireSession();
      if (!session) return;
      (document.getElementById('nav-email') as HTMLElement).textContent = session.user.email ?? '';
      (document.getElementById('nav-account') as HTMLElement).hidden = false;
      document.getElementById('signout-btn')?.addEventListener('click', () => signOut());

      try {
        const [summary, tags, cookbooks] = await Promise.all([
          getAccountSummary(session.user.id, session.user.email ?? ''),
          fetchTagsWithCounts(),
          fetchCookbooksWithCounts(),
        ]);
        state.summary = summary;
        state.tags = tags;
        state.cookbooks = cookbooks;
        render();
      } catch (err) {
        showError(err instanceof Error ? err.message : 'Something went wrong.');
      }
    }

    load().catch((err) => showError(err instanceof Error ? err.message : 'Something went wrong.'));
  </script>
</BaseLayout>

<style is:global>
  :root {
    --bg: #f0eee9; --bg-2: #e9e6df; --ink: #0a0a0a; --ink-2: #2a2a2c; --muted: #6e6e73;
    --line: rgba(10,10,10,0.08); --line-2: rgba(10,10,10,0.04);
    --serif: "Fraunces", Georgia, serif; --sans: "Inter Tight", -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
  }
  *, *::before, *::after { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; background: var(--bg); color: var(--ink); font-family: var(--sans); line-height: 1.45; }
  body { -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility; }
  ::selection { background: #0a0a0a; color: #fff; }
  img { display: block; max-width: 100%; }
  a { color: inherit; text-decoration: none; }
  button { font: inherit; cursor: pointer; }
  [hidden] { display: none !important; }

  .container { max-width: 1000px; margin: 0 auto; padding: 0 56px; }
  .display { font-family: var(--serif); font-weight: 400; font-variation-settings: "opsz" 144; line-height: 0.96; letter-spacing: -0.035em; }
  .display em { font-style: italic; }
  .eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 1.6px; text-transform: uppercase; color: var(--muted); }

  /* Nav */
  nav.rb-nav { position: sticky; top: 0; z-index: 50; backdrop-filter: saturate(180%) blur(14px); -webkit-backdrop-filter: saturate(180%) blur(14px); background: color-mix(in srgb, var(--bg) 86%, transparent); border-bottom: 1px solid var(--line-2); }
  nav.rb-nav .inner { display: flex; align-items: center; justify-content: space-between; height: 64px; max-width: 1000px; }
  nav.rb-nav .brand { display: flex; align-items: center; gap: 10px; font-weight: 700; letter-spacing: -0.02em; font-size: 17px; color: var(--ink); }
  nav.rb-nav .brand .app-ico { width: 30px; height: 30px; border-radius: 7px; box-shadow: 0 1px 2px rgba(0,0,0,0.18); }
  nav.rb-nav ul { list-style: none; padding: 0; margin: 0; display: flex; gap: 28px; }
  nav.rb-nav ul a { font-size: 14px; font-weight: 500; color: var(--ink-2); }
  nav.rb-nav ul a.current, nav.rb-nav ul a:hover { color: var(--ink); }
  .nav-account { display: flex; align-items: center; gap: 12px; }
  .nav-account .who { font-size: 12.5px; color: var(--muted); max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .nav-account .signout { height: 36px; padding: 0 16px; border-radius: 999px; border: 1px solid var(--line); background: transparent; font-size: 13px; font-weight: 600; color: var(--ink-2); }
  .nav-account .signout:hover { border-color: rgba(10,10,10,0.3); color: var(--ink); }

  header.page-head { padding: 44px 0 32px; }
  header.page-head h1 { font-size: 64px; margin: 12px 0 0; }
  main#account-body { padding-bottom: 96px; }

  .card { background: #fff; border: 1px solid var(--line-2); border-radius: 24px; padding: 28px 30px; }
  .card.section { margin-top: 24px; }

  /* Plan */
  .plan-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; }
  .plan-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 1.4px; text-transform: uppercase; color: var(--muted); }
  .plan-name { font-family: var(--serif); font-size: 34px; font-weight: 500; letter-spacing: -0.02em; line-height: 1; margin-top: 6px; }
  .plan-name em { font-style: italic; }
  .badge { font-size: 11px; font-weight: 800; letter-spacing: 1px; padding: 6px 12px; border-radius: 999px; }
  .badge.free { background: var(--bg-2); color: var(--ink-2); }
  .badge.pro { background: linear-gradient(90deg,#4d7cff,#b13fe8); color: #fff; }
  .plan.pro { background: linear-gradient(135deg, rgba(77,124,255,0.06), rgba(177,63,232,0.06)); border-color: rgba(77,124,255,0.2); }
  .plan-note { font-size: 14px; color: var(--muted); margin: 16px 0 0; line-height: 1.5; }
  .usage { margin-top: 22px; }
  .usage-row { display: flex; justify-content: space-between; align-items: baseline; font-size: 14px; color: var(--ink-2); }
  .usage-num b { font-family: var(--serif); font-size: 20px; font-weight: 600; }
  .usage-num b.full { color: #c0392b; }
  .meter { height: 10px; border-radius: 999px; background: var(--bg-2); overflow: hidden; margin-top: 10px; }
  .meter-fill { height: 100%; border-radius: 999px; background: #0a0a0a; transition: width 300ms ease; }
  .meter-fill.full { background: #c0392b; }
  .plan-cta { display: flex; align-items: center; gap: 16px; margin-top: 22px; flex-wrap: wrap; }
  .btn-primary { height: 46px; padding: 0 22px; border-radius: 999px; background: #0a0a0a; color: #fff; border: 0; font-size: 14px; font-weight: 600; display: inline-flex; align-items: center; justify-content: center; }
  .btn-primary:hover { background: #1a1a1a; }
  .plan-cta .hint { font-size: 12.5px; color: var(--muted); }

  /* Sections */
  .section-head { display: flex; align-items: baseline; justify-content: space-between; gap: 16px; margin-bottom: 20px; flex-wrap: wrap; }
  .section-head h2 { font-family: var(--serif); font-size: 26px; font-weight: 500; letter-spacing: -0.02em; margin: 0; }
  .section-sub { font-size: 12.5px; color: var(--muted); }
  .empty-note { font-size: 14px; color: var(--muted); margin: 0; line-height: 1.5; }

  /* Tags */
  .tag-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; }
  .tag-row { display: flex; align-items: center; gap: 14px; padding: 14px 0; border-bottom: 1px solid var(--line); }
  .tag-row:last-child { border-bottom: 0; }
  .tag-chip { display: inline-flex; align-items: center; gap: 7px; padding: 5px 12px; border-radius: 999px; font-size: 13px; font-weight: 600; border: 1px solid; }
  .tag-chip .sw { width: 8px; height: 8px; border-radius: 50%; }
  .tag-count { font-size: 12.5px; color: var(--muted); margin-left: auto; }
  .mini { height: 34px; padding: 0 14px; border-radius: 999px; border: 1px solid var(--line); background: transparent; font-size: 12.5px; font-weight: 600; color: var(--ink-2); }
  .mini:hover:not(:disabled) { border-color: rgba(10,10,10,0.3); color: var(--ink); }
  .mini.solid { background: #0a0a0a; color: #fff; border-color: #0a0a0a; }
  .mini.solid:hover:not(:disabled) { background: #1a1a1a; }
  .mini.danger { color: #c0392b; border-color: rgba(192,57,43,0.3); }
  .mini.danger:hover:not(:disabled) { background: rgba(192,57,43,0.06); }
  .tag-row.editing { align-items: stretch; }
  .tag-edit { width: 100%; display: flex; flex-direction: column; gap: 14px; }
  .tag-name-input { height: 44px; padding: 0 14px; border-radius: 12px; border: 1px solid var(--line); background: var(--bg); font-family: var(--sans); font-size: 15px; color: var(--ink); outline: none; }
  .tag-name-input:focus { border-color: rgba(10,10,10,0.4); background: #fff; }
  .swatches { display: flex; flex-wrap: wrap; gap: 8px; }
  .swatch { width: 30px; height: 30px; border-radius: 50%; border: 2px solid transparent; box-shadow: 0 0 0 1px var(--line); }
  .swatch.on { border-color: #fff; box-shadow: 0 0 0 2px #0a0a0a; }
  .edit-actions { display: flex; align-items: center; gap: 8px; }
  .edit-actions .spacer { flex: 1; }

  /* Cookbooks */
  .cb-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  .cb-card { border-radius: 18px; overflow: hidden; transition: transform 180ms ease; }
  .cb-card:hover { transform: translateY(-3px); }
  .cb-cover { aspect-ratio: 3/2; border-radius: 16px; overflow: hidden; background: var(--bg-2); }
  .cb-cover img { width: 100%; height: 100%; object-fit: cover; }
  .cb-ph { width: 100%; height: 100%; display: grid; place-items: center; font-family: var(--serif); font-size: 48px; font-weight: 500; color: rgba(10,10,10,0.18); background: linear-gradient(135deg, var(--bg-2), #e0dcd2); }
  .cb-body { padding: 12px 4px 4px; }
  .cb-body h3 { font-family: var(--serif); font-size: 18px; font-weight: 500; letter-spacing: -0.015em; margin: 0 0 4px; line-height: 1.15; }
  .cb-count { font-size: 12px; color: var(--muted); }

  /* Skeleton */
  .sk-block { border-radius: 24px; background: linear-gradient(90deg, var(--bg-2) 25%, #e0dcd2 50%, var(--bg-2) 75%); background-size: 200% 100%; animation: shimmer 1.4s ease infinite; }
  @keyframes shimmer { to { background-position: -200% 0; } }

  /* Footer */
  footer.rb-footer { background: #0a0a0a; color: rgba(255,255,255,0.7); padding: 56px 0 64px; }
  footer.rb-footer .row { display: flex; justify-content: space-between; align-items: center; gap: 24px; flex-wrap: wrap; max-width: 1000px; }
  footer.rb-footer .brand { display: flex; align-items: center; gap: 10px; color: #fff; font-weight: 700; font-size: 16px; }
  footer.rb-footer .brand .app-ico { width: 28px; height: 28px; border-radius: 7px; box-shadow: 0 0 0 1px rgba(255,255,255,0.12); }
  footer.rb-footer .links { display: flex; gap: 24px; font-size: 14px; }
  footer.rb-footer .links a { color: rgba(255,255,255,0.6); }
  footer.rb-footer .links a:hover { color: #fff; }
  footer.rb-footer .copy { font-size: 13px; color: rgba(255,255,255,0.4); }

  @media (max-width: 900px) { .cb-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 760px) {
    .container { padding: 0 22px; }
    nav.rb-nav ul { display: none; }
    .nav-account .who { display: none; }
    header.page-head { padding: 28px 0 20px; }
    header.page-head h1 { font-size: 44px; }
    .card { padding: 22px 20px; }
    .cb-grid { grid-template-columns: 1fr 1fr; }
    footer.rb-footer .row { flex-direction: column; align-items: flex-start; gap: 18px; }
  }
</style>
