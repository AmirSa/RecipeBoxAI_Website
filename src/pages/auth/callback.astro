---
import BaseLayout from '@layouts/BaseLayout.astro';
import ThemeToggle from '@components/ThemeToggle.astro';
---

<BaseLayout title="Redirecting to App" description="Redirecting you back to RecipeBox AI">
  <div style="position:absolute; top:16px; right:16px;"><ThemeToggle /></div>
  <div class="container">
    <div class="card">
      <div class="logo">🍳 RecipeBox AI</div>
      <h2 id="title">Redirecting to app...</h2>
      <div class="spinner" id="spinner"></div>
      <p id="message">You will be redirected to the app shortly.</p>
      <a href="#" id="manual-link" class="manual-link" style="display: none;">Open RecipeBox AI</a>
      <div id="store-links" class="store-links" style="display: none;">
        <p>Don't have the app yet?</p>
        <a href="https://apps.apple.com/us/app/recipebox-ai/id6752560797" class="store-link ios">Download for iOS</a>
        <a href="https://play.google.com/store/apps/details?id=com.recipeboxai.android" class="store-link android">Download for Android</a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  body {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    min-height: 100vh;
  }

  .container {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .card {
    background: var(--card);
    padding: 40px;
    border-radius: 15px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    text-align: center;
    max-width: 400px;
    width: 100%;
  }

  .logo {
    font-size: 2em;
    font-weight: bold;
    color: #667eea;
    margin-bottom: 20px;
  }

  .spinner {
    border: 4px solid var(--bg-2);
    border-top: 4px solid #667eea;
    border-radius: 50%;
    width: 40px;
    height: 40px;
    animation: spin 1s linear infinite;
    margin: 20px auto;
  }

  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .manual-link {
    margin-top: 20px;
    padding: 12px 24px;
    background: #667eea;
    color: white;
    text-decoration: none;
    border-radius: 8px;
    display: inline-block;
    font-weight: 500;
  }

  .manual-link:hover {
    background: #5a6fd8;
  }

  .store-links {
    margin-top: 30px;
  }

  .store-link {
    display: inline-block;
    margin: 10px;
    padding: 10px 20px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 500;
    color: white;
  }

  .ios { background: #007AFF; }
  .android { background: #34A853; }

  /* Dark-mode overrides for values with no token (rule 12) */
  :global(:root[data-theme="dark"] body) {
    background: linear-gradient(135deg, #3d478f 0%, #4a2f66 100%);
  }
</style>

<script>
  (function () {
    const params = new URLSearchParams(window.location.search);

    // Also capture hash fragment params (Supabase sometimes uses #access_token=...)
    if (window.location.hash) {
      const hashParams = new URLSearchParams(window.location.hash.substring(1));
      hashParams.forEach((value, key) => {
        if (!params.has(key)) params.set(key, value);
      });
    }

    const queryString = params.toString();

    // --- Platform detection ---
    const ua = navigator.userAgent || '';
    const isIOS = /iPhone|iPad|iPod/i.test(ua);
    const isAndroid = /Android/i.test(ua);

    // --- Deep link URLs ---
    const iosLink = `stage4.recipebox-ai-v5://auth/callback${queryString ? '?' + queryString : ''}`;
    const androidLink = `com.recipeboxai.android://callback${queryString ? '?' + queryString : ''}`;

    // Choose the correct deep link for this platform
    let deepLink: string;
    if (isIOS) {
      deepLink = iosLink;
    } else if (isAndroid) {
      deepLink = androidLink;
    } else {
      // Desktop / unknown — default to iOS scheme
      deepLink = iosLink;
    }

    // --- DOM refs ---
    const titleEl = document.getElementById('title')!;
    const messageEl = document.getElementById('message')!;
    const spinnerEl = document.getElementById('spinner')!;
    const manualLink = document.getElementById('manual-link') as HTMLAnchorElement;
    const storeLinks = document.getElementById('store-links')!;

    manualLink.href = deepLink;

    // Hide the Android store link on iOS and vice-versa
    if (isIOS) {
      const androidStoreLink = storeLinks.querySelector('.android') as HTMLElement | null;
      if (androidStoreLink) androidStoreLink.style.display = 'none';
    } else if (isAndroid) {
      const iosStoreLink = storeLinks.querySelector('.ios') as HTMLElement | null;
      if (iosStoreLink) iosStoreLink.style.display = 'none';
    }

    // --- Validate we have something to forward ---
    const hasAuthParams = params.has('token_hash') || params.has('code') ||
                          params.has('access_token') || params.has('refresh_token');

    if (!hasAuthParams) {
      titleEl.textContent = 'Invalid Link';
      messageEl.textContent = 'This authentication link appears to be invalid or expired.';
      spinnerEl.style.display = 'none';
      storeLinks.style.display = 'block';
      return;
    }

    // --- Try auto-redirect ---
    window.location.href = deepLink;

    // Fallback: if the app didn't open within 2.5s, show manual button
    setTimeout(() => {
      titleEl.textContent = 'Open RecipeBox AI';
      messageEl.textContent = 'Tap the button below to open the app and complete authentication.';
      spinnerEl.style.display = 'none';
      manualLink.style.display = 'inline-block';
      storeLinks.style.display = 'block';
    }, 2500);
  })();
</script>
