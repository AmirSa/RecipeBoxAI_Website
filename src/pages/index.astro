  .phone .status { position: absolute; top: 0; left: 0; right: 0; height: 50px; display: flex; align-items: center; justify-content: space-between; padding: 0 28px; font-size: 14px; font-weight: 600; color: #0a0a0a; z-index: 4; }
  .hero-phone { width: 340px; height: 720px; position: absolute; right: 20px; top: 10px; transform: rotate(-3deg); }

  .hero-screen { padding: 64px 18px 18px; height: 100%; display: flex; flex-direction: column; gap: 14px; background: #fff; }
  .hero-screen .title-row { padding: 0 8px; }
  .hero-screen .title-row h2 { margin: 0; font-family: var(--serif); font-size: 24px; font-weight: 500; letter-spacing: -0.02em; line-height: 1.05; }
  .hero-screen .title-row p { margin: 4px 0 0; font-size: 13px; color: var(--muted); }
  .recipe-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; padding: 0 4px; }
  .recipe-card { position: relative; aspect-ratio: 0.86; border-radius: 18px; overflow: hidden; background: #eee; }
  .recipe-card img { width: 100%; height: 100%; object-fit: cover; }
  .recipe-card .scrim { position: absolute; inset: 0; background: linear-gradient(180deg, transparent 40%, rgba(0,0,0,0.65) 100%); }
  .recipe-card .src { position: absolute; top: 8px; left: 8px; padding: 3px 8px; background: rgba(255,255,255,0.92); border-radius: 999px; font-size: 9px; font-weight: 700; letter-spacing: 0.4px; text-transform: uppercase; color: #0a0a0a; }
  .recipe-card .meta { position: absolute; left: 10px; right: 10px; bottom: 10px; color: #fff; }
  .recipe-card .meta h3 { margin: 0; font-family: var(--serif); font-weight: 500; font-size: 15px; line-height: 1.1; letter-spacing: -0.01em; }
  .recipe-card .meta .sub { margin-top: 4px; font-size: 10px; opacity: 0.85; display: flex; gap: 6px; }

  .hero-tabbar { margin-top: auto; display: flex; align-items: center; justify-content: space-around; padding: 12px 8px 14px; border-top: 1px solid var(--line); }
  .hero-tabbar .tab { display: flex; flex-direction: column; align-items: center; gap: 4px; font-size: 10px; color: var(--muted); font-weight: 600; }
  .hero-tabbar .tab.active { color: var(--ink); }
  .hero-tabbar .tab svg { width: 22px; height: 22px; }
  .hero-tabbar .add { width: 44px; height: 44px; border-radius: 50%; background: #0a0a0a; color: #fff; display: grid; place-items: center; margin-top: -4px; }

  /* Sections */
  section { padding: 120px 0; }
  .sec-head { margin-bottom: 56px; }
  .sec-head h2 { font-size: 64px; margin: 14px 0 0; }
  .sec-head .lead { margin-top: 16px; }

  /* Wow moment */
  section.wow { background: #0a0a0a; color: #fff; }
  section.wow .eyebrow { color: rgba(255,255,255,0.55); }
  section.wow h2 { color: #fff; }
  section.wow .lead { color: rgba(255,255,255,0.7); }
  .wow-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; margin-top: 64px; }
  .wow-card { border: 1px solid rgba(255,255,255,0.1); border-radius: 28px; padding: 28px; background: linear-gradient(180deg, rgba(255,255,255,0.04) 0%, rgba(255,255,255,0) 100%); }
  .wow-card .num { font-family: var(--serif); font-size: 56px; line-height: 0.9; color: #fff; opacity: 0.4; font-weight: 400; }
  .wow-card h3 { font-family: var(--serif); font-size: 26px; font-weight: 500; letter-spacing: -0.02em; line-height: 1.05; margin: 16px 0 0; }
  .wow-card p { color: rgba(255,255,255,0.6); font-size: 14.5px; line-height: 1.5; margin: 10px 0 0; }
  .wow-card .mock { margin-top: 22px; height: 220px; border-radius: 18px; overflow: hidden; background: #141416; border: 1px solid rgba(255,255,255,0.08); display: flex; flex-direction: column; }

  .m-paste { padding: 14px; gap: 10px; }
  .m-paste .url { display: flex; align-items: center; gap: 8px; padding: 10px 12px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 12px; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 11.5px; color: rgba(255,255,255,0.9); }
  .m-paste .url .dot { width: 6px; height: 6px; border-radius: 50%; background: #25F4EE; }
  .m-paste .toast { margin-top: auto; padding: 10px 12px; background: rgba(77,124,255,0.15); border: 1px solid rgba(77,124,255,0.35); border-radius: 12px; color: #c0d2ff; font-size: 12px; display: flex; align-items: center; gap: 8px; }
  .m-paste .spinner { width: 14px; height: 14px; border-radius: 50%; border: 2px solid rgba(255,255,255,0.2); border-top-color: #fff; animation: spin 1s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }

  .m-parse { padding: 14px; gap: 6px; }
  .m-parse .line { height: 12px; border-radius: 6px; background: rgba(255,255,255,0.08); position: relative; overflow: hidden; margin-bottom: 8px; }
  .m-parse .line.shimmer::after { content: ""; position: absolute; inset: 0; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent); animation: shimmer 1.6s linear infinite; }
  @keyframes shimmer { from { transform: translateX(-100%); } to { transform: translateX(100%); } }
  .m-parse .reveal { margin-top: 8px; padding: 10px 12px; background: rgba(255,255,255,0.06); border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); display: flex; flex-direction: column; gap: 6px; }
  .m-parse .reveal .t { font-family: var(--serif); font-size: 16px; font-weight: 500; letter-spacing: -0.01em; }
  .m-parse .reveal .m { font-size: 11px; color: rgba(255,255,255,0.55); display: flex; gap: 10px; }

  .m-result { padding: 0; position: relative; }
  .m-result img { width: 100%; height: 130px; object-fit: cover; }
  .m-result .body { padding: 12px 14px; }
  .m-result .body h4 { margin: 0; font-family: var(--serif); font-size: 17px; font-weight: 500; letter-spacing: -0.01em; color: #fff; }
  .m-result .body .row { margin-top: 8px; display: flex; gap: 6px; flex-wrap: wrap; }
  .m-result .body .chip { padding: 4px 9px; border-radius: 999px; font-size: 10.5px; font-weight: 600; background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.85); border: 1px solid rgba(255,255,255,0.1); }
  .m-result .body .macros { margin-top: 10px; display: flex; gap: 14px; font-size: 11px; color: rgba(255,255,255,0.65); }
  .m-result .body .macros b { color: #fff; font-weight: 700; }

  /* Reviews */
  section.reviews { background: var(--bg); }
  .reviews-headline { display: flex; align-items: baseline; gap: 22px; flex-wrap: wrap; }
  .reviews-headline .big { font-family: var(--serif); font-size: 96px; line-height: 0.9; letter-spacing: -0.04em; font-weight: 500; }
  .reviews-headline .big em { font-style: italic; }
  .stars-big { display: inline-flex; gap: 4px; color: #f5a524; }
  .stars-big svg { width: 28px; height: 28px; }
  .review-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; margin-top: 56px; }
  .review { background: #fff; border: 1px solid var(--line); border-radius: 24px; padding: 22px; display: flex; flex-direction: column; gap: 12px; }
  .review .top { display: flex; align-items: center; justify-content: space-between; }
  .review .stars { display: inline-flex; gap: 2px; color: #f5a524; }
  .review .stars svg { width: 14px; height: 14px; }
  .review .when { font-size: 11.5px; color: var(--muted); }
  .review h4 { margin: 0; font-family: var(--serif); font-size: 19px; font-weight: 500; letter-spacing: -0.01em; line-height: 1.15; }
  .review p { margin: 0; font-size: 14px; line-height: 1.5; color: var(--ink-2); }
  .review .author { margin-top: auto; padding-top: 10px; border-top: 1px solid var(--line); font-size: 12.5px; color: var(--muted); display: flex; align-items: center; gap: 8px; }
  .review .author .av { width: 24px; height: 24px; border-radius: 50%; background: var(--bg-2); display: grid; place-items: center; font-weight: 700; color: var(--ink); font-size: 11px; }

  /* Features */
  section.features { background: #fff; }
  .feat-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 18px; margin-top: 56px; }
  .feat { grid-column: span 2; padding: 28px; border-radius: 24px; background: var(--bg); border: 1px solid var(--line-2); display: flex; flex-direction: column; gap: 16px; min-height: 320px; }
  .feat.wide { grid-column: span 3; }
  .feat.full { grid-column: span 6; }
  .feat .ico-box { width: 44px; height: 44px; border-radius: 12px; background: #0a0a0a; color: #fff; display: grid; place-items: center; }
  .feat .ico-box svg { width: 22px; height: 22px; }
  .feat h3 { margin: 0; font-family: var(--serif); font-size: 26px; font-weight: 500; letter-spacing: -0.02em; line-height: 1.1; }
  .feat p { margin: 0; font-size: 14.5px; line-height: 1.5; color: var(--muted); }
  .feat .viz { margin-top: auto; }

  .ai-chips { display: flex; gap: 8px; flex-wrap: wrap; }
  .ai-chip { padding: 7px 12px; border-radius: 999px; border: 1px solid var(--line); background: #fff; font-size: 12px; font-weight: 600; letter-spacing: -0.01em; display: inline-flex; align-items: center; gap: 6px; }
  .ai-chip.grad { background: var(--ai-grad); color: #fff; border-color: transparent; }

  .nutri { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
  .nutri .cell { padding: 12px; background: #fff; border-radius: 14px; border: 1px solid var(--line); }
  .nutri .lbl { font-size: 10.5px; font-weight: 700; letter-spacing: 0.6px; text-transform: uppercase; color: var(--muted); }
  .nutri .val { font-family: var(--serif); font-size: 28px; font-weight: 500; letter-spacing: -0.02em; margin-top: 4px; line-height: 1; }
  .nutri .unit { font-size: 11px; color: var(--muted); margin-top: 2px; }

  .gen-viz { display: flex; flex-direction: column; gap: 10px; }
  .ico-prompt { width: 22px; height: 22px; display: inline-flex; align-items: center; gap: 3px; }
  .ico-prompt span { width: 4px; height: 4px; border-radius: 50%; background: currentColor; animation: prompt-bounce 1.2s ease-in-out infinite; }
  .ico-prompt span:nth-child(2) { animation-delay: 0.15s; }
  .ico-prompt span:nth-child(3) { animation-delay: 0.3s; }
  @keyframes prompt-bounce { 0%, 60%, 100% { transform: translateY(0); opacity: 0.55; } 30% { transform: translateY(-3px); opacity: 1; } }
  .gen-prompt { padding: 10px 12px; background: #fff; border: 1px solid var(--line); border-radius: 12px; font-size: 12px; color: var(--muted); display: flex; align-items: center; gap: 8px; }
  .gen-prompt b { color: var(--ink); font-weight: 600; }
  .gen-chips { display: flex; flex-wrap: wrap; gap: 6px; }
  .gen-chip { padding: 5px 11px; border-radius: 999px; background: #fff; border: 1px solid var(--line); font-size: 11.5px; font-weight: 600; color: var(--ink-2); display: inline-flex; align-items: center; gap: 4px; }
  .gen-chip .x { color: var(--muted); font-size: 14px; line-height: 1; }
  .gen-chip.add { border-style: dashed; color: var(--muted); }
  .gen-out { margin-top: 4px; padding: 10px 12px; border-radius: 12px; background: var(--ai-grad); color: #fff; display: flex; align-items: center; gap: 10px; }
  .gen-out .spark { width: 16px; height: 16px; flex-shrink: 0; }
  .gen-out .title { font-family: var(--serif); font-size: 16px; font-weight: 500; letter-spacing: -0.01em; line-height: 1.1; }
  .gen-out .meta { font-size: 10.5px; opacity: 0.85; margin-top: 2px; }

  .search-viz { display: flex; flex-direction: column; gap: 10px; }
  .search-bar { background: #fff; border: 1px solid var(--line); border-radius: 12px; padding: 10px 14px; display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--ink-2); }
  .search-bar .cursor { display: inline-block; width: 1.5px; height: 14px; background: var(--ink); animation: blink 1s steps(1) infinite; }
  @keyframes blink { 50% { opacity: 0; } }
  .search-tags { display: flex; gap: 6px; flex-wrap: wrap; }
  .search-tag { padding: 5px 10px; border-radius: 999px; background: #fff; border: 1px solid var(--line); font-size: 11.5px; font-weight: 600; color: var(--ink-2); }
  .search-tag.active { background: #0a0a0a; color: #fff; border-color: #0a0a0a; }

  .privacy { padding: 22px; background: #fff; border: 1px solid var(--line); border-radius: 18px; display: flex; align-items: center; gap: 14px; }
  .privacy .lock { width: 44px; height: 44px; border-radius: 12px; background: var(--bg-2); display: grid; place-items: center; }
  .privacy .text { font-size: 13px; line-height: 1.4; color: var(--ink-2); }
  .privacy .text b { color: var(--ink); font-weight: 700; }

  .scan-feat { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: center; }
  .scan-mock { position: relative; border-radius: 22px; overflow: hidden; aspect-ratio: 4/5; background: #1f1c17; }
  .scan-mock .page-bg { position: absolute; inset: 0; background: radial-gradient(ellipse at center, rgba(0,0,0,0) 50%, rgba(0,0,0,0.55) 100%), linear-gradient(135deg, #faf5ec 0%, #f0e8d6 100%); }
  .scan-mock .gutter { position: absolute; top: 0; bottom: 0; left: 0; width: 22%; background: linear-gradient(90deg, rgba(0,0,0,0.18) 0%, rgba(0,0,0,0) 100%); pointer-events: none; }
  .scan-mock .page { position: absolute; inset: 5% 9% 5% 22%; font-family: var(--serif); color: #1a160e; display: flex; flex-direction: column; }
  .scan-mock .page .brand-line { font-family: var(--serif); font-style: italic; font-size: 14px; color: #8a3a2a; letter-spacing: 0.5px; text-align: center; margin-bottom: 8px; }
  .scan-mock .page .brand-line b { font-style: normal; font-weight: 700; color: #1a160e; margin-right: 4px; }
  .scan-mock .page .title { font-family: var(--serif); font-size: 38px; font-weight: 500; letter-spacing: -0.02em; line-height: 1; text-align: center; margin: 0; }
  .scan-mock .page .subtitle { font-family: var(--serif); font-size: 19px; font-weight: 400; letter-spacing: -0.01em; text-align: center; margin: 4px 0 0; }
  .scan-mock .page .blurb { font-family: var(--serif); font-size: 11.5px; line-height: 1.4; text-align: center; margin: 14px 24px 0; color: #2a221a; font-style: italic; }
  .scan-mock .page .blurb b { font-style: italic; color: #8a6a30; font-weight: 500; }
  .scan-mock .page .columns { margin-top: 20px; display: grid; grid-template-columns: 0.65fr 1fr; gap: 16px; flex: 1; min-width: 0; }
  .scan-mock .page .columns > * { min-width: 0; }
  .scan-mock .page .ingr-head { font-family: var(--sans); font-size: 10px; font-weight: 800; letter-spacing: 1.2px; color: #8a3a2a; text-transform: uppercase; }
  .scan-mock .page .ingr-serves { font-size: 9.5px; color: #6a5a40; margin-top: 1px; font-family: var(--sans); }
  .scan-mock .page .ingr-list { margin-top: 8px; display: flex; flex-direction: column; gap: 4px; padding: 0; list-style: none; }
  .scan-mock .page .ingr-list li { font-family: var(--sans); font-size: 9.5px; line-height: 1.35; color: #2a221a; padding: 2px 0; border-bottom: 1px solid rgba(26,22,14,0.08); }
  .scan-mock .page .method h4 { font-family: var(--serif); font-style: italic; font-size: 13px; font-weight: 500; margin: 0 0 4px; color: #1a160e; }
  .scan-mock .page .method p { font-family: var(--serif); font-size: 9.5px; line-height: 1.45; margin: 0 0 8px; color: #2a221a; overflow-wrap: break-word; }
  .scan-mock .page .pagenum { font-family: var(--sans); font-size: 9px; letter-spacing: 0.8px; color: #8a6a30; text-align: right; margin-top: 8px; text-transform: uppercase; }
  .scan-mock .vignette { position: absolute; inset: 0; pointer-events: none; background: radial-gradient(ellipse at center, transparent 55%, rgba(0,0,0,0.35) 100%); }
  .scan-mock .reticle { position: absolute; left: 10%; right: 10%; top: 8%; bottom: 22%; border: 3px solid rgba(255,255,255,1); border-radius: 12px; box-shadow: 0 0 0 9999px rgba(0,0,0,0.22), 0 0 20px rgba(77,124,255,0.4); }
  .scan-mock .reticle::before, .scan-mock .reticle::after, .scan-mock .reticle > span::before, .scan-mock .reticle > span::after { content: ""; position: absolute; width: 28px; height: 28px; border: 4px solid #fff; }
  .scan-mock .reticle::before { top: -3px; left: -3px; border-right: 0; border-bottom: 0; border-top-left-radius: 8px; }
  .scan-mock .reticle::after { top: -3px; right: -3px; border-left: 0; border-bottom: 0; border-top-right-radius: 8px; }
  .scan-mock .reticle > span::before { bottom: -3px; left: -3px; border-right: 0; border-top: 0; border-bottom-left-radius: 8px; }
  .scan-mock .reticle > span::after { bottom: -3px; right: -3px; border-left: 0; border-top: 0; border-bottom-right-radius: 8px; }
  .scan-mock .scanline { position: absolute; left: 18%; right: 18%; top: 50%; height: 2px; background: linear-gradient(90deg, transparent, #4d7cff, transparent); box-shadow: 0 0 14px #4d7cff; }

  /* Transform showcase */
  section.transform-show { background: var(--bg); }
  .tx-grid { display: grid; grid-template-columns: 0.95fr 1.05fr; gap: 72px; align-items: center; }
  .tx-phone-wrap { display: grid; place-items: center; }
  .tx-cards { display: flex; flex-direction: column; gap: 14px; }
  .tx-card { padding: 22px 24px; background: #fff; border: 1px solid var(--line); border-radius: 20px; }
  .tx-card h4 { margin: 0; font-family: var(--serif); font-size: 24px; font-weight: 500; letter-spacing: -0.02em; }
  .tx-card .row { margin-top: 10px; display: flex; gap: 8px; flex-wrap: wrap; }
  .tx-card .chip { padding: 7px 12px; border-radius: 999px; font-size: 12.5px; font-weight: 600; background: var(--bg); border: 1px solid var(--line-2); color: var(--ink-2); cursor: pointer; user-select: none; transition: background 140ms ease, color 140ms ease, border-color 140ms ease; }
  .tx-card .chip.on { background: var(--ai-grad); color: #fff; border-color: transparent; }
  .tx-card p { margin: 12px 0 0; font-size: 13.5px; line-height: 1.5; color: var(--muted); }
  .tx-phone { width: 320px; height: 660px; }
  .tx-screen { display: flex; flex-direction: column; height: 100%; padding-top: 50px; }
  .tx-screen .hero-img { height: 220px; position: relative; }
  .tx-screen .hero-img img { width: 100%; height: 100%; object-fit: cover; }
  .tx-screen .hero-img .badge { position: absolute; left: 14px; top: 14px; padding: 5px 11px; border-radius: 999px; background: var(--ai-grad); color: #fff; font-size: 10.5px; font-weight: 700; letter-spacing: 0.6px; text-transform: uppercase; display: inline-flex; align-items: center; gap: 5px; }
  .tx-screen .badge svg { width: 12px; height: 12px; }
  .tx-screen .body { padding: 18px 18px 0; flex: 1; }
  .tx-screen .body h3 { margin: 0; font-family: var(--serif); font-size: 22px; font-weight: 500; letter-spacing: -0.02em; }
  .tx-screen .body .ingr-list { margin-top: 14px; display: flex; flex-direction: column; gap: 8px; }
  .tx-screen .ingr { display: flex; justify-content: space-between; align-items: center; padding: 10px 12px; background: var(--bg); border-radius: 12px; font-size: 13px; font-weight: 500; transition: background 200ms ease; }
  .tx-screen .ingr .qty { color: var(--muted); font-size: 12.5px; font-weight: 600; }
  .tx-screen .ingr.swapped { background: rgba(77,124,255,0.08); }
  .tx-screen .ingr.swapped .qty { color: #4d7cff; }
  .tx-screen .ingr.swapped::before { content: "AI"; padding: 2px 6px; background: var(--ai-grad); color: #fff; font-size: 9px; font-weight: 800; letter-spacing: 0.4px; border-radius: 999px; margin-right: 8px; }

  /* Recipes gallery */
  section.recipes-band { background: #fff; }
  .rec-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-top: 48px; }
  .rec-card { position: relative; aspect-ratio: 0.78; border-radius: 22px; overflow: hidden; background: #eee; color: #fff; }
  .rec-card img { width: 100%; height: 100%; object-fit: cover; transition: transform 400ms ease; }
  .rec-card:hover img { transform: scale(1.05); }
  .rec-card .scrim { position: absolute; inset: 0; background: linear-gradient(180deg, transparent 45%, rgba(0,0,0,0.7) 100%); }
  .rec-card .src { position: absolute; top: 12px; left: 12px; padding: 4px 10px; background: rgba(255,255,255,0.94); color: #0a0a0a; border-radius: 999px; font-size: 10px; font-weight: 700; letter-spacing: 0.4px; text-transform: uppercase; }
  .rec-card .meta { position: absolute; left: 16px; right: 16px; bottom: 16px; }
  .rec-card .meta h3 { margin: 0; font-family: var(--serif); font-weight: 500; font-size: 22px; line-height: 1.05; letter-spacing: -0.02em; }
  .rec-card .meta .sub { margin-top: 6px; font-size: 12px; opacity: 0.9; display: flex; gap: 12px; }
  .browse-cta { margin-top: 36px; display: flex; justify-content: center; }

  /* Personas */
  section.personas { background: var(--bg); }
  .pers-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-top: 48px; }
  .persona { padding: 28px; background: #fff; border: 1px solid var(--line-2); border-radius: 22px; display: flex; flex-direction: column; gap: 12px; min-height: 240px; }
  .persona .ico-line { width: 44px; height: 44px; border-radius: 12px; background: var(--bg-2); display: grid; place-items: center; }
  .persona .ico-line svg { width: 22px; height: 22px; stroke: var(--ink); }
  .persona h3 { margin: 0; font-family: var(--serif); font-size: 22px; font-weight: 500; letter-spacing: -0.02em; }
  .persona p { margin: 0; font-size: 14px; line-height: 1.5; color: var(--muted); }
  .persona .ex { margin-top: auto; font-size: 12px; color: var(--ink-2); font-weight: 600; padding-top: 12px; border-top: 1px solid var(--line); }

  /* Closer */
  section.closer { background: #0a0a0a; color: #fff; padding: 140px 0; }
  section.closer h2 { font-size: 104px; color: #fff; margin: 14px 0 0; max-width: 13ch; }
  section.closer .lead { color: rgba(255,255,255,0.65); margin-top: 28px; font-size: 20px; max-width: 50ch; }
  section.closer .btn-primary { background: #fff; color: #0a0a0a; box-shadow: 0 1px 0 rgba(0,0,0,0.08), 0 14px 40px rgba(255,255,255,0.18); margin-top: 40px; }
  section.closer .small { margin-top: 22px; font-size: 13px; color: rgba(255,255,255,0.45); }

  /* Footer */
  footer.rb-footer { background: #0a0a0a; color: rgba(255,255,255,0.7); padding: 56px 0 64px; border-top: 1px solid rgba(255,255,255,0.08); }
  footer.rb-footer .row { display: flex; justify-content: space-between; align-items: center; gap: 24px; flex-wrap: wrap; }
  footer.rb-footer .brand { display: flex; align-items: center; gap: 10px; color: #fff; font-weight: 700; letter-spacing: -0.02em; font-size: 16px; }
  footer.rb-footer .brand .app-ico { width: 28px; height: 28px; border-radius: 7px; box-shadow: 0 0 0 1px rgba(255,255,255,0.12); }
  footer.rb-footer .links { display: flex; gap: 24px; font-size: 14px; }
  footer.rb-footer .links a { color: rgba(255,255,255,0.6); }
  footer.rb-footer .links a:hover { color: #fff; }
  footer.rb-footer .copy { font-size: 13px; color: rgba(255,255,255,0.4); }

  /* Responsive */
  @media (max-width: 1100px) {
    .container, .container-tight { padding: 0 32px; }
    .hero-h1 { font-size: 72px; }
    .sec-head h2 { font-size: 52px; }
    .reviews-headline .big { font-size: 72px; }
