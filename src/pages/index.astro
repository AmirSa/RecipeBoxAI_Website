  <script is:inline>
    (function() {
      const MODES = {
        original: { label: null, ingredients: [
          { name: 'Pork dumplings', qty: '8' },
          { name: 'Coconut milk', qty: '200 ml' },
          { name: 'Chicken stock', qty: '500 ml' },
          { name: 'Garlic, minced', qty: '3 cloves' },
          { name: 'Ginger, grated', qty: '1 tbsp' },
          { name: 'Spring onions', qty: '3 stalks' },
        ]},
        vegan: { label: 'Vegan', ingredients: [
          { name: 'Tofu, cubed', qty: '300 g', swap: true },
          { name: 'Cashew cream', qty: '120 ml', swap: true },
          { name: 'Vegetable stock', qty: '500 ml', swap: true },
          { name: 'Garlic, minced', qty: '3 cloves' },
          { name: 'Ginger, grated', qty: '1 tbsp' },
          { name: 'Spring onions', qty: '3 stalks' },
        ]},
        protein: { label: 'High Protein', ingredients: [
          { name: 'Chicken thigh', qty: '400 g', swap: true },
          { name: 'Greek yogurt', qty: '150 g', swap: true },
          { name: 'Egg whites', qty: '4', swap: true },
          { name: 'Garlic, minced', qty: '3 cloves' },
          { name: 'Ginger, grated', qty: '1 tbsp' },
          { name: 'Spring onions', qty: '3 stalks' },
        ]},
        kid: { label: 'Kid-friendly', ingredients: [
          { name: 'Chicken tenders', qty: '300 g', swap: true },
          { name: 'Mild soy sauce', qty: '2 tbsp', swap: true },
          { name: 'Honey', qty: '1 tbsp', swap: true },
          { name: 'Garlic, minced', qty: '2 cloves' },
          { name: 'Carrots, diced', qty: '1 cup' },
          { name: 'Rice noodles', qty: '200 g' },
        ]},
      };
      const list = document.getElementById('tx-ingredients');
      const badge = document.getElementById('tx-badge');
      const badgeLabel = document.getElementById('tx-badge-label');
      const modeRow = document.getElementById('tx-modes');

      function render(mode) {
        const data = MODES[mode];
        if (!data) return;
        if (data.label) { badge.style.display = 'inline-flex'; badgeLabel.textContent = data.label; }
        else { badge.style.display = 'none'; }
        list.innerHTML = data.ingredients.map(ing => {
          const swapped = ing.swap && mode !== 'original';
          return `<div class="ingr${swapped ? ' swapped' : ''}"><span class="name">${ing.name}</span><span class="qty">${ing.qty}</span></div>`;
        }).join('');
      }
      modeRow.addEventListener('click', e => {
        const chip = e.target.closest('.chip');
        if (!chip) return;
        modeRow.querySelectorAll('.chip').forEach(c => c.classList.remove('on'));
        chip.classList.add('on');
        render(chip.dataset.mode);
      });
      render('protein');
    })();
  </script>
</BaseLayout>

<style is:global>
  :root {
    --bg: #f0eee9;
    --bg-2: #e9e6df;
    --ink: #0a0a0a;
    --ink-2: #2a2a2c;
    --muted: #6e6e73;
    --line: rgba(10,10,10,0.08);
    --line-2: rgba(10,10,10,0.04);
    --serif: "Fraunces", "PP Editorial New", Georgia, serif;
    --sans: "Inter Tight", -apple-system, BlinkMacSystemFont, "SF Pro Text", system-ui, sans-serif;
    --ai-grad: linear-gradient(90deg, #4d7cff 0%, #b13fe8 100%);
  }
  *, *::before, *::after { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; background: var(--bg); color: var(--ink); font-family: var(--sans); line-height: 1.45; }
  body { -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility; overflow-x: hidden; }
  ::selection { background: #0a0a0a; color: #fff; }
  img { display: block; max-width: 100%; }
  a { color: inherit; text-decoration: none; }
  button { font: inherit; cursor: pointer; }

  .container { max-width: 1280px; margin: 0 auto; padding: 0 56px; }
  .container-tight { max-width: 1100px; margin: 0 auto; padding: 0 56px; }
  .eyebrow { font-family: var(--sans); font-size: 12px; font-weight: 600; letter-spacing: 1.6px; text-transform: uppercase; color: var(--muted); }
  .display { font-family: var(--serif); font-weight: 400; font-variation-settings: "opsz" 144; line-height: 0.96; letter-spacing: -0.035em; color: var(--ink); text-wrap: balance; }
  .display em { font-style: italic; font-weight: 400; color: var(--ink); }
  .lead { font-family: var(--sans); font-size: 19px; line-height: 1.45; color: var(--ink-2); letter-spacing: -0.01em; max-width: 56ch; text-wrap: pretty; }

  /* CTAs */
  .cta-row { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
  .btn-primary { height: 56px; padding: 0 24px; border-radius: 999px; background: #0a0a0a; color: #fff; border: 0; font-family: var(--sans); font-size: 16px; font-weight: 600; letter-spacing: -0.01em; display: inline-flex; align-items: center; gap: 12px; box-shadow: 0 1px 0 rgba(0,0,0,0.08), 0 10px 30px rgba(0,0,0,0.18); transition: transform 140ms ease, box-shadow 140ms ease; }
  .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 1px 0 rgba(0,0,0,0.08), 0 14px 40px rgba(0,0,0,0.22); }
  .btn-secondary { height: 56px; padding: 0 22px; border-radius: 999px; background: transparent; color: var(--ink); border: 1.5px solid rgba(10,10,10,0.18); font-family: var(--sans); font-size: 16px; font-weight: 600; letter-spacing: -0.01em; display: inline-flex; align-items: center; gap: 10px; }
  .btn-secondary:hover { border-color: rgba(10,10,10,0.38); }

  /* Nav */
  nav.rb-nav { position: sticky; top: 0; z-index: 50; backdrop-filter: saturate(180%) blur(14px); -webkit-backdrop-filter: saturate(180%) blur(14px); background: color-mix(in srgb, var(--bg) 86%, transparent); border-bottom: 1px solid var(--line-2); }
  nav.rb-nav .inner { display: flex; align-items: center; justify-content: space-between; height: 64px; }
  nav.rb-nav .brand { display: flex; align-items: center; gap: 10px; font-weight: 700; letter-spacing: -0.02em; font-size: 17px; color: var(--ink); }
  nav.rb-nav .brand .app-ico { width: 30px; height: 30px; border-radius: 7px; box-shadow: 0 1px 2px rgba(0,0,0,0.18); }
  nav.rb-nav ul { list-style: none; padding: 0; margin: 0; display: flex; gap: 28px; }
  nav.rb-nav ul a { font-size: 14px; font-weight: 500; color: var(--ink-2); }
  nav.rb-nav ul a:hover { color: var(--ink); }
  nav.rb-nav .download { height: 38px; padding: 0 16px; border-radius: 999px; background: #0a0a0a; color: #fff; font-size: 13px; font-weight: 600; display: inline-flex; align-items: center; gap: 8px; }

  /* Hero */
  section.hero { padding: 56px 0 80px; position: relative; overflow: hidden; }
  .hero-grid { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 64px; align-items: center; }
  .hero-h1 { font-size: 96px; margin: 18px 0 0; }
  .hero-lead { margin-top: 22px; font-size: 20px; }
  .hero-meta { margin-top: 22px; display: flex; gap: 18px; align-items: center; flex-wrap: wrap; font-size: 13px; color: var(--muted); }
  .hero-meta .stars { display: inline-flex; gap: 2px; color: #f5a524; }
  .hero-meta strong { color: var(--ink); font-weight: 700; }

  .channels { margin-top: 36px; display: flex; align-items: center; gap: 18px; flex-wrap: wrap; padding: 18px 22px; background: rgba(255,255,255,0.6); border: 1px solid var(--line-2); border-radius: 18px; max-width: 560px; backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); }
  .channels .label { font-size: 12px; font-weight: 600; letter-spacing: 0.8px; text-transform: uppercase; color: var(--muted); margin-right: 4px; }
  .channels .logos { display: flex; gap: 10px; align-items: center; }
  .ch-chip { width: 36px; height: 36px; border-radius: 10px; display: grid; place-items: center; box-shadow: 0 1px 0 rgba(0,0,0,0.06), 0 4px 10px rgba(0,0,0,0.06); }
