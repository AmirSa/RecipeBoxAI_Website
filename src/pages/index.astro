---
import BaseLayout from '@layouts/BaseLayout.astro';
import NavAccount from '@components/NavAccount.astro';
import { supabase } from '../lib/supabase';

// Fetch 4 recipes for the gallery section so links resolve to real pages
const { data: galleryRecipes } = await supabase
  .from('shared_recipes')
  .select('slug, title, prep_time, cook_time, calories, tags, image_url')
  .eq('is_published', true)
  .order('is_featured', { ascending: false })
  .order('view_count', { ascending: false })
  .limit(4);

type Tags = { mealType?: string; cuisine?: string; diet?: string };
const gallery = (galleryRecipes || []).map((r) => {
  const tags = (r.tags || {}) as Tags;
  return {
    slug: r.slug,
    title: r.title,
    totalTime: (r.prep_time || 0) + (r.cook_time || 0),
    calories: r.calories,
    cuisine: tags.cuisine || 'Recipe',
    image: r.image_url || '',
  };
});

const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'MobileApplication',
  name: 'RecipeBox AI',
  description: 'AI-powered recipe manager with nutrition tracking, recipe scanning, and personalized meal adaptations.',
  applicationCategory: 'LifestyleApplication',
  operatingSystem: 'iOS',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '5', ratingCount: '9' },
  author: { '@type': 'Organization', name: 'RecipeBox AI' },
  screenshot: 'https://recipeboxai.app/app-icon.png',
  downloadUrl: 'https://apps.apple.com/gb/app/recipebox-ai/id6752560797',
};
---

<BaseLayout title="Save any recipe. From anywhere." description="Paste a TikTok, scan a cookbook, drop a YouTube link. RecipeBox AI turns it into a clean, structured recipe with macros — in seconds. Free on iOS.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,800&family=Inter+Tight:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />

  <!-- ─── Nav ─── -->
  <nav class="rb-nav">
    <div class="container inner">
      <a class="brand" href="/">
        <img class="app-ico" src="/app-icon.png" alt="">
        RecipeBox AI
      </a>
      <ul>
        <li><a href="#features">Features</a></li>
        <li><a href="/recipes/">Recipes</a></li>
        <li><a href="/my/recipes/">My Recipes</a></li>
        <li><a href="/my/cookbooks/">Cookbooks</a></li>
        <li><a href="#reviews">Reviews</a></li>
      </ul>
      <a class="download" id="nav-download" href="https://apps.apple.com/gb/app/recipebox-ai/id6752560797">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.06 13.28c-.02-2.45 2-3.62 2.09-3.68-1.14-1.67-2.91-1.9-3.54-1.93-1.51-.15-2.94.89-3.71.89-.78 0-1.96-.86-3.22-.84-1.66.02-3.19.96-4.04 2.45-1.72 2.98-.44 7.4 1.24 9.82.82 1.18 1.8 2.52 3.06 2.47 1.23-.05 1.7-.8 3.19-.8 1.48 0 1.9.8 3.2.78 1.32-.02 2.15-1.2 2.96-2.39.93-1.37 1.32-2.71 1.34-2.78-.03-.01-2.57-.98-2.59-3.89zM14.6 6.06c.67-.81 1.13-1.94.99-3.06-.97.04-2.13.65-2.83 1.45-.62.71-1.18 1.86-1.03 2.96 1.09.09 2.2-.55 2.87-1.35z"/></svg>
        Download
      </a>
      <NavAccount />
    </div>
  </nav>

  <!-- ─── Hero ─── -->
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <div class="eyebrow">RecipeBox AI · iOS</div>
        <h1 class="display hero-h1">Save any recipe.<br><em>From anywhere.</em></h1>
        <p class="lead hero-lead">Paste a TikTok, scan a cookbook, drop a YouTube link. RecipeBox AI turns it into a clean, structured recipe with macros — in seconds.</p>
        <div class="cta-row" style="margin-top: 32px;">
          <a class="btn-primary" href="https://apps.apple.com/gb/app/recipebox-ai/id6752560797">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.06 13.28c-.02-2.45 2-3.62 2.09-3.68-1.14-1.67-2.91-1.9-3.54-1.93-1.51-.15-2.94.89-3.71.89-.78 0-1.96-.86-3.22-.84-1.66.02-3.19.96-4.04 2.45-1.72 2.98-.44 7.4 1.24 9.82.82 1.18 1.8 2.52 3.06 2.47 1.23-.05 1.7-.8 3.19-.8 1.48 0 1.9.8 3.2.78 1.32-.02 2.15-1.2 2.96-2.39.93-1.37 1.32-2.71 1.34-2.78-.03-.01-2.57-.98-2.59-3.89zM14.6 6.06c.67-.81 1.13-1.94.99-3.06-.97.04-2.13.65-2.83 1.45-.62.71-1.18 1.86-1.03 2.96 1.09.09 2.2-.55 2.87-1.35z"/></svg>
            Download for iOS
          </a>
        </div>
        <div class="hero-meta">
          <span class="stars">
            {[1,2,3,4,5].map(() => (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.9 6.4 6.9.7-5.2 4.7 1.5 6.8L12 17l-6.1 3.6 1.5-6.8L2.2 9.1l6.9-.7L12 2z"/></svg>
            ))}
          </span>
          <strong>Every review is 5 stars</strong>
          <span>· Free to download</span>
        </div>

        <div class="channels">
          <span class="label">Save from</span>
          <div class="logos">
            <div class="ch-chip" style="background:#000;"><svg viewBox="0 0 48 48"><path fill="#25F4EE" d="M19 16v14a4 4 0 1 1-4-4v-4a8 8 0 1 0 8 8V20a10 10 0 0 0 6 2v-4a6 6 0 0 1-6-6h-4z"/><path fill="#FE2C55" d="M21 14v14a4 4 0 1 1-4-4v-4a8 8 0 1 0 8 8V18a10 10 0 0 0 6 2v-4a6 6 0 0 1-6-6h-4z"/><path fill="#fff" d="M20 15v14a4 4 0 1 1-4-4v-4a8 8 0 1 0 8 8V19a10 10 0 0 0 6 2v-4a6 6 0 0 1-6-6h-4z"/></svg></div>
            <div class="ch-chip" style="background:radial-gradient(circle at 30% 110%, #ffd521 0%, #ff5a3a 30%, #d300c5 65%, #7638fa 100%);"><svg viewBox="0 0 48 48" fill="none" stroke="#fff" stroke-width="3"><rect x="8" y="8" width="32" height="32" rx="8"/><circle cx="24" cy="24" r="7"/><circle cx="33" cy="15" r="2" fill="#fff" stroke="none"/></svg></div>
            <div class="ch-chip" style="background:#FF0000;"><svg viewBox="0 0 48 48"><rect x="6" y="12" width="36" height="24" rx="6" fill="#fff"/><path d="M21 19v10l9-5z" fill="#FF0000"/></svg></div>
            <div class="ch-chip" style="background:#f3f4f6;"><svg viewBox="0 0 48 48" fill="none" stroke="#111" stroke-width="2.5" stroke-linecap="round"><circle cx="24" cy="24" r="14"/><path d="M10 24h28M24 10c4 4 6 9 6 14s-2 10-6 14M24 10c-4 4-6 9-6 14s2 10 6 14"/></svg></div>
            <div class="ch-chip" style="background:#E60023;"><svg viewBox="0 0 48 48"><circle cx="24" cy="24" r="16" fill="#fff"/><path d="M24 12c-6 0-10 4-10 9 0 3 1 5 3 6 0 0 .3.1.4-.2.1-.2.3-1.1.4-1.4.1-.4 0-.5-.2-.8-.5-.6-.8-1.3-.8-2.4 0-3.1 2.3-5.9 6-5.9 3.3 0 5.1 2 5.1 4.7 0 3.6-1.6 6.6-3.9 6.6-1.3 0-2.3-1.1-2-2.4.4-1.5 1.2-3.2 1.2-4.3 0-1-.5-1.8-1.6-1.8-1.3 0-2.3 1.3-2.3 3.1 0 1.1.4 1.9.4 1.9l-1.5 6.5c-.5 1.9-.1 4.3-.1 4.5 0 .1.2.1.2 0 .1-.1 1.5-1.9 2-3.7.1-.5.8-3.1.8-3.1.4.7 1.5 1.3 2.7 1.3 3.6 0 6-3.3 6-7.7C30 14.7 27 12 24 12z" fill="#E60023"/></svg></div>
          </div>
        </div>
      </div>

      <div class="hero-phone-stage">
        <div class="phone hero-phone">
          <div class="notch"></div>
          <div class="status">
            <span>9:41</span>
            <span style="display:inline-flex;gap:5px;align-items:center;">
              <svg width="16" height="11" viewBox="0 0 16 11" fill="currentColor"><rect x="0" y="6" width="3" height="5" rx="0.5"/><rect x="4" y="4" width="3" height="7" rx="0.5"/><rect x="8" y="2" width="3" height="9" rx="0.5"/><rect x="12" y="0" width="3" height="11" rx="0.5"/></svg>
              <svg width="22" height="11" viewBox="0 0 22 11" fill="none" stroke="currentColor" stroke-width="1"><rect x="0.5" y="0.5" width="18" height="10" rx="2"/><rect x="2" y="2" width="15" height="7" rx="1" fill="currentColor"/></svg>
            </span>
          </div>
          <div class="screen">
            <div class="hero-screen">
              <div class="title-row">
                <h2>Your library</h2>
                <p>24 recipes · all synced</p>
              </div>
              <div class="recipe-grid">
                <div class="recipe-card">
                  <img src="https://images.unsplash.com/photo-1591814468924-caf88d1232e1?w=600&q=80&auto=format&fit=crop" alt="">
                  <div class="scrim"></div>
                  <div class="src">TikTok</div>
                  <div class="meta"><h3>Dumpling Ramen</h3><div class="sub"><span>20 min</span><span>375 kcal</span></div></div>
                </div>
                <div class="recipe-card">
                  <img src="https://images.unsplash.com/photo-1551183053-bf91a1d81141?w=600&q=80&auto=format&fit=crop" alt="">
                  <div class="scrim"></div>
                  <div class="src">Instagram</div>
                  <div class="meta"><h3>Peanut Chilli Noodles</h3><div class="sub"><span>16 min</span><span>420 kcal</span></div></div>
                </div>
                <div class="recipe-card">
                  <img src="https://images.unsplash.com/photo-1604908176997-125f25cc6f3d?w=600&q=80&auto=format&fit=crop" alt="">
                  <div class="scrim"></div>
                  <div class="src">YouTube</div>
                  <div class="meta"><h3>Gochujang Chicken</h3><div class="sub"><span>40 min</span><span>510 kcal</span></div></div>
                </div>
                <div class="recipe-card">
                  <img src="https://images.unsplash.com/photo-1540420773420-3366772f4999?w=600&q=80&auto=format&fit=crop" alt="">
                  <div class="scrim"></div>
                  <div class="src">Web</div>
                  <div class="meta"><h3>Chickpea & Feta</h3><div class="sub"><span>15 min</span><span>320 kcal</span></div></div>
                </div>
              </div>
              <div class="hero-tabbar">
                <div class="tab active">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M7 2v9a2 2 0 002 2v9"/><path d="M5 2v5a2 2 0 002 2"/><path d="M9 2v5"/><path d="M17 2v20"/><path d="M17 14c-2 0-3-1.5-3-4V5a3 3 0 016 0v5c0 2.5-1 4-3 4z"/></svg>
                  My Recipes
                </div>
                <div class="tab">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.6 4.4L18 9l-4.4 1.6L12 15l-1.6-4.4L6 9l4.4-1.6z"/><path d="M19 14l.8 2.2L22 17l-2.2.8L19 20l-.8-2.2L16 17l2.2-.8z"/><path d="M5 16l.6 1.4L7 18l-1.4.6L5 20l-.6-1.4L3 18l1.4-.6z"/></svg>
                  Discover
                </div>
                <div class="add">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
                </div>
                <div class="tab">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h7a3 3 0 013 3v14a2 2 0 00-2-2H4z"/><path d="M20 4h-7a3 3 0 00-3 3v14a2 2 0 012-2h8z"/></svg>
                  Cookbooks
                </div>
                <div class="tab">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0116 0"/></svg>
                  Account
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Wow moment ─── -->
  <section class="wow">
    <div class="container">
      <div class="sec-head" style="max-width: 880px;">
        <div class="eyebrow">The 90-second promise</div>
        <h2 class="display">From a link to a <em>real recipe</em> in under four seconds.</h2>
        <p class="lead">Other apps save links. RecipeBox AI watches the video, reads the page, then writes a clean recipe — ingredients, steps, macros, and a photo — and drops it into your library.</p>
      </div>
      <div class="wow-grid">
        <div class="wow-card">
          <div class="num">01</div>
          <h3>Paste, or share.</h3>
          <p>From TikTok, Insta, YouTube, or anywhere on the web. The share sheet does the rest.</p>
          <div class="mock m-paste">
            <div class="url"><span class="dot"></span>tiktok.com/@chef/video/725...</div>
            <div class="url" style="opacity:0.55;"><span class="dot" style="background:#FE2C55;"></span>instagram.com/reel/CqXf12...</div>
            <div class="toast"><span class="spinner"></span>Importing — 2 of 2</div>
          </div>
        </div>
        <div class="wow-card">
          <div class="num">02</div>
          <h3>AI structures it.</h3>
          <p>Ingredients, quantities, steps, and macros — extracted, cleaned, and ready to cook.</p>
          <div class="mock m-parse">
            <div class="line" style="width:70%;"></div>
            <div class="line shimmer" style="width:92%;"></div>
            <div class="line shimmer" style="width:60%;"></div>
            <div class="line" style="width:85%;"></div>
            <div class="reveal">
              <div class="t">Dumpling Ramen</div>
              <div class="m"><span>20 min</span><span>·</span><span>375 kcal</span><span>·</span><span>Quick</span></div>
            </div>
          </div>
        </div>
        <div class="wow-card">
          <div class="num">03</div>
          <h3>Cook it tonight.</h3>
          <p>One tap launches a hands-free cooking mode with timers and ingredient checklists.</p>
          <div class="mock m-result">
            <img src="https://images.unsplash.com/photo-1591814468924-caf88d1232e1?w=600&q=80&auto=format&fit=crop" alt="">
            <div class="body">
              <h4>Dumpling Ramen</h4>
              <div class="row">
                <span class="chip">Dinner</span>
                <span class="chip">20 min</span>
                <span class="chip">Quick</span>
              </div>
              <div class="macros">
                <span><b>375</b> kcal</span>
                <span><b>28g</b> P</span>
                <span><b>42g</b> C</span>
                <span><b>11g</b> F</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Reviews ─── -->
  <section class="reviews" id="reviews">
    <div class="container">
      <div class="sec-head">
        <div class="eyebrow">App Store</div>
        <div class="reviews-headline">
          <h2 class="display big">Every review is <em>five stars.</em></h2>
          <span class="stars-big">
            {[1,2,3,4,5].map(() => (
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.9 6.4 6.9.7-5.2 4.7 1.5 6.8L12 17l-6.1 3.6 1.5-6.8L2.2 9.1l6.9-.7L12 2z"/></svg>
            ))}
          </span>
        </div>
        <p class="lead" style="margin-top:28px;">Real reviews from real people who use RecipeBox AI to organise their cooking. No paid placements, no nudges — just folks who finally have everything in one place.</p>
      </div>
      <div class="review-grid">
        {[
          { name: 'Fabi 11O',     when: '3 mo ago', title: "Finally — an AI app that's actually useful", text: "I've tried a lot of recipe apps — most are cluttered with ads or just save links. RecipeBox AI is completely different. I can take a photo of a cookbook page or paste a link from Instagram and it turns into a clean step-by-step recipe." },
          { name: 'Ranin S',      when: '6 mo ago', title: "Great app! It's a must have",                 text: "This is what I have been always looking for. It's like a digital album for recipes — it helped me collect everything I'd saved in various apps and files into one place. Beautiful, neat and accessible from everywhere." },
          { name: 'Rue Sha',      when: '5 mo ago', title: 'Great way to stay organised',                 text: "My husband and I cook at home and we have a huge collection of recipes from many sources. We use the app to keep everything in one place in a very organised structure, making cooking less stressful and more fun!" },
          { name: 'Ala Shiban',   when: '5 mo ago', title: 'Love the quick actions',                      text: "I take my favorite recipes and create low-fat healthy versions with a cool photo. I use it every time I want to try a new dish." },
          { name: 'The Greatesting', when: '5 mo ago', title: "You'll get compliments!",                  text: "Genius, simple, user friendly and makes cooking very easy!" },
          { name: 'Latettuccia',  when: '3 wk ago', title: 'Il libro di ricette perfetto',                text: "Finalmente un posto dove posso raggruppare tutte le ricette che trovo nei diversi siti e social e tenerne di mie." },
        ].map((r) => (
          <div class="review">
            <div class="top">
              <span class="stars">
                {[1,2,3,4,5].map(() => (
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.9 6.4 6.9.7-5.2 4.7 1.5 6.8L12 17l-6.1 3.6 1.5-6.8L2.2 9.1l6.9-.7L12 2z"/></svg>
                ))}
              </span>
              <span class="when">{r.when}</span>
            </div>
            <h4>{r.title}</h4>
            <p>"{r.text}"</p>
            <div class="author"><div class="av">{r.name[0]}</div>{r.name}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Features ─── -->
  <section class="features" id="features">
    <div class="container">
      <div class="sec-head" style="max-width: 880px;">
        <div class="eyebrow">Everything you need</div>
        <h2 class="display">Built for the way <em>you actually cook.</em></h2>
      </div>
      <div class="feat-grid">

        <div class="feat full">
          <div class="scan-feat">
            <div>
              <div class="ico-box"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7V5a2 2 0 012-2h2M17 3h2a2 2 0 012 2v2M21 17v2a2 2 0 01-2 2h-2M7 21H5a2 2 0 01-2-2v-2"/><path d="M7 12h10"/></svg></div>
              <h3 style="margin-top:18px;">Scan a cookbook page. Get a real recipe.</h3>
              <p style="margin-top:10px; max-width:52ch;">Point your camera at any printed recipe — your grandma's handwritten card, a magazine clip, a coffee-table cookbook. The AI reads the page, structures the ingredients, and adds it to your library.</p>
            </div>
            <div class="scan-mock">
              <div class="page-bg"></div>
              <div class="gutter"></div>
              <div class="page">
                <div class="brand-line"><b>Blossom</b>{`{ winter }`}</div>
                <h4 class="title">Miso Butter Salmon</h4>
                <p class="subtitle">with charred greens</p>
                <p class="blurb">A weeknight salmon that tastes like a Friday-night restaurant dish — <b>twenty minutes, one pan</b>, and the kind of sauce you'll want to drink with a spoon.</p>
                <div class="columns">
                  <div>
                    <div class="ingr-head">Ingredients</div>
                    <div class="ingr-serves">serves 2–3</div>
                    <ul class="ingr-list">
                      <li>2 salmon fillets, skin-on</li>
                      <li>2 tbsp white miso paste</li>
                      <li>60 g unsalted butter</li>
                      <li>1 tbsp soy sauce</li>
                      <li>2 tsp honey, runny</li>
                      <li>1 lime, juiced & zested</li>
                      <li>2 cm ginger, finely grated</li>
                      <li>2 cloves garlic, crushed</li>
                      <li>200 g tenderstem broccoli</li>
                      <li>1 tbsp sesame oil</li>
                      <li>Black sesame, to finish</li>
                    </ul>
                  </div>
                  <div class="method">
                    <h4>To make</h4>
                    <p>Whisk the miso, butter, soy, honey, lime, ginger and garlic into a glossy paste. Pat the salmon dry and spread half across the flesh, pressing it in.</p>
                    <p>Heat a heavy pan on medium. Lay the salmon skin-down and leave it for four minutes — the skin releases on its own. Flip, baste twice, and let the glaze foam.</p>
                    <h4>To serve</h4>
                    <p>Toss the broccoli in sesame oil and char in the same pan for two minutes. Plate the fish on top, spoon over the sauce, finish with sesame and lime zest.</p>
                    <div class="pagenum">A year at Blossom · 124</div>
                  </div>
                </div>
              </div>
              <div class="vignette"></div>
              <div class="reticle"><span></span></div>
              <div class="scanline"></div>
            </div>
          </div>
        </div>

        <div class="feat wide">
          <div class="ico-box"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M15 4l5 5"/><path d="M4 20l11-11"/><path d="M19 2v3M21 4h-3M5 11v2M6 12H4M19 15v2M20 16h-2"/></svg></div>
          <h3>AI transformations.</h3>
          <p>Make any recipe vegetarian, higher-protein, or kid-friendly with one tap. The AI swaps ingredients and re-balances macros.</p>
          <div class="viz ai-chips">
            <span class="ai-chip">Original</span>
            <span class="ai-chip">Healthier</span>
            <span class="ai-chip grad"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 3v3M12 18v3M5 12H2M22 12h-3"/><circle cx="12" cy="12" r="3"/></svg>High Protein</span>
            <span class="ai-chip">Vegan</span>
            <span class="ai-chip">Kid-friendly</span>
          </div>
        </div>

        <div class="feat wide">
