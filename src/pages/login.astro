---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Sign in" description="Sign in to RecipeBox AI to view your recipe library on the web.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,800&family=Inter+Tight:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <meta name="robots" content="noindex">

  <!-- ─── Nav ─── -->
  <nav class="rb-nav">
    <div class="container inner">
      <a class="brand" href="/">
        <img class="app-ico" src="/app-icon.png" alt="">
        RecipeBox AI
      </a>
      <ul>
        <li><a href="/#features">Features</a></li>
        <li><a href="/recipes/">Recipes</a></li>
        <li><a class="current" href="/my/recipes/">My Recipes</a></li>
      </ul>
      <a class="download" href="https://apps.apple.com/gb/app/recipebox-ai/id6752560797">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.06 13.28c-.02-2.45 2-3.62 2.09-3.68-1.14-1.67-2.91-1.9-3.54-1.93-1.51-.15-2.94.89-3.71.89-.78 0-1.96-.86-3.22-.84-1.66.02-3.19.96-4.04 2.45-1.72 2.98-.44 7.4 1.24 9.82.82 1.18 1.8 2.52 3.06 2.47 1.23-.05 1.7-.8 3.19-.8 1.48 0 1.9.8 3.2.78 1.32-.02 2.15-1.2 2.96-2.39.93-1.37 1.32-2.71 1.34-2.78-.03-.01-2.57-.98-2.59-3.89zM14.6 6.06c.67-.81 1.13-1.94.99-3.06-.97.04-2.13.65-2.83 1.45-.62.71-1.18 1.86-1.03 2.96 1.09.09 2.2-.55 2.87-1.35z"/></svg>
        Download
      </a>
    </div>
  </nav>

  <div class="auth-wrap">
    <div class="auth-card">
      <div class="eyebrow">Your library, on the web</div>
      <h1 class="display">Welcome<br><em>back.</em></h1>
      <p class="lead">Sign in with the same account you use in the RecipeBox AI app — every recipe on your phone is right here.</p>

      <form id="login-form" novalidate>
        <div class="field">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" autocomplete="email" placeholder="you@example.com" required>
        </div>
        <div class="field">
          <label for="password">Password</label>
          <div class="pw-wrap">
            <input type="password" id="password" name="password" autocomplete="current-password" placeholder="••••••••" required>
            <button type="button" id="pw-toggle" aria-label="Show password">
              <svg id="pw-eye" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
        </div>

        <div class="error-card" id="error-card" role="alert" hidden></div>

        <button class="submit" id="submit-btn" type="submit">
          <span class="spinner" hidden></span>
          <span class="label">Sign in</span>
        </button>
      </form>

      <p class="hint">Forgot your password? Reset it from the app's sign-in screen — it changes here too.</p>

      <div class="divider"></div>

      <div class="no-account">
        <div>
          <h3>New to RecipeBox&nbsp;AI?</h3>
          <p>Accounts are created in the app. Download it, save a recipe, and it appears here instantly.</p>
        </div>
        <a class="get-app" href="https://apps.apple.com/gb/app/recipebox-ai/id6752560797">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.06 13.28c-.02-2.45 2-3.62 2.09-3.68-1.14-1.67-2.91-1.9-3.54-1.93-1.51-.15-2.94.89-3.71.89-.78 0-1.96-.86-3.22-.84-1.66.02-3.19.96-4.04 2.45-1.72 2.98-.44 7.4 1.24 9.82.82 1.18 1.8 2.52 3.06 2.47 1.23-.05 1.7-.8 3.19-.8 1.48 0 1.9.8 3.2.78 1.32-.02 2.15-1.2 2.96-2.39.93-1.37 1.32-2.71 1.34-2.78-.03-.01-2.57-.98-2.59-3.89zM14.6 6.06c.67-.81 1.13-1.94.99-3.06-.97.04-2.13.65-2.83 1.45-.62.71-1.18 1.86-1.03 2.96 1.09.09 2.2-.55 2.87-1.35z"/></svg>
          Get the app
        </a>
      </div>
    </div>
  </div>

  <footer class="rb-footer">
    <div class="container row">
      <div class="brand">
        <img class="app-ico" src="/app-icon.png" alt="">
        RecipeBox AI
      </div>
      <div class="links">
        <a href="mailto:hello@recipeboxai.app">Support</a>
        <a href="/privacy/">Privacy</a>
        <a href="/terms/">Terms</a>
        <a href="https://twitter.com/RecipeBoxAI">Twitter</a>
      </div>
      <div class="copy">© 2026 RecipeBox AI</div>
    </div>
  </footer>

  <script>
    import { supabase, safeNextPath } from '@/lib/account';

    const nextPath = safeNextPath(new URLSearchParams(window.location.search).get('next'), '/my/recipes/');

    // Already signed in → straight to the library.
    supabase.auth.getSession().then(({ data: { session } }) => {
      if (session) window.location.replace(nextPath);
    });

    const form = document.getElementById('login-form') as HTMLFormElement;
    const emailEl = document.getElementById('email') as HTMLInputElement;
    const passwordEl = document.getElementById('password') as HTMLInputElement;
    const errorCard = document.getElementById('error-card') as HTMLElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const spinner = submitBtn.querySelector('.spinner') as HTMLElement;
    const label = submitBtn.querySelector('.label') as HTMLElement;

    document.getElementById('pw-toggle')?.addEventListener('click', () => {
      const showing = passwordEl.type === 'text';
      passwordEl.type = showing ? 'password' : 'text';
      passwordEl.focus();
    });

    function showError(message: string) {
      errorCard.textContent = message;
      errorCard.hidden = false;
    }

    function setBusy(busy: boolean) {
      submitBtn.disabled = busy;
      spinner.hidden = !busy;
      label.textContent = busy ? 'Signing in…' : 'Sign in';
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorCard.hidden = true;

      const email = emailEl.value.trim();
      const password = passwordEl.value;
      if (!email || !password) {
        showError('Enter your email and password.');
        return;
      }

      setBusy(true);
      const { error } = await supabase.auth.signInWithPassword({ email, password });
      if (error) {
        setBusy(false);
        const msg = /invalid login credentials/i.test(error.message)
          ? 'That email and password don’t match. Double-check and try again.'
          : /email not confirmed/i.test(error.message)
            ? 'Your email isn’t confirmed yet — tap the link in the confirmation email first.'
            : error.message;
        showError(msg);
        return;
      }
      window.location.replace(nextPath);
    });
  </script>
</BaseLayout>

<style is:global>
  :root {
    --bg: #f0eee9;
    --bg-2: #e9e6df;
    --ink: #0a0a0a;
    --ink-2: #2a2a2c;
    --muted: #6e6e73;
    --line: rgba(10,10,10,0.08);
    --line-2: rgba(10,10,10,0.04);
    --serif: "Fraunces", Georgia, serif;
    --sans: "Inter Tight", -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
  }
  *, *::before, *::after { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; background: var(--bg); color: var(--ink); font-family: var(--sans); line-height: 1.45; }
  body { -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility; }
  ::selection { background: #0a0a0a; color: #fff; }
  img { display: block; max-width: 100%; }
  a { color: inherit; text-decoration: none; }
  button { font: inherit; cursor: pointer; }

  .container { max-width: 1280px; margin: 0 auto; padding: 0 56px; }
  .display { font-family: var(--serif); font-weight: 400; font-variation-settings: "opsz" 144; line-height: 0.96; letter-spacing: -0.035em; text-wrap: balance; }
  .display em { font-style: italic; font-weight: 400; }
  .eyebrow { font-family: var(--sans); font-size: 11px; font-weight: 700; letter-spacing: 1.6px; text-transform: uppercase; color: var(--muted); }
  .lead { font-size: 16px; line-height: 1.5; color: var(--ink-2); letter-spacing: -0.01em; text-wrap: pretty; }

  /* Nav */
  nav.rb-nav { position: sticky; top: 0; z-index: 50; backdrop-filter: saturate(180%) blur(14px); -webkit-backdrop-filter: saturate(180%) blur(14px); background: color-mix(in srgb, var(--bg) 86%, transparent); border-bottom: 1px solid var(--line-2); }
  nav.rb-nav .inner { display: flex; align-items: center; justify-content: space-between; height: 64px; }
  nav.rb-nav .brand { display: flex; align-items: center; gap: 10px; font-weight: 700; letter-spacing: -0.02em; font-size: 17px; color: var(--ink); }
  nav.rb-nav .brand .app-ico { width: 30px; height: 30px; border-radius: 7px; box-shadow: 0 1px 2px rgba(0,0,0,0.18); }
  nav.rb-nav ul { list-style: none; padding: 0; margin: 0; display: flex; gap: 28px; }
  nav.rb-nav ul a { font-size: 14px; font-weight: 500; color: var(--ink-2); }
  nav.rb-nav ul a.current, nav.rb-nav ul a:hover { color: var(--ink); }
  nav.rb-nav .download { height: 38px; padding: 0 16px; border-radius: 999px; background: #0a0a0a; color: #fff; font-size: 13px; font-weight: 600; display: inline-flex; align-items: center; gap: 8px; }

  /* Auth card */
  .auth-wrap { min-height: calc(100vh - 64px - 176px); display: flex; align-items: center; justify-content: center; padding: 64px 22px 96px; }
  .auth-card { width: 100%; max-width: 460px; background: #fff; border: 1px solid var(--line-2); border-radius: 28px; padding: 44px 40px 36px; box-shadow: 0 24px 60px -32px rgba(10,10,10,0.18); }
  .auth-card h1 { font-size: 56px; margin: 12px 0 16px; }
  .auth-card .lead { margin: 0 0 30px; }

  .field { margin-bottom: 18px; }
  .field label { display: block; font-size: 11px; font-weight: 700; letter-spacing: 1.4px; text-transform: uppercase; color: var(--muted); margin-bottom: 8px; }
  .field input { width: 100%; height: 50px; padding: 0 16px; border-radius: 14px; border: 1px solid var(--line); background: var(--bg); font-family: var(--sans); font-size: 15px; color: var(--ink); outline: none; transition: border-color 120ms ease, background 120ms ease; }
  .field input::placeholder { color: var(--muted); opacity: 0.7; }
  .field input:focus { border-color: rgba(10,10,10,0.45); background: #fff; }
  .pw-wrap { position: relative; }
  .pw-wrap input { padding-right: 48px; }
  .pw-wrap button { position: absolute; right: 6px; top: 50%; transform: translateY(-50%); width: 38px; height: 38px; border: 0; background: transparent; border-radius: 10px; color: var(--muted); display: grid; place-items: center; }
  .pw-wrap button:hover { color: var(--ink); background: var(--bg-2); }

  .error-card { margin: 0 0 16px; padding: 12px 16px; border-radius: 14px; background: rgba(224,83,61,0.08); border: 1px solid rgba(224,83,61,0.25); color: #a53421; font-size: 13.5px; line-height: 1.45; }

  .submit { width: 100%; height: 52px; border-radius: 999px; background: #0a0a0a; color: #fff; border: 0; font-size: 15px; font-weight: 600; letter-spacing: -0.005em; display: inline-flex; align-items: center; justify-content: center; gap: 10px; transition: background 140ms ease, opacity 140ms ease; }
  .submit:hover:not(:disabled) { background: #1a1a1a; }
  .submit:disabled { opacity: 0.65; cursor: default; }
  .spinner { width: 16px; height: 16px; border-radius: 50%; border: 2px solid rgba(255,255,255,0.35); border-top-color: #fff; animation: spin 700ms linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }

  .hint { margin: 16px 0 0; font-size: 12.5px; color: var(--muted); line-height: 1.5; }
  .divider { height: 1px; background: var(--line); margin: 26px 0; }

  .no-account { display: flex; align-items: center; justify-content: space-between; gap: 16px; }
  .no-account h3 { font-family: var(--serif); font-size: 19px; font-weight: 500; letter-spacing: -0.02em; margin: 0 0 4px; line-height: 1.1; }
  .no-account p { margin: 0; font-size: 12.5px; color: var(--muted); line-height: 1.45; max-width: 30ch; }
  .get-app { flex-shrink: 0; height: 42px; padding: 0 18px; border-radius: 999px; border: 1px solid var(--line); font-size: 13px; font-weight: 600; display: inline-flex; align-items: center; gap: 8px; color: var(--ink); white-space: nowrap; }
  .get-app:hover { border-color: rgba(10,10,10,0.3); }

  /* Footer */
  footer.rb-footer { background: #0a0a0a; color: rgba(255,255,255,0.7); padding: 56px 0 64px; }
  footer.rb-footer .row { display: flex; justify-content: space-between; align-items: center; gap: 24px; flex-wrap: wrap; }
  footer.rb-footer .brand { display: flex; align-items: center; gap: 10px; color: #fff; font-weight: 700; letter-spacing: -0.02em; font-size: 16px; }
  footer.rb-footer .brand .app-ico { width: 28px; height: 28px; border-radius: 7px; box-shadow: 0 0 0 1px rgba(255,255,255,0.12); }
  footer.rb-footer .links { display: flex; gap: 24px; font-size: 14px; }
  footer.rb-footer .links a { color: rgba(255,255,255,0.6); }
  footer.rb-footer .links a:hover { color: #fff; }
  footer.rb-footer .copy { font-size: 13px; color: rgba(255,255,255,0.4); }

  @media (max-width: 760px) {
    .container { padding: 0 22px; }
    nav.rb-nav ul { display: none; }
    .auth-wrap { padding: 32px 18px 64px; align-items: flex-start; }
    .auth-card { padding: 32px 24px 28px; }
    .auth-card h1 { font-size: 44px; }
    .no-account { flex-direction: column; align-items: flex-start; }
    .no-account p { max-width: none; }
    footer.rb-footer .row { flex-direction: column; align-items: flex-start; gap: 18px; }
  }
</style>
