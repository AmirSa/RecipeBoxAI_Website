---
import BaseLayout from '@layouts/BaseLayout.astro';
import NavAccount from '@components/NavAccount.astro';
import ThemeToggle from '@components/ThemeToggle.astro';
import MobileNav from '@components/MobileNav.astro';
---

<BaseLayout title="Cookbook" description="A cookbook from your RecipeBox AI library.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,800&family=Inter+Tight:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <meta name="robots" content="noindex">

  <nav class="rb-nav">
    <div class="container inner">
      <a class="brand" href="/">
        <img class="app-ico" src="/app-icon.png" alt="">
        RecipeBox AI
      </a>
      <ul>
        <li><a id="nav-primary" href="/my/recipes/">My Recipes</a></li>
        <li><a class="current" href="/my/cookbooks/">My Cookbooks</a></li>
        <li><a href="/recipes/">Discover</a></li>
      </ul>
      <div class="nav-actions">
        <NavAccount dest="/login/" />
        <ThemeToggle />
        <MobileNav />
      </div>
    </div>
  </nav>

  <div class="container" id="app">
    <div class="crumb"><a href="/my/cookbooks/">My Cookbooks</a><span class="sep">/</span><span class="sk-inline"></span></div>
    <div class="sk-block" style="height: 60px; width: 60%; margin: 20px 0;"></div>
    <div class="grid">
      <div class="sk-block" style="aspect-ratio:4/3;border-radius:22px;"></div>
      <div class="sk-block" style="aspect-ratio:4/3;border-radius:22px;"></div>
      <div class="sk-block" style="aspect-ratio:4/3;border-radius:22px;"></div>
    </div>
  </div>

  <footer class="rb-footer">
    <div class="container row">
      <div class="brand"><img class="app-ico" src="/app-icon.png" alt="">RecipeBox AI</div>
      <div class="links">
        <a href="mailto:hello@recipeboxai.app">Support</a>
        <a href="/privacy/">Privacy</a>
        <a href="/terms/">Terms</a>
        <a href="https://twitter.com/RecipeBoxAI">Twitter</a>
      </div>
      <div class="copy">© 2026 RecipeBox AI</div>
    </div>
  </footer>

  <script>
    import { requireSession, escapeHtml, fetchCookbook } from '@/lib/account';

    const app = document.getElementById('app') as HTMLElement;
    const ICON_TIMER = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" width="13" height="13"><circle cx="12" cy="13" r="8"/><path d="M12 9v4l3 2M9 2h6"/></svg>';

    function state(title: string, msg: string) {
      app.innerHTML = `
        <div class="crumb"><a href="/my/cookbooks/">My Cookbooks</a></div>
        <div class="page-state"><h2>${escapeHtml(title)}</h2><p>${escapeHtml(msg)}</p><a class="state-btn" href="/my/cookbooks/">Back to My Cookbooks</a></div>`;
    }

    function recipeCard(r: { id: string; title: string; totalTime: number; calories: number; image: string | null }) {
      const initial = escapeHtml((r.title || 'R').slice(0, 1).toUpperCase());
      return `
        <a class="card" href="/my/recipes/view/?id=${encodeURIComponent(r.id)}">
          <div class="img-wrap">
            ${r.image
              ? `<img src="${escapeHtml(r.image)}" alt="${escapeHtml(r.title)}" loading="lazy" onerror="this.replaceWith(Object.assign(document.createElement('div'),{className:'ph',textContent:'${initial}'}))">`
              : `<div class="ph">${initial}</div>`}
          </div>
          <div class="body">
            <h3>${escapeHtml(r.title)}</h3>
            <div class="meta-row">
              ${r.totalTime > 0 ? `<span class="mt">${ICON_TIMER} ${r.totalTime} min</span>` : ''}
              ${r.totalTime > 0 && r.calories > 0 ? '<span class="dot"></span>' : ''}
              ${r.calories > 0 ? `<span>${r.calories} kcal</span>` : ''}
            </div>
          </div>
        </a>`;
    }

    async function load() {
      const session = await requireSession();
      if (!session) return;
      const id = new URLSearchParams(location.search).get('id');
      if (!id) { state('Cookbook not found', 'This link is missing a cookbook id.'); return; }

      const cb = await fetchCookbook(id).catch((e) => { throw e; });
      if (!cb) { state('Cookbook not found', "This cookbook doesn't exist in your library — it may have been deleted on another device."); return; }
      document.title = `${cb.name} - RecipeBox AI`;

      app.innerHTML = `
        <div class="crumb"><a href="/my/cookbooks/">My Cookbooks</a><span class="sep">/</span><span style="color:var(--ink);">${escapeHtml(cb.name)}</span></div>
        <header class="cb-head">
          <h1 class="display">${escapeHtml(cb.name)}</h1>
          ${cb.description ? `<p class="cb-desc">${escapeHtml(cb.description)}</p>` : ''}
          <div class="cb-meta">${cb.recipes.length} recipe${cb.recipes.length === 1 ? '' : 's'}</div>
        </header>
        ${cb.recipes.length === 0
          ? `<div class="page-state"><h2>No recipes yet</h2><p>Add recipes to this cookbook in the app and they'll appear here.</p><a class="state-btn" href="/my/recipes/">Browse your recipes</a></div>`
          : `<div class="grid">${cb.recipes.map(recipeCard).join('')}</div>`}`;
    }

    load().catch((err) => state('Something went wrong', err instanceof Error ? err.message : 'Please try again.'));
  </script>
</BaseLayout>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; background: var(--bg); color: var(--ink); font-family: var(--sans); line-height: 1.45; }
  body { -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility; }
  img { display: block; max-width: 100%; }
  a { color: inherit; text-decoration: none; }
  button { font: inherit; cursor: pointer; }
  [hidden] { display: none !important; }

  .container { max-width: 1100px; margin: 0 auto; padding: 0 56px; }
  .display { font-family: var(--serif); font-weight: 400; font-variation-settings: "opsz" 144; line-height: 0.98; letter-spacing: -0.035em; }

  nav.rb-nav { position: sticky; top: 0; z-index: 50; backdrop-filter: saturate(180%) blur(14px); -webkit-backdrop-filter: saturate(180%) blur(14px); background: color-mix(in srgb, var(--bg) 86%, transparent); border-bottom: 1px solid var(--line-2); }
  nav.rb-nav .inner { display: flex; align-items: center; justify-content: space-between; height: 64px; max-width: 1200px; margin: 0 auto; }
  nav.rb-nav .brand { display: flex; align-items: center; gap: 10px; font-weight: 700; letter-spacing: -0.02em; font-size: 17px; color: var(--ink); }
  nav.rb-nav .brand .app-ico { width: 30px; height: 30px; border-radius: 7px; box-shadow: 0 1px 2px rgba(0,0,0,0.18); }
  nav.rb-nav ul { list-style: none; padding: 0; margin: 0; display: flex; gap: 28px; }
  nav.rb-nav ul a { font-size: 14px; font-weight: 500; color: var(--ink-2); }
  nav.rb-nav ul a.current, nav.rb-nav ul a:hover { color: var(--ink); }
  nav.rb-nav .nav-actions { display: flex; align-items: center; gap: 14px; }

  .crumb { padding: 24px 0 0; font-size: 13px; color: var(--muted); display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
  .crumb a:hover { color: var(--ink); }
  .crumb .sep { opacity: 0.5; }
  .cb-head { padding: 20px 0 32px; }
  .cb-head h1 { font-size: 56px; margin: 0; }
  .cb-desc { font-size: 17px; color: var(--ink-2); margin: 16px 0 0; max-width: 60ch; line-height: 1.5; }
  .cb-meta { font-size: 12.5px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; color: var(--muted); margin-top: 14px; }

  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; padding-bottom: 96px; }
  .card { border-radius: 22px; overflow: hidden; display: flex; flex-direction: column; transition: transform 200ms ease; color: var(--ink); }
  .card:hover { transform: translateY(-3px); }
  .card .img-wrap { aspect-ratio: 4/3; border-radius: 22px; overflow: hidden; background: var(--bg-2); }
  .card .img-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform 400ms ease; }
  .card:hover .img-wrap img { transform: scale(1.04); }
  .card .ph { width: 100%; height: 100%; display: grid; place-items: center; font-family: var(--serif); font-size: 64px; font-weight: 500; color: color-mix(in srgb, var(--ink) 18%, transparent); background: linear-gradient(135deg, var(--bg-2), color-mix(in srgb, var(--bg-2) 95%, var(--ink))); }
  .card .body { padding: 14px 4px 4px; }
  .card h3 { font-family: var(--serif); font-size: 20px; line-height: 1.12; font-weight: 500; letter-spacing: -0.02em; margin: 0 0 8px; }
  .card .meta-row { display: flex; gap: 10px; font-size: 12px; color: var(--muted); align-items: center; }
  .card .meta-row .mt { display: inline-flex; align-items: center; gap: 4px; }
  .card .meta-row .dot { width: 3px; height: 3px; border-radius: 50%; background: var(--muted); }

  .page-state { margin: 40px 0 96px; max-width: 560px; padding: 60px 40px; text-align: center; background: var(--card); border: 1px solid var(--line-2); border-radius: 24px; }
  .page-state h2 { font-family: var(--serif); font-size: 30px; font-weight: 500; letter-spacing: -0.02em; margin: 0 0 10px; }
  .page-state p { margin: 0 auto; color: var(--muted); font-size: 15px; max-width: 42ch; }
  .state-btn { display: inline-flex; margin-top: 22px; height: 46px; padding: 0 24px; align-items: center; border-radius: 999px; background: var(--solid); color: var(--on-solid); font-size: 14px; font-weight: 600; }

  .sk-inline { display: inline-block; width: 120px; height: 12px; border-radius: 6px; }
  .sk-block, .sk-inline { background: linear-gradient(90deg, var(--bg-2) 25%, color-mix(in srgb, var(--bg-2) 95%, var(--ink)) 50%, var(--bg-2) 75%); background-size: 200% 100%; animation: shimmer 1.4s ease infinite; }
  @keyframes shimmer { to { background-position: -200% 0; } }

  footer.rb-footer { background: var(--panel); color: rgba(255,255,255,0.7); padding: 56px 0 64px; }
  footer.rb-footer .row { display: flex; justify-content: space-between; align-items: center; gap: 24px; flex-wrap: wrap; max-width: 1100px; }
  footer.rb-footer .brand { display: flex; align-items: center; gap: 10px; color: #fff; font-weight: 700; font-size: 16px; }
  footer.rb-footer .brand .app-ico { width: 28px; height: 28px; border-radius: 7px; box-shadow: 0 0 0 1px rgba(255,255,255,0.12); }
  footer.rb-footer .links { display: flex; gap: 24px; font-size: 14px; }
  footer.rb-footer .links a { color: rgba(255,255,255,0.6); }
  footer.rb-footer .links a:hover { color: #fff; }
  footer.rb-footer .copy { font-size: 13px; color: rgba(255,255,255,0.4); }

  @media (max-width: 900px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 760px) {
    .container { padding: 0 22px; }
    nav.rb-nav ul { display: none; }
    .cb-head h1 { font-size: 40px; }
    .grid { grid-template-columns: 1fr; }
    footer.rb-footer .row { flex-direction: column; align-items: flex-start; gap: 18px; }
  }
</style>
