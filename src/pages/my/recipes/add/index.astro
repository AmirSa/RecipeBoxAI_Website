---
import BaseLayout from '@layouts/BaseLayout.astro';
import NavAccount from '@components/NavAccount.astro';
import ThemeToggle from '@components/ThemeToggle.astro';
import MobileNav from '@components/MobileNav.astro';
import ImportTray from '@components/ImportTray.astro';
---

<BaseLayout title="Add a Recipe" description="Add a recipe to your RecipeBox AI library from the web.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,800&family=Inter+Tight:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <meta name="robots" content="noindex">

  <!-- ─── Nav ─── -->
  <nav class="rb-nav">
    <div class="container inner">
      <a class="brand" href="/">
        <img class="app-ico" src="/app-icon.png" alt="">
        RecipeBox AI
      </a>
      <ul>
        <li><a id="nav-primary" class="current" href="/my/recipes/">My Recipes</a></li>
        <li><a href="/my/cookbooks/">My Cookbooks</a></li>
        <li><a href="/recipes/">Discover</a></li>
      </ul>
      <div class="nav-actions">
        <NavAccount dest="/login/" />
        <ThemeToggle />
        <MobileNav />
      </div>
    </div>
  </nav>

  <ImportTray />

  <div class="container narrow">
    <div class="crumb">
      <a href="/my/recipes/">My Recipes</a>
      <span class="sep">/</span>
      <span style="color: var(--ink);">Add a recipe</span>
    </div>

    <header class="page-head">
      <div class="eyebrow">Same AI as the app</div>
      <h1 class="display">Add a <em>recipe.</em></h1>
      <p class="lead">From an idea, a link, a photo, or plain text — the AI structures it into your library, synced to your phone.</p>
    </header>

    <!-- Method tiles -->
    <div class="methods" id="methods">
      <button class="method active" data-method="text" type="button">
        <span class="m-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M4 6h16M4 12h16M4 18h10"/></svg></span>
        <span class="m-name">Paste text</span>
        <span class="m-desc">Notes, messages, anything</span>
      </button>
      <button class="method" data-method="link" type="button">
        <span class="m-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg></span>
        <span class="m-name">From a link</span>
        <span class="m-desc">Websites, YouTube, socials</span>
      </button>
      <button class="method" data-method="photo" type="button">
        <span class="m-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="9" cy="9" r="2"/><path d="M21 15l-5-5L5 21"/></svg></span>
        <span class="m-name">From a photo</span>
        <span class="m-desc">Cookbook pages, cards</span>
      </button>
      <button class="method" data-method="ai" type="button">
        <span class="m-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M12 3l1.9 5.8L20 10.6l-6.1 1.8L12 18l-1.9-5.6L4 10.6l6.1-1.8z"/></svg></span>
        <span class="m-name">Create with AI</span>
        <span class="m-desc">Guided, ingredients, or luck</span>
      </button>
    </div>

    <main class="panel" id="panel">
      <div class="sk-panel" id="loading">
        <div class="sk-line w40"></div>
        <div class="sk-area"></div>
      </div>

      <div id="gate-blocked" hidden>
        <div class="state-card">
          <h3>Your library is full</h3>
          <p id="gate-msg">You've used all your free recipe slots. Upgrade to Pro in the RecipeBox AI app for unlimited recipes.</p>
          <a class="state-btn" href="/my/recipes/">Back to My Recipes</a>
        </div>
      </div>

      <div id="forms" hidden>
        <!-- Paste text -->
        <form class="method-form" id="form-text" data-panel="text">
          <label class="field-label" for="recipe-text">Your recipe text</label>
          <textarea
            id="recipe-text"
            placeholder="Paste or type the recipe here — ingredients, steps, rough notes, anything. The AI will structure it, estimate times and calories, and analyze nutrition."
            spellcheck="false"
          ></textarea>
          <div class="form-row">
            <span class="hint">Works best with at least a few lines.</span>
            <button class="go-btn" id="go-text" type="submit" disabled>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><path d="M12 3l1.9 5.8L20 10.6l-6.1 1.8L12 18l-1.9-5.6L4 10.6l6.1-1.8z"/></svg>
              Create recipe
            </button>
          </div>
        </form>

        <!-- From a link -->
        <form class="method-form" id="form-link" data-panel="link" hidden>
          <label class="field-label" for="recipe-url">Recipe link</label>
          <input
            type="url"
            id="recipe-url"
            class="url-input"
            placeholder="https://www.youtube.com/watch?v=…  ·  https://www.instagram.com/p/…"
            autocomplete="off"
            spellcheck="false"
          >
          <div class="form-row">
            <span class="hint">Any recipe website, plus YouTube, Instagram, TikTok, Facebook, Pinterest &amp; X.</span>
            <button class="go-btn" id="go-link" type="submit" disabled>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
              Import recipe
            </button>
          </div>
        </form>

        <!-- From a photo -->
        <form class="method-form" id="form-photo" data-panel="photo" hidden>
          <label class="field-label">Photos of the recipe</label>
          <label class="drop" id="drop">
            <input type="file" id="photo-input" accept="image/*" multiple hidden>
            <div class="drop-inner" id="drop-inner">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="9" cy="9" r="2"/><path d="M21 15l-5-5L5 21"/></svg>
              <span><b>Choose photos</b> or drop them here</span>
              <span class="drop-sub">A cookbook page, a recipe card, a screenshot — up to 3 photos of one recipe.</span>
            </div>
            <div class="thumbs" id="thumbs" hidden></div>
          </label>
          <div class="form-row">
            <span class="hint">The first photo is also used as the recipe's cover image.</span>
            <button class="go-btn" id="go-photo" type="submit" disabled>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><path d="M12 3l1.9 5.8L20 10.6l-6.1 1.8L12 18l-1.9-5.6L4 10.6l6.1-1.8z"/></svg>
              Scan recipe
            </button>
          </div>
        </form>

        <!-- Create with AI -->
        <form class="method-form" id="form-ai" data-panel="ai" hidden>
          <div id="ai-entry">
            <button type="button" class="guided-launch" id="guided-open">
              <span class="g-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M9 11l3-8 3 8"/><path d="M5 21h14"/><circle cx="12" cy="16" r="3"/></svg></span>
              <span class="g-copy">
                <b>Guided mode</b>
                <span>Answer a few questions and we'll create a recipe for you</span>
              </span>
              <svg class="g-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </button>
            <div class="or-divider"><span>or</span></div>
            <label class="field-label" for="ai-ingredients">What's in your kitchen — or what are you craving?</label>
            <textarea
              id="ai-ingredients"
              class="ai-textarea"
              placeholder="e.g. chicken thighs, a lemon, rice, and some spinach — or just “something cozy for a rainy evening”."
              spellcheck="false"
            ></textarea>
            <div class="form-row">
              <button class="lucky-btn" id="go-lucky" type="button">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><rect x="3" y="3" width="18" height="18" rx="4"/><circle cx="8.5" cy="8.5" r="1.2" fill="currentColor"/><circle cx="15.5" cy="8.5" r="1.2" fill="currentColor"/><circle cx="8.5" cy="15.5" r="1.2" fill="currentColor"/><circle cx="15.5" cy="15.5" r="1.2" fill="currentColor"/><circle cx="12" cy="12" r="1.2" fill="currentColor"/></svg>
                Feeling adventurous
              </button>
              <button class="go-btn" id="go-ai" type="submit" disabled>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><path d="M12 3l1.9 5.8L20 10.6l-6.1 1.8L12 18l-1.9-5.6L4 10.6l6.1-1.8z"/></svg>
                Generate recipe
              </button>
            </div>
          </div>

          <!-- Guided wizard (the apps' 4-step guided AI flow) -->
          <div id="guided-wizard" hidden>
            <div class="gw-head">
              <div class="gw-dots" aria-hidden="true">
                <span class="gw-dot"></span><span class="gw-line"></span>
                <span class="gw-dot"></span><span class="gw-line"></span>
                <span class="gw-dot"></span><span class="gw-line"></span>
                <span class="gw-dot"></span>
              </div>
              <div class="gw-meta">
                <span id="gw-stepnum">Step 1 of 4</span>
                <button type="button" class="gw-exit" id="gw-exit">Exit guided mode</button>
              </div>
            </div>

            <div class="gw-step" data-step="1">
              <h3 class="gw-title">What's your vibe?</h3>
              <p class="gw-sub">Choose the style of recipe you're craving</p>
              <div class="gw-options" data-key="vibe">
                <button type="button" class="gw-opt" data-value="Comfort Food">Comfort Food</button>
                <button type="button" class="gw-opt" data-value="Healthy &amp; Light">Healthy &amp; Light</button>
                <button type="button" class="gw-opt" data-value="Quick &amp; Easy">Quick &amp; Easy</button>
                <button type="button" class="gw-opt" data-value="Gourmet">Gourmet</button>
              </div>
            </div>

            <div class="gw-step" data-step="2" hidden>
              <h3 class="gw-title">Any dietary needs?</h3>
              <p class="gw-sub">We'll make sure your recipe fits your diet</p>
              <div class="gw-options" data-key="dietary">
                <button type="button" class="gw-opt" data-value="None">None</button>
                <button type="button" class="gw-opt" data-value="Vegetarian">Vegetarian</button>
                <button type="button" class="gw-opt" data-value="Vegan">Vegan</button>
                <button type="button" class="gw-opt" data-value="Pescatarian">Pescatarian</button>
                <button type="button" class="gw-opt" data-value="Dairy-Free">Dairy-Free</button>
                <button type="button" class="gw-opt" data-value="Gluten-Free">Gluten-Free</button>
                <button type="button" class="gw-opt" data-value="Keto">Keto</button>
                <button type="button" class="gw-opt" data-value="High Protein">High Protein</button>
                <button type="button" class="gw-opt" data-value="Paleo">Paleo</button>
              </div>
            </div>

            <div class="gw-step" data-step="3" hidden>
              <h3 class="gw-title">How much time?</h3>
              <p class="gw-sub">We'll find something that fits your schedule</p>
              <div class="gw-options" data-key="time">
                <button type="button" class="gw-opt" data-value="Under 15 mins">Under 15 mins</button>
                <button type="button" class="gw-opt" data-value="Under 45 mins">Under 45 mins</button>
                <button type="button" class="gw-opt" data-value="No time limit">No time limit</button>
              </div>
            </div>

            <div class="gw-step" data-step="4" hidden>
              <h3 class="gw-title">Got ingredients? <span class="gw-badge">Optional</span></h3>
              <p class="gw-sub">Tell us what you have and we'll work with it</p>
              <textarea
                id="gw-ingredients"
                class="ai-textarea"
                placeholder="e.g., Chicken, broccoli, garlic, olive oil..."
                spellcheck="false"
              ></textarea>
              <p class="gw-hint">Skip this step to let AI surprise you!</p>
            </div>

            <div class="gw-nav">
              <button type="button" class="lucky-btn" id="gw-back" hidden>Back</button>
              <button type="button" class="go-btn" id="gw-next" disabled>Continue</button>
            </div>
          </div>
        </form>

        <div class="error" id="error" hidden></div>
      </div>

      <div id="progress" hidden>
        <div class="prog-card">
          <h3 id="prog-title">Working on it…</h3>
          <ol class="steps">
            <li id="step-1"><span class="dot"></span><span id="step-1-label">Extracting the recipe</span></li>
            <li id="step-2"><span class="dot"></span>Importing in the background</li>
            <li id="step-3"><span class="dot"></span>Saved to your library</li>
          </ol>
          <p class="prog-note" id="prog-note">This usually takes 10–30 seconds. Your recipe will sync to the app automatically.</p>
        </div>
      </div>
    </main>
  </div>

  <footer class="rb-footer">
    <div class="container row">
      <div class="brand">
        <img class="app-ico" src="/app-icon.png" alt="">
        RecipeBox AI
      </div>
      <div class="links">
        <a href="mailto:hello@recipeboxai.app">Support</a>
        <a href="/privacy/">Privacy</a>
        <a href="/terms/">Terms</a>
        <a href="https://twitter.com/RecipeBoxAI">Twitter</a>
      </div>
      <div class="copy">© 2026 RecipeBox AI</div>
    </div>
  </footer>

  <script>
    import { requireSession, getSaveGate, escapeHtml } from '@/lib/account';
    import {
      submitImport, waitForRecipe, prepareImage, uploadCoverImage, classifyLink,
      type ImportPayload,
    } from '@/lib/ai';
    import { trackImport, removeImport, requestImportNotifications } from '@/lib/imports';

    const loading = document.getElementById('loading') as HTMLElement;
    const forms = document.getElementById('forms') as HTMLElement;
    const gateBlocked = document.getElementById('gate-blocked') as HTMLElement;
    const gateMsg = document.getElementById('gate-msg') as HTMLElement;
    const errorEl = document.getElementById('error') as HTMLElement;
    const progress = document.getElementById('progress') as HTMLElement;
    const progTitle = document.getElementById('prog-title') as HTMLElement;
    const step1Label = document.getElementById('step-1-label') as HTMLElement;

    const MIN_TEXT_CHARS = 20;
    const MAX_PHOTOS = 3;

    // ── Method tile switching ───────────────────────────────────────────────
    const methodBtns = [...document.querySelectorAll<HTMLButtonElement>('.method[data-method]')];
    function showPanel(method: string) {
      methodBtns.forEach((b) => b.classList.toggle('active', b.dataset.method === method));
      document.querySelectorAll<HTMLElement>('.method-form').forEach((f) => {
        f.hidden = f.dataset.panel !== method;
      });
      errorEl.hidden = true;
    }
    methodBtns.forEach((b) => b.addEventListener('click', () => showPanel(b.dataset.method!)));

    // ── Shared pipeline UI ──────────────────────────────────────────────────
    function setStep(n: 1 | 2 | 3, state: '' | 'active' | 'done') {
      document.getElementById(`step-${n}`)!.className = state;
    }

    function startProgress(stepOneLabel: string, note?: string) {
      errorEl.hidden = true;
      forms.hidden = true;
      progress.hidden = false;
      step1Label.textContent = stepOneLabel;
      setStep(1, 'active'); setStep(2, ''); setStep(3, '');
      progTitle.textContent = 'Working on it…';
      const noteEl = document.getElementById('prog-note') as HTMLElement;
      noteEl.textContent = note ?? 'This usually takes 10–30 seconds. Your recipe will sync to the app automatically.';
    }

    function showError(message: string) {
      errorEl.innerHTML = escapeHtml(message);
      errorEl.hidden = false;
      progress.hidden = true;
      forms.hidden = false;
    }

    function friendlyError(err: unknown): string {
      return err instanceof Error ? err.message : 'Something went wrong — please try again.';
    }

    // Warn on leaving ONLY during the brief pre-accept window: once the server
    // has accepted the job (202), the import runs server-side and closing the
    // tab is completely safe — that's the whole point of import-recipe.
    let submitting = false;
    window.addEventListener('beforeunload', (e) => {
      if (!submitting) return;
      e.preventDefault();
      e.returnValue = '';
    });

    /**
     * Shared runner: hand the job to the import-recipe Edge Function, then
     * poll `recipes` until the finished row appears and open it.
     */
    async function runImport(userId: string, payload: ImportPayload, stepOneLabel: string, note?: string) {
      startProgress(stepOneLabel, note);
      try {
        if (!(await guardGate(userId))) return;

        // Ask for notification permission from this user gesture, so the
        // import tray can announce completion even from another tab.
        requestImportNotifications();

        submitting = true;
        const recipeId = await submitImport(payload);
        submitting = false;

        // Hand tracking to the site-wide import tray: if the user navigates
        // away (or closes the tab and comes back), the tray keeps showing the
        // import and flips to "Ready" when it lands.
        let label = '';
        if (payload.kind === 'link') {
          try { label = new URL((payload as { url: string }).url).hostname.replace(/^www\./, ''); } catch { /* keep empty */ }
        }
        trackImport({ id: recipeId, label, kind: payload.kind });

        setStep(1, 'done'); setStep(2, 'active');
        progTitle.textContent = 'Importing on our servers…';
        (document.getElementById('prog-note') as HTMLElement).textContent =
          "Safe to close this tab — the recipe will appear in your library when it's ready.";

        const found = await waitForRecipe(recipeId);
        if (found) {
          setStep(2, 'done'); setStep(3, 'done');
          removeImport(recipeId); // user is being taken straight to it
          window.location.href = `/my/recipes/view/?id=${encodeURIComponent(recipeId)}`;
        } else {
          showError("This is taking longer than expected. The import may still finish in the background — check My Recipes in a few minutes. If it never appears, the content probably didn't contain a readable recipe.");
        }
      } catch (err) {
        submitting = false;
        showError(friendlyError(err));
      }
    }

    async function guardGate(userId: string): Promise<boolean> {
      const gate = await getSaveGate(userId);
      if (!gate.allowed) {
        showError(`Your library is full (${gate.used}/${gate.limit} recipes). Upgrade to Pro in the app for unlimited recipes.`);
        return false;
      }
      return true;
    }

    // ── Flow: paste text ────────────────────────────────────────────────────
    function wireTextFlow(userId: string) {
      const form = document.getElementById('form-text') as HTMLFormElement;
      const textarea = document.getElementById('recipe-text') as HTMLTextAreaElement;
      const go = document.getElementById('go-text') as HTMLButtonElement;
      textarea.addEventListener('input', () => { go.disabled = textarea.value.trim().length < MIN_TEXT_CHARS; });
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const text = textarea.value.trim();
        if (text.length < MIN_TEXT_CHARS) return;
        runImport(userId, { kind: 'text', text }, 'Handing off to the kitchen');
      });
    }

    // ── Flow: from a link ───────────────────────────────────────────────────
    function wireLinkFlow(userId: string) {
      const form = document.getElementById('form-link') as HTMLFormElement;
      const input = document.getElementById('recipe-url') as HTMLInputElement;
      const go = document.getElementById('go-link') as HTMLButtonElement;
      input.addEventListener('input', () => { go.disabled = !/^https?:\/\/\S+\.\S+/.test(input.value.trim()); });
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const url = input.value.trim();
        if (!url) return;
        const note = classifyLink(url) === 'web'
          ? 'Most recipe pages take 15–40 seconds. Your recipe will sync to the app automatically.'
          : 'Video links can take up to a minute or two. Your recipe will sync to the app automatically.';
        runImport(userId, { kind: 'link', url }, 'Handing off to the kitchen', note);
      });
    }

    // ── Flow: from a photo ──────────────────────────────────────────────────
    function wirePhotoFlow(userId: string) {
      const form = document.getElementById('form-photo') as HTMLFormElement;
      const input = document.getElementById('photo-input') as HTMLInputElement;
      const drop = document.getElementById('drop') as HTMLElement;
      const dropInner = document.getElementById('drop-inner') as HTMLElement;
      const thumbs = document.getElementById('thumbs') as HTMLElement;
      const go = document.getElementById('go-photo') as HTMLButtonElement;
      let files: File[] = [];

      function setFiles(list: FileList | File[]) {
        files = [...list].filter((f) => f.type.startsWith('image/')).slice(0, MAX_PHOTOS);
        go.disabled = files.length === 0;
        thumbs.hidden = files.length === 0;
        dropInner.hidden = files.length > 0;
        thumbs.innerHTML = files.map((f, i) =>
          `<span class="thumb"><img src="${URL.createObjectURL(f)}" alt="photo ${i + 1}"></span>`).join('')
          + `<span class="thumb more">+</span>`;
      }
      input.addEventListener('change', () => input.files && setFiles(input.files));
      drop.addEventListener('dragover', (e) => { e.preventDefault(); drop.classList.add('over'); });
      drop.addEventListener('dragleave', () => drop.classList.remove('over'));
      drop.addEventListener('drop', (e) => {
        e.preventDefault();
        drop.classList.remove('over');
        if (e.dataTransfer?.files.length) setFiles(e.dataTransfer.files);
      });

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (files.length === 0) return;
        startProgress('Preparing your photos');
        try {
          if (!(await guardGate(userId))) return;
          const prepared = await Promise.all(files.map((f) => prepareImage(f)));

          // Upload the first photo as the cover, at the apps' storage path,
          // before handing the job to the server.
          const recipeId = crypto.randomUUID();
          let imageUrl: string | null = null;
          try { imageUrl = await uploadCoverImage(userId, recipeId, prepared[0].blob); } catch { /* cover is optional */ }

          await runImport(
            userId,
            { kind: 'photo', id: recipeId, images: prepared.map((p) => p.dataUrl), imageUrl },
            'Handing off to the kitchen',
          );
        } catch (err) { showError(friendlyError(err)); }
      });
    }

    // ── Flow: create with AI ────────────────────────────────────────────────
    function wireAiFlow(userId: string) {
      const form = document.getElementById('form-ai') as HTMLFormElement;
      const textarea = document.getElementById('ai-ingredients') as HTMLTextAreaElement;
      const go = document.getElementById('go-ai') as HTMLButtonElement;
      const lucky = document.getElementById('go-lucky') as HTMLButtonElement;

      textarea.addEventListener('input', () => { go.disabled = textarea.value.trim().length < 3; });

      function generate(kind: 'ingredients' | 'adventurous') {
        runImport(
          userId,
          { kind: 'ai', mode: kind, ingredients: kind === 'ingredients' ? textarea.value.trim() : undefined },
          kind === 'adventurous' ? 'Dreaming up something new' : 'Composing your recipe',
        );
      }

      form.addEventListener('submit', (e) => { e.preventDefault(); if (textarea.value.trim().length >= 3) generate('ingredients'); });
      lucky.addEventListener('click', () => generate('adventurous'));
    }

    // ── Flow: guided AI wizard (the apps' 4-step guided mode) ───────────────
    function wireGuidedFlow(userId: string) {
      const entry = document.getElementById('ai-entry') as HTMLElement;
      const wizard = document.getElementById('guided-wizard') as HTMLElement;
      const openBtn = document.getElementById('guided-open') as HTMLButtonElement;
      const exitBtn = document.getElementById('gw-exit') as HTMLButtonElement;
      const backBtn = document.getElementById('gw-back') as HTMLButtonElement;
      const nextBtn = document.getElementById('gw-next') as HTMLButtonElement;
      const stepNum = document.getElementById('gw-stepnum') as HTMLElement;
      const ingredientsEl = document.getElementById('gw-ingredients') as HTMLTextAreaElement;
      const steps = [...wizard.querySelectorAll<HTMLElement>('.gw-step')];
      const dots = [...wizard.querySelectorAll<HTMLElement>('.gw-dot')];
      const lines = [...wizard.querySelectorAll<HTMLElement>('.gw-line')];

      // Step order + requiredness mirror iOS GuidedRecipeView.canProceed:
      // vibe, dietary, time each required; ingredients (step 4) optional.
      const picks: { vibe?: string; dietary?: string; time?: string } = {};
      const stepKeys = ['vibe', 'dietary', 'time'] as const;
      let step = 1;

      function render() {
        steps.forEach((s) => { s.hidden = Number(s.dataset.step) !== step; });
        dots.forEach((d, i) => {
          d.classList.toggle('filled', i + 1 <= step);
          d.classList.toggle('current', i + 1 === step);
        });
        lines.forEach((l, i) => l.classList.toggle('filled', i + 1 < step));
        stepNum.textContent = `Step ${step} of 4`;
        backBtn.hidden = step === 1;
        nextBtn.textContent = step === 4 ? 'Generate My Recipe' : 'Continue';
        nextBtn.disabled = step < 4 && !picks[stepKeys[step - 1]];
      }

      function openWizard() {
        errorEl.hidden = true;
        entry.hidden = true;
        wizard.hidden = false;
        render();
      }

      openBtn.addEventListener('click', openWizard);
      exitBtn.addEventListener('click', () => { wizard.hidden = true; entry.hidden = false; });

      wizard.querySelectorAll<HTMLElement>('.gw-options').forEach((group) => {
        group.addEventListener('click', (e) => {
          const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.gw-opt');
          if (!btn) return;
          picks[group.dataset.key as (typeof stepKeys)[number]] = btn.dataset.value!;
          group.querySelectorAll('.gw-opt').forEach((b) => b.classList.toggle('selected', b === btn));
          render();
        });
      });

      backBtn.addEventListener('click', () => { if (step > 1) { step -= 1; render(); } });
      nextBtn.addEventListener('click', () => {
        if (step < 4) {
          if (!picks[stepKeys[step - 1]]) return;
          step += 1;
          render();
          return;
        }
        const ingredients = ingredientsEl.value.trim();
        runImport(
          userId,
          {
            kind: 'ai',
            mode: 'guided',
            vibe: picks.vibe!,
            dietary: picks.dietary!,
            time: picks.time!,
            ingredients: ingredients || undefined,
          },
          'Composing your recipe',
        );
      });

      return { openWizard };
    }

    // ── Init ────────────────────────────────────────────────────────────────
    async function init() {
      const session = await requireSession();
      if (!session) return;
      const userId = session.user.id;

      const gate = await getSaveGate(userId).catch(() => null);
      loading.hidden = true;
      if (gate && !gate.allowed) {
        gateMsg.textContent = `You've used ${gate.used} of ${gate.limit} free recipe slots. Upgrade to Pro in the RecipeBox AI app for unlimited recipes.`;
        gateBlocked.hidden = false;
        return;
      }

      forms.hidden = false;
      wireTextFlow(userId);
      wireLinkFlow(userId);
      wirePhotoFlow(userId);
      wireAiFlow(userId);
      const guided = wireGuidedFlow(userId);

      // Deep-linkable method selection: /my/recipes/add/?method=link
      // (?method=guided opens the AI panel with the wizard already active)
      const method = new URLSearchParams(window.location.search).get('method');
      if (method && ['text', 'link', 'photo', 'ai'].includes(method)) showPanel(method);
      if (method === 'guided') { showPanel('ai'); guided.openWizard(); }
    }

    init().catch((err) => {
      loading.hidden = true;
      forms.hidden = false;
      showError(err instanceof Error ? err.message : 'Something went wrong.');
    });
  </script>
</BaseLayout>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; background: var(--bg); color: var(--ink); font-family: var(--sans); line-height: 1.45; }
  body { -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility; }
  ::selection { background: var(--ink); color: var(--bg); }
  img { display: block; max-width: 100%; }
  a { color: inherit; text-decoration: none; }
  button { font: inherit; cursor: pointer; }
  [hidden] { display: none !important; }

  .container { max-width: 1440px; margin: 0 auto; padding: 0 56px; }
  .container.narrow { max-width: 880px; }
  .display { font-family: var(--serif); font-weight: 400; font-variation-settings: "opsz" 144; line-height: 0.96; letter-spacing: -0.035em; text-wrap: balance; }
  .display em { font-style: italic; font-weight: 400; }
  .eyebrow { font-family: var(--sans); font-size: 11px; font-weight: 700; letter-spacing: 1.6px; text-transform: uppercase; color: var(--muted); }
  .lead { font-size: 18px; line-height: 1.5; color: var(--ink-2); letter-spacing: -0.01em; text-wrap: pretty; }

  /* Nav (matches /my/recipes/) */
  nav.rb-nav { position: sticky; top: 0; z-index: 50; backdrop-filter: saturate(180%) blur(14px); -webkit-backdrop-filter: saturate(180%) blur(14px); background: color-mix(in srgb, var(--bg) 86%, transparent); border-bottom: 1px solid var(--line-2); }
  nav.rb-nav .inner { display: flex; align-items: center; justify-content: space-between; height: 64px; max-width: 1200px; margin: 0 auto; }
  nav.rb-nav .brand { display: flex; align-items: center; gap: 10px; font-weight: 700; letter-spacing: -0.02em; font-size: 17px; color: var(--ink); }
  nav.rb-nav .brand .app-ico { width: 30px; height: 30px; border-radius: 7px; box-shadow: 0 1px 2px rgba(0,0,0,0.18); }
  nav.rb-nav ul { list-style: none; padding: 0; margin: 0; display: flex; gap: 28px; }
  nav.rb-nav ul a { font-size: 14px; font-weight: 500; color: var(--ink-2); }
  nav.rb-nav ul a.current, nav.rb-nav ul a:hover { color: var(--ink); }
  nav.rb-nav .nav-actions { display: flex; align-items: center; gap: 12px; }

  .crumb { padding: 28px 0 0; font-size: 13px; color: var(--muted); display: flex; gap: 8px; align-items: center; }
  .crumb a:hover { color: var(--ink); }
  .crumb .sep { opacity: 0.5; }

  header.page-head { padding: 26px 0 30px; }
  header.page-head h1 { font-size: 72px; margin: 14px 0 0; }
  header.page-head .lead { margin-top: 14px; max-width: 58ch; }

  /* Method tiles */
  .methods { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 26px; }
  .method { position: relative; text-align: left; display: flex; flex-direction: column; gap: 4px; padding: 16px 16px 14px; border-radius: 18px; border: 1px solid var(--line); background: transparent; color: var(--ink); transition: border-color 120ms ease, background 120ms ease; }
  .method:hover { border-color: var(--line-strong); }
  .method .m-ico { color: var(--ink-2); margin-bottom: 6px; }
  .method .m-name { font-weight: 650; font-size: 14.5px; letter-spacing: -0.01em; }
  .method .m-desc { font-size: 12px; color: var(--muted); }
  .method.active { border-color: var(--solid); background: color-mix(in srgb, var(--solid) 5%, transparent); }
  .method.active .m-ico { color: var(--ink); }

  /* Panel + forms */
  main.panel { padding-bottom: 96px; }
  .field-label { display: block; font-size: 12px; font-weight: 700; letter-spacing: 1.2px; text-transform: uppercase; color: var(--muted); margin-bottom: 10px; }
  #recipe-text, .ai-textarea { width: 100%; min-height: 280px; resize: vertical; padding: 20px; border-radius: 18px; border: 1px solid var(--line); background: var(--card); color: var(--ink); font-family: var(--sans); font-size: 15px; line-height: 1.6; outline: none; transition: border-color 120ms ease; }
  .ai-textarea { min-height: 140px; }
  #recipe-text:focus, .ai-textarea:focus, .url-input:focus { border-color: var(--line-strong); }
  #recipe-text::placeholder, .ai-textarea::placeholder, .url-input::placeholder { color: var(--muted); }
  .url-input { width: 100%; padding: 16px 20px; border-radius: 999px; border: 1px solid var(--line); background: var(--card); color: var(--ink); font-family: var(--sans); font-size: 15px; outline: none; transition: border-color 120ms ease; }
  .form-row { display: flex; justify-content: space-between; align-items: center; gap: 16px; margin-top: 14px; flex-wrap: wrap; }
  .hint { font-size: 12.5px; color: var(--muted); max-width: 52ch; }
  .go-btn { display: inline-flex; align-items: center; gap: 8px; height: 46px; padding: 0 24px; border-radius: 999px; background: var(--solid); color: var(--on-solid); border: 0; font-size: 14px; font-weight: 600; transition: opacity 120ms ease; margin-left: auto; }
  .go-btn:hover { background: color-mix(in srgb, var(--solid) 92%, var(--bg)); }
  .go-btn:disabled { opacity: 0.4; cursor: default; }
  .lucky-btn { display: inline-flex; align-items: center; gap: 8px; height: 46px; padding: 0 22px; border-radius: 999px; background: transparent; border: 1px solid var(--line); color: var(--ink); font-size: 14px; font-weight: 600; transition: border-color 120ms ease; }
  .lucky-btn:hover { border-color: var(--line-strong); }
  .error { margin-top: 16px; padding: 14px 18px; border-radius: 14px; border: 1px solid color-mix(in srgb, #e0533d 35%, transparent); background: color-mix(in srgb, #e0533d 7%, transparent); color: var(--ink); font-size: 14px; }

  /* Guided wizard */
  .guided-launch { display: flex; align-items: center; gap: 14px; width: 100%; text-align: left; padding: 16px 18px; margin-bottom: 18px; border-radius: 16px; border: 1px solid var(--line); background: var(--card); color: var(--ink); transition: border-color 120ms ease, background 120ms ease; }
  .guided-launch:hover { border-color: var(--line-strong); }
  .guided-launch .g-ico { display: grid; place-items: center; width: 40px; height: 40px; border-radius: 12px; background: color-mix(in srgb, var(--solid) 8%, transparent); color: var(--ink); flex-shrink: 0; }
  .guided-launch .g-copy { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .guided-launch .g-copy b { font-size: 14.5px; font-weight: 650; letter-spacing: -0.01em; }
  .guided-launch .g-copy span { font-size: 12.5px; color: var(--muted); }
  .guided-launch .g-arrow { margin-left: auto; color: var(--muted); flex-shrink: 0; transition: transform 120ms ease; }
  .guided-launch:hover .g-arrow { transform: translateX(3px); color: var(--ink); }
  .or-divider { display: flex; align-items: center; gap: 12px; margin: 0 0 18px; color: var(--muted); font-size: 11px; font-weight: 700; letter-spacing: 1.4px; text-transform: uppercase; }
  .or-divider::before, .or-divider::after { content: ""; flex: 1; height: 1px; background: var(--line-2); }

  .gw-head { margin-bottom: 26px; }
  .gw-dots { display: flex; align-items: center; max-width: 340px; margin: 0 auto 10px; }
  .gw-dot { width: 12px; height: 12px; border-radius: 50%; border: 2px solid var(--line-strong); background: transparent; flex-shrink: 0; transition: background 150ms ease, border-color 150ms ease, box-shadow 150ms ease; }
  .gw-dot.filled { background: var(--solid); border-color: var(--solid); }
  .gw-dot.current { box-shadow: 0 0 0 3px color-mix(in srgb, var(--solid) 22%, transparent); }
  .gw-line { flex: 1; height: 2px; background: var(--line-2); margin: 0 6px; transition: background 150ms ease; }
  .gw-line.filled { background: var(--solid); }
  .gw-meta { display: flex; align-items: center; justify-content: center; gap: 14px; font-size: 12.5px; color: var(--muted); }
  .gw-exit { background: none; border: 0; padding: 0; font-size: 12.5px; color: var(--muted); text-decoration: underline; text-underline-offset: 3px; }
  .gw-exit:hover { color: var(--ink); }

  .gw-title { font-family: var(--serif); font-size: 28px; font-weight: 500; letter-spacing: -0.02em; margin: 0 0 6px; display: flex; align-items: center; gap: 10px; }
  .gw-badge { font-family: var(--sans); font-size: 11px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: var(--muted); border: 1px solid var(--line); border-radius: 999px; padding: 3px 10px; }
  .gw-sub { margin: 0 0 18px; font-size: 14px; color: var(--muted); }
  .gw-options { display: flex; flex-direction: column; gap: 10px; max-width: 480px; }
  .gw-opt { text-align: left; padding: 14px 18px; border-radius: 14px; border: 1px solid var(--line); background: var(--card); color: var(--ink); font-size: 14.5px; font-weight: 550; transition: border-color 120ms ease, background 120ms ease; }
  .gw-opt:hover { border-color: var(--line-strong); }
  .gw-opt.selected { border-color: var(--solid); background: color-mix(in srgb, var(--solid) 6%, transparent); font-weight: 650; }
  #gw-ingredients { min-height: 120px; max-width: 480px; }
  .gw-hint { margin: 10px 0 0; font-size: 12.5px; color: var(--muted); }
  .gw-nav { display: flex; justify-content: space-between; align-items: center; gap: 16px; margin-top: 24px; }

  @media (max-width: 760px) {
    .gw-title { font-size: 24px; }
    .gw-nav { flex-direction: column-reverse; align-items: stretch; }
    .gw-nav .go-btn, .gw-nav .lucky-btn { justify-content: center; margin-left: 0; }
  }

  /* Photo drop zone */
  .drop { display: block; border: 1.5px dashed var(--line-strong); border-radius: 18px; background: var(--card); padding: 36px 24px; cursor: pointer; transition: border-color 120ms ease, background 120ms ease; }
  .drop.over { border-color: var(--solid); background: color-mix(in srgb, var(--solid) 5%, var(--card)); }
  .drop-inner { display: flex; flex-direction: column; align-items: center; gap: 8px; text-align: center; color: var(--ink-2); font-size: 14px; }
  .drop-inner svg { color: var(--muted); }
  .drop-inner b { color: var(--ink); }
  .drop-sub { font-size: 12.5px; color: var(--muted); }
  .thumbs { display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; }
  .thumb { width: 84px; height: 84px; border-radius: 12px; overflow: hidden; background: var(--bg-2); }
  .thumb img { width: 100%; height: 100%; object-fit: cover; }
  .thumb.more { display: grid; place-items: center; font-size: 24px; color: var(--muted); border: 1px dashed var(--line-strong); background: transparent; }

  /* Progress */
  .prog-card { padding: 40px 32px; border: 1px solid var(--line-2); border-radius: 22px; background: var(--card); text-align: center; }
  .prog-card h3 { font-family: var(--serif); font-size: 30px; font-weight: 500; letter-spacing: -0.02em; margin: 0 0 24px; }
  .steps { list-style: none; margin: 0 auto; padding: 0; display: flex; flex-direction: column; gap: 12px; max-width: 340px; text-align: left; }
  .steps li { display: flex; align-items: center; gap: 12px; font-size: 14.5px; color: var(--muted); transition: color 150ms ease; }
  .steps li .dot { width: 10px; height: 10px; border-radius: 50%; border: 2px solid var(--line-strong); flex-shrink: 0; }
  .steps li.active { color: var(--ink); font-weight: 600; }
  .steps li.active .dot { border-color: var(--solid); animation: pulse 1.1s ease infinite; }
  .steps li.done { color: var(--ink-2); }
  .steps li.done .dot { background: var(--solid); border-color: var(--solid); }
  @keyframes pulse { 50% { transform: scale(1.35); } }
  .prog-note { margin: 26px auto 0; font-size: 13px; color: var(--muted); max-width: 44ch; }

  /* States + skeleton */
  .state-card { padding: 72px 28px; text-align: center; background: var(--card); border: 1px solid var(--line-2); border-radius: 22px; }
  .state-card h3 { font-family: var(--serif); font-size: 32px; font-weight: 500; letter-spacing: -0.02em; margin: 0 0 10px; }
  .state-card p { margin: 0 auto; color: var(--muted); font-size: 15px; max-width: 46ch; }
  .state-btn { display: inline-flex; align-items: center; justify-content: center; margin-top: 24px; height: 46px; padding: 0 24px; border-radius: 999px; background: var(--solid); color: var(--on-solid); border: 0; font-size: 14px; font-weight: 600; }
  .sk-panel .sk-line { height: 14px; border-radius: 7px; margin-bottom: 14px; }
  .sk-panel .sk-line.w40 { width: 40%; }
  .sk-panel .sk-area { height: 280px; border-radius: 18px; }
  .sk-panel .sk-line, .sk-panel .sk-area { background: linear-gradient(90deg, var(--bg-2) 25%, #e0dcd2 50%, var(--bg-2) 75%); background-size: 200% 100%; animation: shimmer 1.4s ease infinite; }
  @keyframes shimmer { to { background-position: -200% 0; } }

  /* Footer */
  footer.rb-footer { background: var(--panel); color: rgba(255,255,255,0.7); padding: 56px 0 64px; }
  footer.rb-footer .row { display: flex; justify-content: space-between; align-items: center; gap: 24px; flex-wrap: wrap; }
  footer.rb-footer .brand { display: flex; align-items: center; gap: 10px; color: #fff; font-weight: 700; letter-spacing: -0.02em; font-size: 16px; }
  footer.rb-footer .brand .app-ico { width: 28px; height: 28px; border-radius: 7px; box-shadow: 0 0 0 1px rgba(255,255,255,0.12); }
  footer.rb-footer .links { display: flex; gap: 24px; font-size: 14px; }
  footer.rb-footer .links a { color: rgba(255,255,255,0.6); }
  footer.rb-footer .links a:hover { color: #fff; }
  footer.rb-footer .copy { font-size: 13px; color: rgba(255,255,255,0.4); }

  /* Responsive */
  @media (max-width: 1100px) {
    .container { padding: 0 32px; }
    header.page-head h1 { font-size: 56px; }
    .methods { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 760px) {
    .container { padding: 0 22px; }
    nav.rb-nav ul { display: none; }
    header.page-head h1 { font-size: 44px; line-height: 1; }
    .methods { grid-template-columns: 1fr 1fr; }
    .form-row { flex-direction: column; align-items: stretch; }
    .go-btn, .lucky-btn { justify-content: center; margin-left: 0; }
    footer.rb-footer .row { flex-direction: column; align-items: flex-start; gap: 18px; }
  }

  /* Dark-mode overrides for values with no token equivalent */
  :root[data-theme="dark"] .sk-panel .sk-line,
  :root[data-theme="dark"] .sk-panel .sk-area { background: linear-gradient(90deg, var(--bg-2) 25%, #2a2723 50%, var(--bg-2) 75%); background-size: 200% 100%; }
</style>
