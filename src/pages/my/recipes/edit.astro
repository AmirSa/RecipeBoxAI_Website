---
import BaseLayout from '@layouts/BaseLayout.astro';
import NavAccount from '@components/NavAccount.astro';
import ThemeToggle from '@components/ThemeToggle.astro';
import MobileNav from '@components/MobileNav.astro';
import ImportTray from '@components/ImportTray.astro';
---

<BaseLayout title="Edit Recipe" description="Edit a recipe in your RecipeBox AI library.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,800&family=Inter+Tight:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <meta name="robots" content="noindex">

  <!-- ─── Nav ─── -->
  <nav class="rb-nav">
    <div class="container inner">
      <a class="brand" href="/">
        <img class="app-ico" src="/app-icon.png" alt="">
        RecipeBox AI
      </a>
      <ul>
        <li><a id="nav-primary" class="current" href="/my/recipes/">My Recipes</a></li>
        <li><a href="/my/cookbooks/">My Cookbooks</a></li>
        <li><a href="/recipes/">Discover</a></li>
      </ul>
      <div class="nav-actions">
        <NavAccount dest="/login/" />
        <ThemeToggle />
        <MobileNav />
      </div>
    </div>
  </nav>

  <ImportTray />

  <div class="container narrow">
    <div class="crumb">
      <a href="/my/recipes/">My Recipes</a>
      <span class="sep">/</span>
      <a id="crumb-recipe" href="/my/recipes/"><span class="sk-inline" id="crumb-sk"></span></a>
      <span class="sep">/</span>
      <span style="color: var(--ink);">Edit</span>
    </div>

    <header class="page-head">
      <h1 class="display">Edit <em>recipe.</em></h1>
      <p class="lead">Changes save to your library and sync to all your devices.</p>
    </header>

    <div id="loading">
      <div class="sk-line w40"></div>
      <div class="sk-area"></div>
    </div>

    <div id="state" hidden></div>

    <form id="editor" hidden novalidate>
      <!-- Title -->
      <section class="ed-block">
        <label class="field-label" for="f-title">Title</label>
        <input id="f-title" class="title-input" type="text" maxlength="300" placeholder="Recipe title" autocomplete="off" spellcheck="false">
      </section>

      <!-- Description -->
      <section class="ed-block">
        <label class="field-label" for="f-notes">Description</label>
        <textarea id="f-notes" class="notes-area" rows="4" placeholder="A short description or your own notes about this recipe…"></textarea>
      </section>

      <!-- Cover photo -->
      <section class="ed-block">
        <span class="field-label">Cover photo</span>
        <div class="photo-row">
          <div class="photo-prev" id="photo-prev"></div>
          <div class="photo-actions">
            <button type="button" class="ghost-btn" id="photo-pick">Choose a photo</button>
            <button type="button" class="ghost-btn danger" id="photo-remove" hidden>Remove photo</button>
            <span class="hint">JPG or PNG. It becomes the recipe's cover on every device.</span>
            <input type="file" id="photo-input" accept="image/*" hidden>
          </div>
        </div>
      </section>

      <!-- Ingredients -->
      <section class="ed-block">
        <span class="field-label">Ingredients</span>
        <div id="sections"></div>
        <button type="button" class="add-btn" id="add-section">+ Add section</button>
      </section>

      <!-- Method -->
      <section class="ed-block">
        <span class="field-label">Method</span>
        <ol class="step-edit-list" id="steps"></ol>
        <button type="button" class="add-btn" id="add-step">+ Add step</button>
      </section>

      <div class="error" id="error" hidden></div>

      <div class="save-bar">
        <a class="btn-secondary" id="cancel-link" href="/my/recipes/">Cancel</a>
        <button class="go-btn" id="save-btn" type="submit">Save changes</button>
      </div>
    </form>
  </div>

  <footer class="rb-footer">
    <div class="container row">
      <div class="brand">
        <img class="app-ico" src="/app-icon.png" alt="">
        RecipeBox AI
      </div>
      <div class="links">
        <a href="mailto:hello@recipeboxai.app">Support</a>
        <a href="/privacy/">Privacy</a>
        <a href="/terms/">Terms</a>
        <a href="https://twitter.com/RecipeBoxAI">Twitter</a>
      </div>
      <div class="copy">© 2026 RecipeBox AI</div>
    </div>
  </footer>

  <script>
    import {
      supabase, requireSession, escapeHtml, updateRecipe,
      parseIngredientSections, parseInstructions,
      type UserRecipeRow, type WireIngredientSection, type WireIngredient,
    } from '@/lib/account';
    import { prepareImage, uploadCoverImage } from '@/lib/ai';

    const loading = document.getElementById('loading') as HTMLElement;
    const stateEl = document.getElementById('state') as HTMLElement;
    const editor = document.getElementById('editor') as HTMLFormElement;
    const errorEl = document.getElementById('error') as HTMLElement;
    const sectionsEl = document.getElementById('sections') as HTMLElement;
    const stepsEl = document.getElementById('steps') as HTMLElement;
    const titleInput = document.getElementById('f-title') as HTMLInputElement;
    const notesInput = document.getElementById('f-notes') as HTMLTextAreaElement;
    const photoPrev = document.getElementById('photo-prev') as HTMLElement;
    const photoPick = document.getElementById('photo-pick') as HTMLButtonElement;
    const photoRemove = document.getElementById('photo-remove') as HTMLButtonElement;
    const photoInput = document.getElementById('photo-input') as HTMLInputElement;
    const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;

    let userId = '';
    let recipeId = '';
    let existingImageUrl: string | null = null;
    let newImageFile: File | null = null;
    let imageRemoved = false;
    let dirty = false;
    let saving = false;

    function showState(title: string, body: string) {
      loading.hidden = true;
      editor.hidden = true;
      stateEl.hidden = false;
      stateEl.innerHTML = `
        <div class="page-state">
          <h2>${escapeHtml(title)}</h2>
          <p>${escapeHtml(body)}</p>
          <a class="state-btn" href="/my/recipes/">Back to My Recipes</a>
        </div>`;
    }

    // ── Element builders ──────────────────────────────────────────────────
    // The form's state lives in the DOM: rows are built programmatically
    // (values set via .value, never innerHTML) and read back on save.

    function el<K extends keyof HTMLElementTagNameMap>(tag: K, className?: string): HTMLElementTagNameMap[K] {
      const node = document.createElement(tag);
      if (className) node.className = className;
      return node;
    }

    function makeIngredientRow(ing?: WireIngredient): HTMLElement {
      const row = el('div', 'ing-row');
      // Keep the original raw text so an untouched row round-trips losslessly.
      if (ing?.originalText) row.dataset.originalText = ing.originalText;

      const amount = el('input', 'ing-amount');
      amount.type = 'text';
      amount.placeholder = 'Amount';
      amount.autocomplete = 'off';
      amount.value = ing?.amount ?? '';

      const unit = el('input', 'ing-unit');
      unit.type = 'text';
      unit.placeholder = 'Unit';
      unit.autocomplete = 'off';
      unit.value = ing?.unit ?? '';

      const name = el('input', 'ing-name');
      name.type = 'text';
      name.placeholder = 'Ingredient';
      name.autocomplete = 'off';
      // additionalInfo is display-appended in the apps and on the view page
      // ("flour, sifted") — fold it into the editable name so what the user
      // sees in this input is exactly what every device will render.
      name.value = ing ? `${ing.name}${ing.additionalInfo ? `, ${ing.additionalInfo}` : ''}` : '';

      const remove = el('button', 'row-x');
      remove.type = 'button';
      remove.title = 'Remove ingredient';
      remove.setAttribute('aria-label', 'Remove ingredient');
      remove.textContent = '✕';
      remove.addEventListener('click', () => { row.remove(); markDirty(); });

      row.append(amount, unit, name, remove);
      return row;
    }

    function makeSection(section?: WireIngredientSection): HTMLElement {
      const wrap = el('div', 'ing-section');

      const head = el('div', 'sec-head');
      const header = el('input', 'sec-name');
      header.type = 'text';
      header.placeholder = 'Section name (optional) — e.g. For the sauce';
      header.autocomplete = 'off';
      header.value = section?.header ?? '';
      const removeSec = el('button', 'ghost-btn danger sec-x');
      removeSec.type = 'button';
      removeSec.textContent = 'Remove section';
      removeSec.addEventListener('click', () => {
        if (rows.children.length > 0 && !confirm('Remove this section and its ingredients?')) return;
        wrap.remove();
        markDirty();
      });
      head.append(header, removeSec);

      const rows = el('div', 'ing-rows');
      for (const ing of section?.ingredients ?? []) rows.appendChild(makeIngredientRow(ing));

      const add = el('button', 'add-btn small');
      add.type = 'button';
      add.textContent = '+ Add ingredient';
      add.addEventListener('click', () => {
        rows.appendChild(makeIngredientRow());
        (rows.lastElementChild!.querySelector('.ing-amount') as HTMLInputElement).focus();
        markDirty();
      });

      wrap.append(head, rows, add);
      return wrap;
    }

    function makeStep(text?: string): HTMLElement {
      const li = el('li', 'step-row');
      const area = el('textarea', 'step-text');
      area.rows = 2;
      area.placeholder = 'Describe this step…';
      area.value = text ?? '';
      const autosize = () => {
        area.style.height = 'auto';
        area.style.height = `${area.scrollHeight}px`;
      };
      area.addEventListener('input', autosize);
      requestAnimationFrame(autosize);

      const remove = el('button', 'row-x');
      remove.type = 'button';
      remove.title = 'Remove step';
      remove.setAttribute('aria-label', 'Remove step');
      remove.textContent = '✕';
      remove.addEventListener('click', () => { li.remove(); markDirty(); });

      li.append(area, remove);
      return li;
    }

    // ── Cover photo ───────────────────────────────────────────────────────

    function paintPhoto() {
      const url = newImageFile
        ? URL.createObjectURL(newImageFile)
        : (imageRemoved ? null : existingImageUrl);
      if (url) {
        photoPrev.classList.remove('empty');
        photoPrev.innerHTML = '';
        const img = el('img');
        img.src = url;
        img.alt = 'Recipe cover';
        photoPrev.appendChild(img);
        photoRemove.hidden = false;
        photoPick.textContent = 'Replace photo';
      } else {
        photoPrev.classList.add('empty');
        photoPrev.innerHTML = '<span>No photo</span>';
        photoRemove.hidden = true;
        photoPick.textContent = 'Choose a photo';
      }
    }

    function wirePhoto() {
      photoPick.addEventListener('click', () => photoInput.click());
      photoInput.addEventListener('change', () => {
        const file = photoInput.files?.[0];
        if (!file || !file.type.startsWith('image/')) return;
        newImageFile = file;
        imageRemoved = false;
        paintPhoto();
        markDirty();
      });
      photoRemove.addEventListener('click', () => {
        newImageFile = null;
        imageRemoved = true;
        photoInput.value = '';
        paintPhoto();
        markDirty();
      });
    }

    // ── Dirty tracking ────────────────────────────────────────────────────

    function markDirty() { dirty = true; }
    window.addEventListener('beforeunload', (e) => {
      if (!dirty || saving) return;
      e.preventDefault();
      e.returnValue = '';
    });

    // ── Read the form back into wire format ───────────────────────────────

    function collectSections(): string | null {
      const out: { header: string; ingredients: { name: string; amount: string; unit: string; originalText: string }[] }[] = [];
      for (const sec of sectionsEl.querySelectorAll<HTMLElement>('.ing-section')) {
        const header = (sec.querySelector('.sec-name') as HTMLInputElement).value.trim();
        const ingredients = [...sec.querySelectorAll<HTMLElement>('.ing-row')]
          .map((row) => ({
            name: (row.querySelector('.ing-name') as HTMLInputElement).value.trim(),
            amount: (row.querySelector('.ing-amount') as HTMLInputElement).value.trim(),
            unit: (row.querySelector('.ing-unit') as HTMLInputElement).value.trim(),
            originalText: row.dataset.originalText ?? '',
          }))
          .filter((i) => i.name.length > 0);
        if (ingredients.length > 0) out.push({ header, ingredients });
      }
      // Double-encoded on the wire (the row column holds a JSON *string*).
      return out.length > 0 ? JSON.stringify(out) : null;
    }

    function collectInstructions(): string | null {
      const steps = [...stepsEl.querySelectorAll<HTMLTextAreaElement>('.step-text')]
        // The wire format is newline-joined, so a step can't contain newlines.
        .map((a) => a.value.replace(/\s*\n\s*/g, ' ').trim())
        .filter(Boolean);
      return steps.length > 0 ? steps.join('\n') : null;
    }

    // ── Save ──────────────────────────────────────────────────────────────

    function wireSave() {
      editor.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorEl.hidden = true;

        const title = titleInput.value.trim();
        if (!title) {
          errorEl.textContent = 'Please give the recipe a title.';
          errorEl.hidden = false;
          titleInput.focus();
          return;
        }

        saving = true;
        saveBtn.disabled = true;
        saveBtn.textContent = 'Saving…';
        try {
          let imageUrl = imageRemoved ? null : existingImageUrl;
          if (newImageFile) {
            // Same downscale + storage path as the add-recipe photo flow
            // (recipe-images/{userId}/{recipeId}/{uuid}.jpg).
            const { blob } = await prepareImage(newImageFile);
            imageUrl = await uploadCoverImage(userId, recipeId, blob);
          }

          await updateRecipe(recipeId, {
            title,
            notes: notesInput.value.trim() || null,
            image_url: imageUrl,
            ingredient_sections: collectSections(),
            instructions: collectInstructions(),
          });

          dirty = false;
          window.location.href = `/my/recipes/view/?id=${encodeURIComponent(recipeId)}`;
        } catch (err) {
          saving = false;
          saveBtn.disabled = false;
          saveBtn.textContent = 'Save changes';
          errorEl.textContent = 'Could not save changes: ' + (err instanceof Error ? err.message : 'please try again');
          errorEl.hidden = false;
        }
      });
    }

    // ── Init ──────────────────────────────────────────────────────────────

    async function load() {
      const session = await requireSession();
      if (!session) return;
      userId = session.user.id;

      const id = new URLSearchParams(window.location.search).get('id');
      if (!id) {
        showState('Recipe not found', 'This link is missing a recipe id.');
        return;
      }
      recipeId = id;

      const { data, error } = await supabase
        .from('recipes')
        .select('*')
        .eq('id', id)
        .is('deleted_at', null)
        .maybeSingle();

      if (error) {
        showState("Couldn't load this recipe", error.message);
        return;
      }
      if (!data) {
        showState('Recipe not found', "This recipe doesn't exist in your library — it may have been deleted on another device.");
        return;
      }

      const recipe = data as unknown as UserRecipeRow;
      const title = recipe.title || 'Untitled recipe';
      document.title = `Edit ${title} - RecipeBox AI`;

      const crumb = document.getElementById('crumb-recipe') as HTMLAnchorElement;
      crumb.href = `/my/recipes/view/?id=${encodeURIComponent(recipe.id)}`;
      crumb.textContent = title;
      (document.getElementById('cancel-link') as HTMLAnchorElement).href = crumb.href;

      titleInput.value = recipe.title ?? '';
      notesInput.value = recipe.notes ?? '';
      existingImageUrl = recipe.image_url;

      const sections = parseIngredientSections(recipe.ingredient_sections);
      for (const s of sections) sectionsEl.appendChild(makeSection(s));
      if (sections.length === 0) sectionsEl.appendChild(makeSection());

      const steps = parseInstructions(recipe.instructions);
      for (const s of steps) stepsEl.appendChild(makeStep(s));
      if (steps.length === 0) stepsEl.appendChild(makeStep());

      paintPhoto();
      wirePhoto();
      wireSave();

      document.getElementById('add-section')!.addEventListener('click', () => {
        const sec = makeSection();
        sectionsEl.appendChild(sec);
        (sec.querySelector('.sec-name') as HTMLInputElement).focus();
        markDirty();
      });
      document.getElementById('add-step')!.addEventListener('click', () => {
        const step = makeStep();
        stepsEl.appendChild(step);
        (step.querySelector('.step-text') as HTMLTextAreaElement).focus();
        markDirty();
      });
      editor.addEventListener('input', markDirty);

      loading.hidden = true;
      editor.hidden = false;
    }

    load().catch((err) => showState('Something went wrong', err instanceof Error ? err.message : 'Please try again.'));
  </script>
</BaseLayout>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; background: var(--bg); color: var(--ink); font-family: var(--sans); line-height: 1.45; }
  body { -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility; }
  ::selection { background: var(--ink); color: var(--bg); }
  img { display: block; max-width: 100%; }
  a { color: inherit; text-decoration: none; }
  button { font: inherit; cursor: pointer; }
  [hidden] { display: none !important; }

  .container { max-width: 1440px; margin: 0 auto; padding: 0 56px; }
  .container.narrow { max-width: 880px; }
  .display { font-family: var(--serif); font-weight: 400; font-variation-settings: "opsz" 144; line-height: 0.96; letter-spacing: -0.035em; text-wrap: balance; }
  .display em { font-style: italic; font-weight: 400; }
  .lead { font-size: 18px; line-height: 1.5; color: var(--ink-2); letter-spacing: -0.01em; text-wrap: pretty; }

  /* Nav (matches /my/recipes/) */
  nav.rb-nav { position: sticky; top: 0; z-index: 50; backdrop-filter: saturate(180%) blur(14px); -webkit-backdrop-filter: saturate(180%) blur(14px); background: color-mix(in srgb, var(--bg) 86%, transparent); border-bottom: 1px solid var(--line-2); }
  nav.rb-nav .inner { display: flex; align-items: center; justify-content: space-between; height: 64px; max-width: 1200px; margin: 0 auto; }
  nav.rb-nav .brand { display: flex; align-items: center; gap: 10px; font-weight: 700; letter-spacing: -0.02em; font-size: 17px; color: var(--ink); }
  nav.rb-nav .brand .app-ico { width: 30px; height: 30px; border-radius: 7px; box-shadow: 0 1px 2px rgba(0,0,0,0.18); }
  nav.rb-nav ul { list-style: none; padding: 0; margin: 0; display: flex; gap: 28px; }
  nav.rb-nav ul a { font-size: 14px; font-weight: 500; color: var(--ink-2); }
  nav.rb-nav ul a.current, nav.rb-nav ul a:hover { color: var(--ink); }
  nav.rb-nav .nav-actions { display: flex; align-items: center; gap: 12px; }

  .crumb { padding: 28px 0 0; font-size: 13px; color: var(--muted); display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
  .crumb a:hover { color: var(--ink); }
  .crumb .sep { opacity: 0.5; }

  header.page-head { padding: 26px 0 30px; }
  header.page-head h1 { font-size: 72px; margin: 0; }
  header.page-head .lead { margin-top: 14px; max-width: 58ch; }

  /* Editor blocks */
  #editor { padding-bottom: 96px; }
  .ed-block { margin-bottom: 36px; }
  .field-label { display: block; font-size: 12px; font-weight: 700; letter-spacing: 1.2px; text-transform: uppercase; color: var(--muted); margin-bottom: 10px; }
  .hint { font-size: 12.5px; color: var(--muted); }

  .title-input { width: 100%; padding: 14px 20px; border-radius: 16px; border: 1px solid var(--line); background: var(--card); color: var(--ink); font-family: var(--serif); font-size: 28px; font-weight: 500; letter-spacing: -0.02em; outline: none; transition: border-color 120ms ease; }
  .notes-area { width: 100%; min-height: 110px; resize: vertical; padding: 16px 20px; border-radius: 16px; border: 1px solid var(--line); background: var(--card); color: var(--ink); font-family: var(--sans); font-size: 15px; line-height: 1.6; outline: none; transition: border-color 120ms ease; }
  .title-input:focus, .notes-area:focus, .sec-name:focus, .ing-row input:focus, .step-text:focus { border-color: var(--line-strong); }
  .title-input::placeholder, .notes-area::placeholder { color: var(--muted); }

  /* Cover photo */
  .photo-row { display: flex; gap: 20px; align-items: flex-start; }
  .photo-prev { width: 168px; aspect-ratio: 4/5; border-radius: 18px; overflow: hidden; background: var(--bg-2); flex-shrink: 0; }
  .photo-prev img { width: 100%; height: 100%; object-fit: cover; }
  .photo-prev.empty { display: grid; place-items: center; border: 1.5px dashed var(--line-strong); background: var(--card); color: var(--muted); font-size: 13px; }
  .photo-actions { display: flex; flex-direction: column; gap: 10px; align-items: flex-start; padding-top: 6px; }
  .ghost-btn { display: inline-flex; align-items: center; gap: 8px; height: 40px; padding: 0 18px; border-radius: 999px; background: transparent; border: 1px solid var(--line); color: var(--ink); font-size: 13.5px; font-weight: 600; transition: border-color 120ms ease, color 120ms ease; }
  .ghost-btn:hover { border-color: var(--line-strong); }
  .ghost-btn.danger { color: #e0533d; }
  .ghost-btn.danger:hover { border-color: rgba(224,83,61,0.4); }

  /* Ingredient sections */
  .ing-section { border: 1px solid var(--line-2); background: var(--card); border-radius: 18px; padding: 18px; margin-bottom: 14px; }
  .sec-head { display: flex; gap: 10px; align-items: center; margin-bottom: 12px; }
  .sec-name { flex: 1; min-width: 0; padding: 10px 14px; border-radius: 12px; border: 1px solid var(--line); background: var(--bg-2); color: var(--ink); font-family: var(--sans); font-size: 13px; font-weight: 700; letter-spacing: 0.4px; outline: none; transition: border-color 120ms ease; }
  .sec-name::placeholder { color: var(--muted); font-weight: 500; letter-spacing: 0; text-transform: none; }
  .sec-x { height: 36px; padding: 0 14px; font-size: 12.5px; flex-shrink: 0; }
  .ing-rows { display: flex; flex-direction: column; gap: 8px; }
  .ing-row { display: grid; grid-template-columns: 90px 90px 1fr 32px; gap: 8px; align-items: center; }
  .ing-row input { width: 100%; padding: 10px 12px; border-radius: 10px; border: 1px solid var(--line); background: var(--bg); color: var(--ink); font-family: var(--sans); font-size: 14px; outline: none; transition: border-color 120ms ease; }
  .ing-row input::placeholder { color: var(--muted); }
  .row-x { width: 32px; height: 32px; border-radius: 999px; border: 1px solid transparent; background: transparent; color: var(--muted); font-size: 12px; display: grid; place-items: center; padding: 0; flex-shrink: 0; transition: color 120ms ease, border-color 120ms ease; }
  .row-x:hover { color: #e0533d; border-color: rgba(224,83,61,0.35); }

  .add-btn { display: inline-flex; align-items: center; gap: 6px; height: 40px; padding: 0 18px; border-radius: 999px; border: 1.5px dashed var(--line-strong); background: transparent; color: var(--ink-2); font-size: 13.5px; font-weight: 600; transition: border-color 120ms ease, color 120ms ease; }
  .add-btn:hover { border-color: var(--solid); color: var(--ink); }
  .add-btn.small { height: 34px; padding: 0 14px; font-size: 12.5px; margin-top: 10px; }

  /* Method steps */
  .step-edit-list { list-style: none; margin: 0 0 4px; padding: 0; counter-reset: step; display: flex; flex-direction: column; gap: 10px; }
  .step-row { counter-increment: step; display: grid; grid-template-columns: 44px 1fr 32px; gap: 10px; align-items: start; }
  .step-row::before { content: counter(step, decimal-leading-zero); font-family: var(--serif); font-size: 28px; font-weight: 500; line-height: 1.3; letter-spacing: -0.02em; color: var(--muted); text-align: right; padding-top: 6px; }
