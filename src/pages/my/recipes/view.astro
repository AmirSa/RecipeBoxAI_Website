---
import BaseLayout from '@layouts/BaseLayout.astro';
import NavAccount from '@components/NavAccount.astro';
import ThemeToggle from '@components/ThemeToggle.astro';
import MobileNav from '@components/MobileNav.astro';
import ImportTray from '@components/ImportTray.astro';
---

<BaseLayout title="Recipe" description="View a recipe from your RecipeBox AI library.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,800&family=Inter+Tight:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <meta name="robots" content="noindex">

  <!-- ─── Nav ─── -->
  <nav class="rb-nav">
    <div class="container inner">
      <a class="brand" href="/">
        <img class="app-ico" src="/app-icon.png" alt="">
        RecipeBox AI
      </a>
      <ul>
        <li><a id="nav-primary" class="current" href="/my/recipes/">My Recipes</a></li>
        <li><a href="/my/cookbooks/">My Cookbooks</a></li>
        <li><a href="/recipes/">Discover</a></li>
      </ul>
      <div class="nav-actions">
        <NavAccount dest="/login/" />
        <ThemeToggle />
        <MobileNav />
      </div>
    </div>
  </nav>

  <ImportTray />

  <div class="container" id="app">
    <!-- skeleton while loading -->
    <div class="crumb"><a href="/my/recipes/">My Recipes</a><span class="sep">/</span><span class="sk-inline"></span></div>
    <section class="hero">
      <div class="hero-grid">
        <div>
          <div class="sk-line" style="width: 30%;"></div>
          <div class="sk-title"></div>
          <div class="sk-line" style="width: 80%;"></div>
          <div class="sk-line" style="width: 55%;"></div>
        </div>
        <div class="sk-img"></div>
      </div>
    </section>
  </div>

  <footer class="rb-footer">
    <div class="container row">
      <div class="brand">
        <img class="app-ico" src="/app-icon.png" alt="">
        RecipeBox AI
      </div>
      <div class="links">
        <a href="mailto:hello@recipeboxai.app">Support</a>
        <a href="/privacy/">Privacy</a>
        <a href="/terms/">Terms</a>
        <a href="https://twitter.com/RecipeBoxAI">Twitter</a>
      </div>
      <div class="copy">© 2026 RecipeBox AI</div>
    </div>
  </footer>

  <script>
    import {
      supabase, requireSession, escapeHtml, tagHex, setRecipeFavorite, deleteRecipe, getSaveGate,
      parseIngredientSections, parseInstructions, parseNutrition,
      type UserRecipeRow, type UserTagRow, type WireNutrition,
    } from '@/lib/account';
    import { submitTransform, waitForRecipe, waitForRecipeUpdate, findIngredientAlternatives, type TransformPayload, type IngredientAlternative } from '@/lib/ai';
    import { trackImport, removeImport, requestImportNotifications } from '@/lib/imports';

    const app = document.getElementById('app') as HTMLElement;
    let userId = '';

    // The apps' DietaryConversion presets, in AITransformView's grid order.
    const CONVERSIONS: { name: string; emoji: string }[] = [
      { name: 'Custom', emoji: '✍️' },
      { name: 'Healthy', emoji: '❤️' },
      { name: 'Vegetarian', emoji: '🥬' },
      { name: 'Vegan', emoji: '🌱' },
      { name: 'Pescatarian', emoji: '🐟' },
      { name: 'Gluten-Free', emoji: '🌾' },
      { name: 'Dairy-Free', emoji: '🥛' },
      { name: 'Low Carb', emoji: '🥦' },
      { name: 'High Protein', emoji: '💪' },
      { name: 'Paleo', emoji: '🍖' },
      { name: 'Keto', emoji: '🥑' },
      { name: 'Low Sodium', emoji: '🧂' },
      { name: 'Low Saturated Fat', emoji: '🫀' },
      { name: 'Less Microplastic', emoji: '♻️' },
      { name: 'High Fibre', emoji: '🌿' },
      { name: 'Kid-Friendly', emoji: '🧒' },
    ];

    const ICON = {
      heart: '<svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>',
      heartLine: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>',
      starFill: '<svg viewBox="0 0 24 24" fill="currentColor" width="15" height="15"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z"/></svg>',
      star: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" width="15" height="15"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z"/></svg>',
      link: '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>',
      check: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 7"/></svg>',
      dots: '<svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><circle cx="5" cy="12" r="1.8"/><circle cx="12" cy="12" r="1.8"/><circle cx="19" cy="12" r="1.8"/></svg>',
      trash: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><path d="M3 6h18"/><path d="M8 6V4a2 2 0 012-2h4a2 2 0 012 2v2"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/></svg>',
      wand: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><path d="M15 4V2"/><path d="M15 16v-2"/><path d="M8 9h2"/><path d="M20 9h2"/><path d="M17.8 11.8L19 13"/><path d="M15 9h.01"/><path d="M17.8 6.2L19 5"/><path d="M3 21l9-9"/><path d="M12.2 6.2L11 5"/></svg>',
      pencil: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><path d="M17 3a2.85 2.83 0 114 4L7.5 20.5 2 22l1.5-5.5z"/></svg>',
      swap: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><path d="M21 12a9 9 0 01-15.3 6.4M3 12a9 9 0 0115.3-6.4"/><path d="M21 3v6h-6"/><path d="M3 21v-6h6"/></svg>',
      copy: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>',
    };

    function showState(title: string, body: string, backLabel = 'Back to My Recipes') {
      app.innerHTML = `
        <div class="page-state">
          <h2>${escapeHtml(title)}</h2>
          <p>${escapeHtml(body)}</p>
          <a class="state-btn" href="/my/recipes/">${escapeHtml(backLabel)}</a>
        </div>`;
    }

    function formatDate(iso: string | null): string {
      if (!iso) return '';
      const d = new Date(iso);
      return isNaN(d.getTime()) ? '' : d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
    }

    function starsHtml(rating: number): string {
      return Array.from({ length: 5 }, (_, i) => (i < rating ? ICON.starFill : ICON.star)).join('');
    }

    // AI-transformed recipes carry an app-parity metadata block in notes
    // ("🤖 AI-Generated Recipe / Original Recipe: … / Original ID: <uuid>").
    // Render it human-friendly: hide the raw id lines and turn the original
    // recipe's title into a link to it instead.
    function overviewHtml(notes: string): string {
      let html = escapeHtml(notes);
      // The id can sit on its own line (the canonical block) or mid-sentence
      // (older transforms let the model paraphrase it into the notes).
      const idMatch = html.match(/Original ID:\s*([0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12})/i);
      html = html.replace(/\s*Original ID:\s*[0-9a-f-]{36}/gi, '');
      if (idMatch) {
        html = html.replace(
          /^(Original Recipe: )(.+)$/m,
          (_, prefix, title) => `${prefix}<a class="orig-link" href="/my/recipes/view/?id=${idMatch[1].toLowerCase()}">${title}</a>`,
        );
      }
      return html;
    }

    // Nutrition rows beyond the macro chart, in app display order.
    const NUTRIENT_LABELS: [keyof WireNutrition, string, string][] = [
      ['fiber', 'Fiber', 'g'],
      ['sugar', 'Sugar', 'g'],
      ['saturated_fat', 'Saturated fat', 'g'],
      ['cholesterol', 'Cholesterol', 'mg'],
      ['sodium', 'Sodium', 'mg'],
      ['potassium', 'Potassium', 'mg'],
      ['calcium', 'Calcium', 'mg'],
      ['iron', 'Iron', 'mg'],
      ['vitamin_a', 'Vitamin A', ''],
      ['vitamin_c', 'Vitamin C', 'mg'],
    ];

    function fmtAmount(v: number, unit: string): string {
      const rounded = Math.round(v * 10) / 10;
      const n = Number.isInteger(rounded) ? String(rounded) : rounded.toFixed(1);
      return unit ? `${n}${unit}` : n;
    }

    function render(recipe: UserRecipeRow, tags: UserTagRow[]) {
      const title = recipe.title || 'Untitled recipe';
      document.title = `${title} - RecipeBox AI`;

      const sections = parseIngredientSections(recipe.ingredient_sections);
      const steps = parseInstructions(recipe.instructions);
      const nutrition = parseNutrition(recipe.detailed_nutrition);

      const totalTime = recipe.total_time || (recipe.prep_time || 0) + (recipe.cook_time || 0);
      const cookLabel = totalTime <= 30 ? 'weeknight quick' : totalTime <= 60 ? 'easy dinner' : 'weekend project';

      const protein = Math.round(nutrition?.protein ?? 0);
      const carbs = Math.round(nutrition?.carbs ?? 0);
      const fat = Math.round(nutrition?.fat ?? 0);
      const totalMacros = protein + carbs + fat;
      const calFromMacros = protein * 4 + carbs * 4 + fat * 9;
      const pct = (g: number, kcal: number) => (calFromMacros > 0 ? Math.round((g * kcal / calFromMacros) * 100) : 0);
      const proteinPct = pct(protein, 4);
      const carbsPct = pct(carbs, 4);
      const fatPct = pct(fat, 9);

      const nutrientRows = NUTRIENT_LABELS
        .map(([key, label, unit]) => {
          const v = nutrition?.[key];
          return typeof v === 'number' && v > 0 ? { label, text: fmtAmount(v, unit) } : null;
        })
        .filter((r): r is { label: string; text: string } => !!r);

      const tagChips = tags.map((t) => {
        const hex = tagHex(t.color);
        return `<span class="tag" style="--tag-c:${hex};"><span class="sw" style="background:${hex};"></span>${escapeHtml(t.name)}</span>`;
      }).join('');

      const created = formatDate(recipe.created_at);
      // Only web sources get a link — original_url can hold app-internal
      // schemes (e.g. discover://…) that mean nothing in a browser.
      const sourceUrl = /^https?:\/\//i.test(recipe.original_url ?? '') ? recipe.original_url : null;
      const sourceHost = (() => {
        if (!sourceUrl) return null;
        try { return new URL(sourceUrl).hostname.replace(/^www\./, ''); } catch { return null; }
      })();

      app.innerHTML = `
        <div class="crumb">
          <a href="/my/recipes/">My Recipes</a>
          <span class="sep">/</span>
          <span style="color: var(--ink);">${escapeHtml(title)}</span>
        </div>

        <section class="hero">
          <div class="hero-grid">
            <div>
              ${tagChips ? `<div class="tags">${tagChips}</div>` : ''}
              <h1 class="display hero-h1">${escapeHtml(title)}</h1>
              <div class="meta-line">
                ${recipe.rating > 0 ? `<span class="stars">${starsHtml(recipe.rating)}</span>` : ''}
                <button class="fav-chip ${recipe.is_favorite ? 'on' : ''}" id="fav-btn" aria-pressed="${recipe.is_favorite}">${recipe.is_favorite ? ICON.heart : ICON.heartLine} Favorite</button>
                <button class="ai-chip" id="transform-btn">${ICON.wand} AI Transform</button>
                ${recipe.source_name ? `<span>From <b>${escapeHtml(recipe.source_name)}</b></span>` : ''}
                ${created ? `<span>Saved ${escapeHtml(created)}</span>` : ''}
                <div class="opt-wrap">
                  <button class="opt-btn" id="opt-btn" aria-haspopup="menu" aria-expanded="false" aria-label="Recipe options" title="Recipe options">${ICON.dots}</button>
                  <div class="opt-menu" id="opt-menu" role="menu" hidden>
                    <a class="opt-item" id="edit-btn" role="menuitem" href="/my/recipes/edit/?id=${encodeURIComponent(recipe.id)}">${ICON.pencil} Edit recipe</a>
                    <button class="opt-item danger" id="delete-btn" role="menuitem">${ICON.trash} Delete recipe</button>
                  </div>
                </div>
              </div>
              ${recipe.notes ? `<p class="overview">${overviewHtml(recipe.notes)}</p>` : ''}
            </div>
            <div class="hero-img-wrap">
              ${recipe.image_url
                ? `<img src="${escapeHtml(recipe.image_url)}" alt="${escapeHtml(title)}" onerror="this.parentElement.classList.add('ph');this.remove();">`
                : `<div class="ph-mark">${escapeHtml(title.slice(0, 1).toUpperCase())}</div>`}
            </div>
          </div>
        </section>

        <div class="stats">
          <div class="label-col">A ${totalTime}-minute<br><em>${escapeHtml(cookLabel)}</em></div>
          ${recipe.prep_time > 0 ? `<div class="stat"><div class="k">Prep</div><div class="v">${recipe.prep_time}<span class="u">min</span></div></div>` : ''}
          ${recipe.cook_time > 0 ? `<div class="stat"><div class="k">Cook</div><div class="v">${recipe.cook_time}<span class="u">min</span></div></div>` : ''}
          <div class="stat"><div class="k">Serves</div><div class="v">${recipe.servings || 1}</div></div>
          ${recipe.calories > 0 ? `<div class="stat"><div class="k">Per serving</div><div class="v">${recipe.calories}<span class="u">kcal</span></div></div>` : ''}
          <div class="cta-col">
            <a class="btn-secondary" href="/my/recipes/">← Back to library</a>
          </div>
        </div>

        <div class="body-layout">
          <aside class="side">
            ${totalMacros > 0 ? `
              <div class="card-base">
                <h3>Macros · per serving</h3>
                <div class="macro-total">
                  <div class="big">${totalMacros}<span style="font-size:14px; color:var(--muted);">g</span></div>
                  <div class="small">total macronutrients</div>
                </div>
                <div class="macro-bar">
                  <div class="seg-p" style="width:${proteinPct}%;"></div>
                  <div class="seg-c" style="width:${carbsPct}%;"></div>
                  <div class="seg-f" style="width:${fatPct}%;"></div>
                </div>
                <div class="macro-list">
                  <div class="macro-row"><div class="lhs"><span class="dot p"></span>Protein</div><div><span class="v">${protein}g</span><span class="pct">${proteinPct}%</span></div></div>
                  <div class="macro-row"><div class="lhs"><span class="dot c"></span>Carbs</div><div><span class="v">${carbs}g</span><span class="pct">${carbsPct}%</span></div></div>
                  <div class="macro-row"><div class="lhs"><span class="dot f"></span>Fat</div><div><span class="v">${fat}g</span><span class="pct">${fatPct}%</span></div></div>
                </div>
              </div>` : ''}

            ${nutrientRows.length > 0 ? `
              <div class="card-base">
                <h3>Nutrition · per serving</h3>
                <div class="nutr-list">
                  ${nutrientRows.map((n, i) => `
                    <div class="nutr-row"><span class="name">${escapeHtml(n.label)}</span><span class="dv">${escapeHtml(n.text)}</span></div>
                    ${i < nutrientRows.length - 1 ? '<hr class="nutr-divider">' : ''}`).join('')}
                </div>
              </div>` : ''}

            ${sourceUrl ? `
              <div class="card-base">
                <h3>Source</h3>
                <a class="source-link" href="${escapeHtml(sourceUrl)}" target="_blank" rel="noopener noreferrer">
                  ${ICON.link}
                  <span>${escapeHtml(recipe.source_name || sourceHost || 'Original recipe')}</span>
                </a>
              </div>` : ''}

            <div class="cta-card">
              <h3>Cook it from your phone</h3>
              <p>This recipe lives in your RecipeBox — open the app for cooking mode, AI transformations, and grocery lists.</p>
              <a class="btn" href="https://apps.apple.com/gb/app/recipebox-ai/id6752560797">Open RecipeBox AI</a>
            </div>
          </aside>

          <main class="recipe-main">
            ${sections.length > 0 ? `
              <div class="section">
                <h2>Ingredients</h2>
                <div class="servings-bar" id="servings-bar">
                  <button data-step="-1" aria-label="Fewer servings">−</button>
                  <div class="num"><span id="servings-num">${recipe.servings || 1}</span><span> servings</span></div>
                  <button data-step="1" aria-label="More servings">+</button>
                </div>
                ${sections.map((section, sIdx) => `
                  ${section.header ? `<div class="group-head">${escapeHtml(section.header)}</div>` : ''}
                  <ul class="ing-list">
                    ${section.ingredients.map((ing, iIdx) => {
                      const amountNum = parseFloat(String(ing.amount ?? ''));
                      const isNumeric = !isNaN(amountNum) && amountNum > 0;
                      const extra = ing.additionalInfo ? `, ${ing.additionalInfo}` : '';
                      return `
                        <li>
                          <button class="check" data-check="s${sIdx}-i${iIdx}" aria-label="Mark ingredient">${ICON.check}</button>
                          <span class="qty" data-base-amount="${isNumeric ? amountNum : ''}" data-unit="${escapeHtml(ing.unit ?? '')}">${isNumeric ? `${amountNum}${ing.unit ? ' ' + escapeHtml(ing.unit) : ''}` : escapeHtml(ing.amount ?? '')}</span>
                          <span class="name">${escapeHtml(ing.name)}${escapeHtml(extra)}</span>
                          <button class="swap" data-ing="${escapeHtml(ing.name)}" aria-label="Find alternatives for ${escapeHtml(ing.name)}" title="Find alternatives">${ICON.swap}</button>
                        </li>`;
                    }).join('')}
                  </ul>`).join('')}
              </div>` : ''}

            ${steps.length > 0 ? `
              <div class="section">
                <h2>Method</h2>
                <ol class="step-list" id="step-list">
                  ${steps.map((s, i) => `
                    <li>
                      <div class="n">${String(i + 1).padStart(2, '0')}</div>
                      <div class="txt">${escapeHtml(s)}</div>
                    </li>`).join('')}
                </ol>
              </div>` : ''}

            ${sections.length === 0 && steps.length === 0 ? `
              <div class="page-state" style="padding: 56px 28px;">
                <h2>No details yet</h2>
                <p>This recipe doesn't have ingredients or steps stored. Open it in the app to add them.</p>
              </div>` : ''}
          </main>
        </div>

        <div class="tx-overlay" id="tx-overlay" hidden>
          <div class="tx-modal" role="dialog" aria-modal="true" aria-labelledby="tx-title">
            <button class="tx-close" id="tx-close" aria-label="Close">✕</button>
            <div id="tx-config">
              <h3 class="tx-h" id="tx-title">Transform Recipe</h3>
              <p class="tx-sub">Convert “${escapeHtml(title)}” to a different dietary style — or describe your own changes.</p>
              <div class="tx-grid">
                ${CONVERSIONS.map((c) => `<button class="tx-preset${c.name === 'Custom' ? ' custom' : ''}" data-conversion="${escapeHtml(c.name)}"><span class="em">${c.emoji}</span>${escapeHtml(c.name)}</button>`).join('')}
              </div>
              <textarea class="tx-custom" id="tx-custom" rows="3" hidden placeholder="e.g. Make it spicier, double the servings, use only pantry staples… You can combine several changes at once."></textarea>
              <div class="tx-options">
                <label class="tx-opt"><input type="radio" name="tx-target" value="new" checked> Save as a new recipe</label>
                <label class="tx-opt"><input type="radio" name="tx-target" value="replace"> Replace this recipe</label>
              </div>
              <p class="tx-gate" id="tx-gate" hidden></p>
              <button class="tx-go" id="tx-go" disabled>${ICON.wand} Transform Recipe</button>
            </div>
          </div>
        </div>

        <div class="tx-overlay" id="alt-overlay" hidden>
          <div class="tx-modal alt-modal" role="dialog" aria-modal="true" aria-labelledby="alt-title">
            <button class="tx-close" id="alt-close" aria-label="Close">✕</button>
            <p class="alt-kicker">Alternatives for</p>
            <h3 class="tx-h" id="alt-title"></h3>
            <div class="alt-body" id="alt-body"></div>
          </div>
        </div>`;

      wireInteractions(recipe.servings || 1);
      wireFavorite(recipe);
      wireOptions(recipe);
      wireTransform(recipe);
      wireAlternatives();
    }

    // Ingredient alternatives — the apps' per-ingredient swap feature
    // (RecipeDetailView.findAlternatives → IngredientAlternativesSheet): tap
    // the swap icon, get 5 AI substitutes with the healthier ones highlighted,
    // tap a row to copy it.
    function wireAlternatives() {
      const overlay = document.getElementById('alt-overlay') as HTMLElement;
      const titleEl = document.getElementById('alt-title') as HTMLElement;
      const body = document.getElementById('alt-body') as HTMLElement;
      const closeBtn = document.getElementById('alt-close');
      if (!overlay || !titleEl || !body) return;

      const setOpen = (open: boolean) => {
        overlay.hidden = !open;
        document.body.style.overflow = open ? 'hidden' : '';
      };
      closeBtn?.addEventListener('click', () => setOpen(false));
      overlay.addEventListener('click', (e) => { if (e.target === overlay) setOpen(false); });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !overlay.hidden) setOpen(false); });

      function renderList(alternatives: IngredientAlternative[]) {
        if (alternatives.length === 0) {
          body.innerHTML = `
            <div class="alt-state">
              <h4>No alternatives found</h4>
              <p>We couldn't find any suitable alternatives for this ingredient.</p>
            </div>`;
          return;
        }
        body.innerHTML = `
          <ul class="alt-list">
            ${alternatives.map((a, i) => `
              <li class="alt-row" data-copy="${escapeHtml(a.name)}" title="Copy to clipboard">
                <span class="n">${i + 1}</span>
                <span class="alt-name">${escapeHtml(a.name)}</span>
                ${a.isHealthier ? '<span class="healthy-pill">Healthy</span>' : ''}
                <span class="copy-ico">${ICON.copy}</span>
              </li>`).join('')}
          </ul>
          <p class="alt-hint">Tap an alternative to copy it.</p>`;

        body.querySelectorAll<HTMLElement>('.alt-row').forEach((row) => {
          row.addEventListener('click', async () => {
            try {
              await navigator.clipboard.writeText(row.dataset.copy!);
              row.classList.add('copied');
              setTimeout(() => row.classList.remove('copied'), 1200);
            } catch { /* clipboard unavailable — nothing useful to do */ }
          });
        });
      }

      async function fetchAlternatives(name: string) {
        body.innerHTML = `
          <div class="alt-state">
            <div class="alt-spinner" role="status" aria-label="Loading"></div>
            <p>Finding alternatives…</p>
          </div>`;
        try {
          renderList(await findIngredientAlternatives(name));
        } catch (err) {
          body.innerHTML = `
            <div class="alt-state">
              <h4>Unable to find alternatives</h4>
              <p>${escapeHtml(err instanceof Error ? err.message : 'Please try again.')}</p>
              <button class="alt-retry" id="alt-retry">Retry</button>
            </div>`;
          document.getElementById('alt-retry')?.addEventListener('click', () => fetchAlternatives(name));
        }
      }

      document.querySelectorAll<HTMLButtonElement>('.ing-list .swap').forEach((btn) => {
        btn.addEventListener('click', () => {
          const name = btn.dataset.ing || '';
          if (!name) return;
          titleEl.textContent = name;
          setOpen(true);
          fetchAlternatives(name);
        });
      });
    }

    // AI Transform — the apps' AITransformView flow, adapted to the imports'
    // server-side contract: submit → 202 → poll `recipes` for completion.
    function wireTransform(recipe: UserRecipeRow) {
      const overlay = document.getElementById('tx-overlay') as HTMLElement;
      const openBtn = document.getElementById('transform-btn');
      const closeBtn = document.getElementById('tx-close');
      const custom = document.getElementById('tx-custom') as HTMLTextAreaElement;
      const gateEl = document.getElementById('tx-gate') as HTMLElement;
      const go = document.getElementById('tx-go') as HTMLButtonElement;
      if (!overlay || !openBtn || !go) return;

      let selected: string | null = null;

      const target = (): 'new' | 'replace' =>
        (document.querySelector('input[name="tx-target"]:checked') as HTMLInputElement)?.value === 'replace' ? 'replace' : 'new';
      const refreshGo = () => {
        go.disabled = !selected || (selected === 'Custom' && !custom.value.trim());
      };
      const setOpen = (open: boolean) => {
        overlay.hidden = !open;
        document.body.style.overflow = open ? 'hidden' : '';
      };

      openBtn.addEventListener('click', () => setOpen(true));
      closeBtn?.addEventListener('click', () => setOpen(false));
      overlay.addEventListener('click', (e) => { if (e.target === overlay) setOpen(false); });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !overlay.hidden) setOpen(false); });

      document.querySelectorAll<HTMLButtonElement>('.tx-preset').forEach((btn) => {
        btn.addEventListener('click', () => {
          selected = btn.dataset.conversion!;
          document.querySelectorAll('.tx-preset').forEach((b) => b.classList.toggle('on', b === btn));
          custom.hidden = selected !== 'Custom';
          if (!custom.hidden) custom.focus();
          refreshGo();
        });
      });
      custom.addEventListener('input', refreshGo);
      document.querySelectorAll<HTMLInputElement>('input[name="tx-target"]').forEach((r) => {
        r.addEventListener('change', () => { gateEl.hidden = true; });
      });

      go.addEventListener('click', async () => {
        if (!selected) return;

        // Free-tier gate only applies when adding a recipe (like the apps:
        // "Replace Original" never counts against the library limit).
        if (target() === 'new') {
          go.disabled = true;
          try {
            const gate = await getSaveGate(userId);
            if (!gate.allowed) {
              gateEl.textContent = `Your free library is full (${gate.used}/${gate.limit} recipes). Delete a recipe, upgrade to Pro in the app, or choose “Replace this recipe”.`;
              gateEl.hidden = false;
              refreshGo();
              return;
            }
          } catch { /* best-effort gate — don't block on a profile hiccup */ }
        }

        // Same background contract as imports, with zero waiting UI: mint the
        // result id HERE (the function honors it, like import-recipe's photo
        // flow), register it in the bell tray, and close the modal instantly.
        // The submit itself runs in the background; if the server rejects it,
        // the tray entry is rolled back and the modal reopens with the error.
        // A transformed dish looks different — always generate a fresh AI
        // cover, for replacements too (Amir, 2026-07-12).
        const mode = target();
        const targetId = mode === 'new' ? crypto.randomUUID() : recipe.id;
        const payload: TransformPayload & { id?: string } = selected === 'Custom'
          ? { recipeId: recipe.id, conversion: 'Custom', customPrompt: custom.value.trim(), target: mode, generateImage: true }
          : { recipeId: recipe.id, conversion: selected, target: mode, generateImage: true };
        if (mode === 'new') payload.id = targetId;

        requestImportNotifications();
        trackImport({
          id: targetId,
          label: selected === 'Custom' ? 'Custom' : selected!,
          kind: 'transform',
          mode,
        });
        setOpen(false);
        refreshGo();

        try {
          await submitTransform(payload);
          // Accepted (202) — the tray owns tracking now. If the user stays on
          // this page, redirect/reload when the transform lands (mirror of
          // the add page's runImport).
          const ok = mode === 'new'
            ? await waitForRecipe(targetId)
            : await waitForRecipeUpdate(recipe.id, recipe.updated_at);
          if (ok) {
            removeImport(targetId);
            if (mode === 'new') window.location.href = `/my/recipes/view/?id=${targetId}`;
            else window.location.reload();
          }
          // On timeout do nothing — the tray keeps tracking it.
        } catch (err) {
          removeImport(targetId);
          setOpen(true);
          alert('Could not start the transformation: ' + (err instanceof Error ? err.message : 'please try again'));
        }
      });
    }

    // Options (⋯) menu — "Edit recipe" (a plain link to the edit page) and
    // "Delete recipe". The delete is the same hard-DELETE the apps do: the
    // server records a tombstone, so the recipe disappears from every device
    // on its next sync.
    function wireOptions(recipe: UserRecipeRow) {
      const btn = document.getElementById('opt-btn');
      const menu = document.getElementById('opt-menu');
      const del = document.getElementById('delete-btn') as HTMLButtonElement | null;
      if (!btn || !menu || !del) return;

      const setOpen = (open: boolean) => {
        menu.hidden = !open;
        btn.setAttribute('aria-expanded', String(open));
      };
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        setOpen(menu.hidden);
      });
      document.addEventListener('click', (e) => {
        if (!menu.hidden && !menu.contains(e.target as Node)) setOpen(false);
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') setOpen(false);
      });

      del.addEventListener('click', async () => {
        const title = recipe.title || 'this recipe';
        if (!confirm(`Delete "${title}"?\n\nIt will be removed from your library on all your devices. This can't be undone.`)) {
          setOpen(false);
          return;
        }
        del.disabled = true;
        del.innerHTML = 'Deleting…';
        try {
          await deleteRecipe(recipe.id);
          window.location.href = '/my/recipes/';
        } catch (err) {
          del.disabled = false;
          del.innerHTML = `${ICON.trash} Delete recipe`;
          setOpen(false);
          alert('Could not delete recipe: ' + (err instanceof Error ? err.message : 'try again'));
        }
      });
    }

    // Optimistic favorite toggle (same contract as the apps' small mutations):
    // flip the chip immediately, push to Supabase, revert + alert on failure.
    function wireFavorite(recipe: UserRecipeRow) {
      const btn = document.getElementById('fav-btn');
      if (!btn) return;
      let busy = false;
      const paint = () => {
        btn.classList.toggle('on', recipe.is_favorite);
        btn.setAttribute('aria-pressed', String(recipe.is_favorite));
        btn.setAttribute('title', recipe.is_favorite ? 'Remove from favorites' : 'Add to favorites');
        btn.innerHTML = `${recipe.is_favorite ? ICON.heart : ICON.heartLine} Favorite`;
      };
      paint();
      btn.addEventListener('click', async () => {
        if (busy) return;
        busy = true;
        recipe.is_favorite = !recipe.is_favorite;
        paint();
        try {
          await setRecipeFavorite(recipe.id, recipe.is_favorite);
        } catch (err) {
          recipe.is_favorite = !recipe.is_favorite;
          paint();
          alert('Could not update favorite: ' + (err instanceof Error ? err.message : 'try again'));
        } finally {
          busy = false;
        }
      });
    }

    function wireInteractions(baseServings: number) {
      const numEl = document.getElementById('servings-num');
      const bar = document.getElementById('servings-bar');
      let current = baseServings;

      function format(n: number): string {
        const rounded = Math.round(n * 100) / 100;
        return Number.isInteger(rounded) ? String(rounded) : rounded.toFixed(2).replace(/0+$/, '').replace(/\.$/, '');
      }

      bar?.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('button[data-step]') as HTMLElement | null;
        if (!btn || !numEl) return;
        current = Math.max(1, current + parseInt(btn.dataset.step!, 10));
        numEl.textContent = String(current);
        const scale = current / baseServings;
        document.querySelectorAll<HTMLElement>('.qty').forEach((el) => {
          const base = parseFloat(el.dataset.baseAmount || '');
          if (!isNaN(base) && base > 0) {
            const unit = el.dataset.unit || '';
            el.textContent = format(base * scale) + (unit ? ' ' + unit : '');
          }
        });
      });

      document.querySelectorAll('[data-check]').forEach((btn) => {
        btn.addEventListener('click', () => {
          btn.classList.toggle('on');
          btn.closest('li')?.classList.toggle('done');
        });
      });

      document.querySelectorAll('#step-list li').forEach((li) => {
        li.addEventListener('click', () => li.classList.toggle('done'));
        (li as HTMLElement).style.cursor = 'pointer';
      });
    }

    async function load() {
      const session = await requireSession();
      if (!session) return;
      userId = session.user.id;

      const id = new URLSearchParams(window.location.search).get('id');
      if (!id) {
        showState('Recipe not found', 'This link is missing a recipe id.');
        return;
      }

      const { data, error } = await supabase
        .from('recipes')
        .select('*, recipe_tags(tag_id)')
        .eq('id', id)
        .is('deleted_at', null)
        .maybeSingle();

      if (error) {
        showState("Couldn't load this recipe", error.message);
        return;
      }
      if (!data) {
        showState('Recipe not found', "This recipe doesn't exist in your library — it may have been deleted on another device.");
        return;
      }

      const recipe = data as unknown as UserRecipeRow;
      const tagIds = (recipe.recipe_tags ?? []).map((t) => t.tag_id);
      let tags: UserTagRow[] = [];
      if (tagIds.length > 0) {
        const { data: tagRows } = await supabase
          .from('tags')
          .select('id, name, color')
          .in('id', tagIds)
          .is('deleted_at', null);
        tags = (tagRows ?? []) as UserTagRow[];
      }

      render(recipe, tags);
    }

    load().catch((err) => showState('Something went wrong', err instanceof Error ? err.message : 'Please try again.'));
  </script>
</BaseLayout>

