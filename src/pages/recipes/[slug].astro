---
import BaseLayout from '@layouts/BaseLayout.astro';
import NavAccount from '@components/NavAccount.astro';
import ThemeToggle from '@components/ThemeToggle.astro';
import MobileNav from '@components/MobileNav.astro';
import ImportTray from '@components/ImportTray.astro';
import { fetchAllPublishedRecipes, type SharedRecipe } from '../../lib/supabase';

export async function getStaticPaths() {
  const allRecipes = await fetchAllPublishedRecipes<SharedRecipe & Record<string, any>>('*');

  return allRecipes.map((recipe) => {
    const recipeTags = [...Object.values(recipe.tags || {}), ...(recipe.auto_tags || [])].map((t: string) => t.toLowerCase());

    let relatedRecipes = allRecipes
      .filter((r) => r.slug !== recipe.slug)
      .map((r) => {
        const rTags = [...Object.values(r.tags || {}), ...(r.auto_tags || [])].map((t: string) => t.toLowerCase());
        const matchCount = recipeTags.filter((t) => rTags.includes(t)).length;
        return { ...r, matchCount };
      })
      .sort((a, b) => b.matchCount - a.matchCount)
      .slice(0, 8);

    if (relatedRecipes.length < 4) {
      const others = allRecipes
        .filter((r) => r.slug !== recipe.slug && !relatedRecipes.find((rel) => rel.slug === r.slug))
        .sort(() => Math.random() - 0.5)
        .slice(0, 4 - relatedRecipes.length);
      relatedRecipes = [...relatedRecipes, ...others];
    }

    return {
      params: { slug: recipe.slug },
      props: { recipe, relatedRecipes },
    };
  });
}

interface Props {
  recipe: SharedRecipe;
  relatedRecipes: SharedRecipe[];
}

const { recipe, relatedRecipes } = Astro.props;
const slug = recipe.slug;

// ── Tags ──
const cuisine = recipe.tags?.cuisine || '';
const diet = recipe.tags?.diet || '';
const mealType = recipe.tags?.mealType || '';
const tagValues = Object.values(recipe.tags || {}).filter(Boolean) as string[];
const allTags = [...tagValues, ...(recipe.auto_tags || [])].filter(Boolean).slice(0, 6);

// ── Macros (with percent of calories) ──
const protein = recipe.nutrition?.protein || 0;
const carbs   = recipe.nutrition?.carbs   || 0;
const fat     = recipe.nutrition?.fat     || 0;
const totalMacros = protein + carbs + fat;
const calFromMacros = protein * 4 + carbs * 4 + fat * 9;
const pct = (g: number, kcalPerG: number) =>
  calFromMacros > 0 ? Math.round((g * kcalPerG / calFromMacros) * 100) : 0;
const proteinPct = pct(protein, 4);
const carbsPct   = pct(carbs,   4);
const fatPct     = pct(fat,     9);
const hasMacros = totalMacros > 0;

// ── Ingredients flat list (for schema.org) ──
const ingredientsFlat = (recipe.sections || []).flatMap((section) =>
  (section.ingredients || []).map((ing) => ({
    amount: [ing.amount, ing.unit].filter(Boolean).join(' '),
    name: ing.name,
    note: ing.preparation || '',
  }))
);

// ── Instructions ──
const instructions = (recipe.instructions || [])
  .map((inst) => inst.instruction || (inst as { text?: string }).text || '')
  .filter(Boolean);

// ── Schema.org ──
const datePublished = recipe.created_at ? recipe.created_at.split('T')[0] : new Date().toISOString().split('T')[0];
const category = mealType || 'Main Dish';
const keywords = allTags.join(', ');

// ── Hero image ──
const heroImage = recipe.image_url || '/images/recipe-placeholder.jpg';

// ── Stats label ──
const totalTime = (recipe.prep_time || 0) + (recipe.cook_time || 0);
const cookLabel = totalTime <= 30 ? 'weeknight quick' : totalTime <= 60 ? 'an hour-long bake' : 'a weekend bake';

// ── Rich nutrients ──
const richNutrients = recipe.nutrition?.richNutrients || [];

// ── Payload for the client-side "Save to library" flow ──
const saveData = {
  slug,
  title: recipe.title,
  notes: recipe.notes || recipe.description || null,
  prep_time: recipe.prep_time || 0,
  cook_time: recipe.cook_time || 0,
  servings: recipe.servings || 4,
  calories: recipe.calories || 0,
  image_url: recipe.image_url || null,
  sections: recipe.sections || [],
  instructions: recipe.instructions || [],
  nutrition: recipe.nutrition || null,
};
const saveDataJson = JSON.stringify(saveData).replace(/</g, '\\u003c');
---

<BaseLayout
  title={recipe.title}
  description={recipe.description || `${recipe.title} — structured by RecipeBox AI`}
  image={heroImage}
>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,800&family=Inter+Tight:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <!-- Schema.org BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://recipeboxai.app/' },
      { '@type': 'ListItem', position: 2, name: 'Recipes', item: 'https://recipeboxai.app/recipes/' },
      { '@type': 'ListItem', position: 3, name: recipe.title, item: `https://recipeboxai.app/recipes/${slug}/` },
    ],
  })} />

  <!-- Schema.org Recipe -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Recipe',
    name: recipe.title,
    description: recipe.description || '',
    image: [heroImage],
    author: { '@type': 'Organization', name: 'RecipeBox AI', url: 'https://recipeboxai.app' },
    publisher: {
      '@type': 'Organization', name: 'RecipeBox AI',
      logo: { '@type': 'ImageObject', url: 'https://recipeboxai.app/app-icon.png' },
    },
    datePublished,
    prepTime: `PT${recipe.prep_time}M`,
    cookTime: `PT${recipe.cook_time}M`,
    totalTime: `PT${totalTime}M`,
    recipeYield: `${recipe.servings} servings`,
    recipeCategory: category,
    recipeCuisine: cuisine || null,
    keywords,
    nutrition: recipe.nutrition ? {
      '@type': 'NutritionInformation',
      calories: `${recipe.calories} calories`,
      proteinContent: protein ? `${protein}g` : undefined,
      fatContent: fat ? `${fat}g` : undefined,
      carbohydrateContent: carbs ? `${carbs}g` : undefined,
    } : undefined,
    recipeIngredient: ingredientsFlat.map((i) =>
      `${i.amount || ''} ${i.name}${i.note ? ` (${i.note})` : ''}`.trim()
    ),
    recipeInstructions: instructions.map((text, index) => ({
      '@type': 'HowToStep',
      name: `Step ${index + 1}`,
      text,
      url: `https://recipeboxai.app/recipes/${slug}/#step-${index + 1}`,
      image: heroImage,
    })),
  })} />

  <!-- ─── Nav ─── -->
  <nav class="rb-nav">
    <div class="container inner">
      <a class="brand" href="/">
        <img class="app-ico" src="/app-icon.png" alt="">
        RecipeBox AI
      </a>
      <ul>
        <li><a id="nav-primary" href="/">Home</a></li>
        <li><a href="/my/cookbooks/">My Cookbooks</a></li>
        <li><a class="current" href="/recipes/">Discover</a></li>
      </ul>
      <div class="nav-actions">
        <a class="download" id="nav-download" href="https://apps.apple.com/gb/app/recipebox-ai/id6752560797">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.06 13.28c-.02-2.45 2-3.62 2.09-3.68-1.14-1.67-2.91-1.9-3.54-1.93-1.51-.15-2.94.89-3.71.89-.78 0-1.96-.86-3.22-.84-1.66.02-3.19.96-4.04 2.45-1.72 2.98-.44 7.4 1.24 9.82.82 1.18 1.8 2.52 3.06 2.47 1.23-.05 1.7-.8 3.19-.8 1.48 0 1.9.8 3.2.78 1.32-.02 2.15-1.2 2.96-2.39.93-1.37 1.32-2.71 1.34-2.78-.03-.01-2.57-.98-2.59-3.89zM14.6 6.06c.67-.81 1.13-1.94.99-3.06-.97.04-2.13.65-2.83 1.45-.62.71-1.18 1.86-1.03 2.96 1.09.09 2.2-.55 2.87-1.35z"/></svg>
          Download
        </a>
        <NavAccount />
        <ThemeToggle />
        <MobileNav />
      </div>
    </div>
  </nav>

  <ImportTray />

  <div class="container">
    <div class="crumb">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <a href="/recipes/">Discover</a>
      {cuisine && (
        <>
          <span class="sep">/</span>
          <span style="color: var(--ink);">{cuisine}</span>
        </>
      )}
    </div>

    <!-- ─── Hero ─── -->
    <section class="hero">
      <div class="hero-grid">
        <div>
          <div class="tags">
            {diet && diet !== 'Standard' && (
              <span class={`tag ${diet.toLowerCase() === 'vegetarian' || diet.toLowerCase() === 'vegan' ? 'veg' : ''}`}>{diet}</span>
            )}
            {allTags.filter((t) => t !== diet).slice(0, 5).map((t) => (
              <span class="tag">{t}</span>
            ))}
          </div>
          <h1 class="display hero-h1">{recipe.title}</h1>
          {recipe.description && <p class="overview">{recipe.description}</p>}
          <div class="author">
            <div class="av">AI</div>
            <span>Structured by <b>RecipeBox AI</b> · ready to import</span>
          </div>
        </div>
        <div class="hero-img-wrap">
          <img src={heroImage} alt={recipe.title} onerror="this.src='/app-icon.png';this.style.objectFit='contain';this.style.padding='25%';this.style.background='var(--bg-2)';">
        </div>
      </div>
    </section>

    <!-- ─── Stats strip ─── -->
    <div class="stats">
      <div class="label-col">A {totalTime}-minute<br><em>{cookLabel}</em></div>
      {recipe.prep_time > 0 && <div class="stat"><div class="k">Prep</div><div class="v">{recipe.prep_time}<span class="u">min</span></div></div>}
      {recipe.cook_time > 0 && <div class="stat"><div class="k">Cook</div><div class="v">{recipe.cook_time}<span class="u">min</span></div></div>}
      <div class="stat"><div class="k">Serves</div><div class="v">{recipe.servings}</div></div>
      {recipe.calories > 0 && <div class="stat"><div class="k">Per serving</div><div class="v">{recipe.calories}<span class="u">kcal</span></div></div>}
      <div class="cta-col">
        <button class="btn-primary" id="add-to-recipebox-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5v14"/></svg>
          Save to library
        </button>
      </div>
    </div>

    <!-- ─── Body two-column ─── -->
    <div class="body-layout">

      <aside class="side">
        {hasMacros && (
          <div class="card-base">
            <h3>Macros · per serving</h3>
            <div class="macro-total">
              <div class="big">{totalMacros}<span style="font-size:14px; color:var(--muted);">g</span></div>
              <div class="small">total macronutrients</div>
            </div>
            <div class="macro-bar">
              <div class="seg-p" style={`width:${proteinPct}%;`}></div>
              <div class="seg-c" style={`width:${carbsPct}%;`}></div>
              <div class="seg-f" style={`width:${fatPct}%;`}></div>
            </div>
            <div class="macro-list">
              <div class="macro-row">
                <div class="lhs"><span class="dot p"></span>Protein</div>
                <div><span class="v">{protein}g</span><span class="pct">{proteinPct}%</span></div>
              </div>
              <div class="macro-row">
                <div class="lhs"><span class="dot c"></span>Carbs</div>
                <div><span class="v">{carbs}g</span><span class="pct">{carbsPct}%</span></div>
              </div>
              <div class="macro-row">
                <div class="lhs"><span class="dot f"></span>Fat</div>
                <div><span class="v">{fat}g</span><span class="pct">{fatPct}%</span></div>
              </div>
            </div>
          </div>
        )}

        {richNutrients.length > 0 && (
          <div class="card-base">
            <h3>Rich in</h3>
            <div class="nutr-list">
              {richNutrients.slice(0, 5).map((n, i) => (
                <>
                  <div class="nutr-row">
                    <span class="name">{n.name}</span>
                    <span class="dv">{n.amount}</span>
                    {n.description && <span class="desc">{n.description}</span>}
                  </div>
                  {i < Math.min(richNutrients.length, 5) - 1 && <hr class="nutr-divider">}
                </>
              ))}
            </div>
          </div>
        )}

        <div class="cta-card">
          <h3>Save this to your library</h3>
          <p>One tap imports the full recipe — ingredients, steps, macros — straight into your RecipeBox.</p>
          <a class="btn" href="https://apps.apple.com/gb/app/recipebox-ai/id6752560797">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.06 13.28c-.02-2.45 2-3.62 2.09-3.68-1.14-1.67-2.91-1.9-3.54-1.93-1.51-.15-2.94.89-3.71.89-.78 0-1.96-.86-3.22-.84-1.66.02-3.19.96-4.04 2.45-1.72 2.98-.44 7.4 1.24 9.82.82 1.18 1.8 2.52 3.06 2.47 1.23-.05 1.7-.8 3.19-.8 1.48 0 1.9.8 3.2.78 1.32-.02 2.15-1.2 2.96-2.39.93-1.37 1.32-2.71 1.34-2.78-.03-.01-2.57-.98-2.59-3.89zM14.6 6.06c.67-.81 1.13-1.94.99-3.06-.97.04-2.13.65-2.83 1.45-.62.71-1.18 1.86-1.03 2.96 1.09.09 2.2-.55 2.87-1.35z"/></svg>
            Get the app
          </a>
        </div>
      </aside>

      <main class="recipe-main">

        <!-- Ingredients -->
        <div class="section">
          <h2>Ingredients</h2>
          <div class="servings-bar" id="servings-bar">
            <button data-step="-1" aria-label="Fewer servings">−</button>
            <div class="num"><span id="servings-num">{recipe.servings}</span><span> servings</span></div>
            <button data-step="1" aria-label="More servings">+</button>
          </div>

          {(recipe.sections || []).map((section, sIdx) => (
            <>
              {section.title && <div class="group-head">{section.title}</div>}
              <ul class="ing-list">
                {(section.ingredients || []).map((ing, iIdx) => {
                  const key = `s${sIdx}-i${iIdx}`;
                  const amountNum = parseFloat(String(ing.amount || ''));
                  const isNumeric = !isNaN(amountNum) && amountNum > 0;
                  return (
                    <li data-key={key}>
                      <button class="check" data-check={key} aria-label="Mark ingredient">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 7"/></svg>
                      </button>
                      <span
                        class="qty"
                        data-base-amount={isNumeric ? amountNum : ''}
                        data-unit={ing.unit || ''}
                        data-raw={!isNumeric ? (ing.amount || '') : ''}
                      >
                        {isNumeric ? `${amountNum}${ing.unit ? ' ' + ing.unit : ''}` : (ing.amount || '')}
                      </span>
                      <span class="name">{ing.name}{ing.preparation ? `, ${ing.preparation}` : ''}</span>
                    </li>
                  );
                })}
              </ul>
            </>
          ))}
        </div>

        <!-- Transform card -->
        <div class="transform-card">
          <div class="eyebrow" style="color: #b13fe8;">AI Transformation</div>
          <h3 style="font-family: var(--serif); font-size: 28px; font-weight: 500; letter-spacing: -0.02em; margin: 8px 0 0; line-height: 1.05;">Make this recipe yours.</h3>
          <p style="margin: 8px 0 18px; font-size: 14.5px; color: var(--ink-2); max-width: 60ch;">
            Don't eat dairy? Want more protein? Cooking for kids? Tap any option in the app and the AI rewrites the ingredients and rebalances the macros.
          </p>
          <div class="chips">
            <span class="chip"><span class="swatch"></span>Vegan</span>
            <span class="chip"><span class="swatch"></span>Vegetarian</span>
            <span class="chip"><span class="swatch"></span>High protein</span>
            <span class="chip"><span class="swatch"></span>Lower calorie</span>
            <span class="chip"><span class="swatch"></span>Kid-friendly</span>
            <span class="chip"><span class="swatch"></span>Gluten-free</span>
            <span class="chip"><span class="swatch"></span>Dairy-free</span>
          </div>
          <div class="download-row">
            <a class="download-btn" href="https://apps.apple.com/gb/app/recipebox-ai/id6752560797">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.06 13.28c-.02-2.45 2-3.62 2.09-3.68-1.14-1.67-2.91-1.9-3.54-1.93-1.51-.15-2.94.89-3.71.89-.78 0-1.96-.86-3.22-.84-1.66.02-3.19.96-4.04 2.45-1.72 2.98-.44 7.4 1.24 9.82.82 1.18 1.8 2.52 3.06 2.47 1.23-.05 1.7-.8 3.19-.8 1.48 0 1.9.8 3.2.78 1.32-.02 2.15-1.2 2.96-2.39.93-1.37 1.32-2.71 1.34-2.78-.03-.01-2.57-.98-2.59-3.89zM14.6 6.06c.67-.81 1.13-1.94.99-3.06-.97.04-2.13.65-2.83 1.45-.62.71-1.18 1.86-1.03 2.96 1.09.09 2.2-.55 2.87-1.35z"/></svg>
              Download RecipeBox AI
            </a>
            <span class="download-hint">Free · iOS · iPad</span>
          </div>
        </div>

        <!-- Method -->
        {instructions.length > 0 && (
          <div class="section">
            <h2>Method</h2>
            <ol class="step-list" id="step-list">
              {instructions.map((s, i) => (
                <li data-step-idx={i} id={`step-${i + 1}`}>
                  <div class="n">{String(i + 1).padStart(2, '0')}</div>
                  <div class="txt">{s}</div>
                </li>
              ))}
            </ol>
          </div>
        )}

      </main>
    </div>

    <!-- ─── Related ─── -->
    {relatedRecipes && relatedRecipes.length > 0 && (
      <section class="related-band">
        <div class="related-head">
          <h2>More recipes <em>you'll love</em></h2>
          <a href="/recipes/">View all
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="rec-grid">
          {relatedRecipes.slice(0, 4).map((rel) => {
            const relTime = (rel.prep_time || 0) + (rel.cook_time || 0);
            const relDiet = rel.tags?.diet || rel.tags?.cuisine || '';
            return (
              <a class="rec-card" href={`/recipes/${rel.slug}/`}>
                <div class="img-wrap">
                  <img src={rel.image_url || '/app-icon.png'} alt={rel.title} loading="lazy" onerror="this.src='/app-icon.png';this.style.objectFit='contain';this.style.padding='25%';this.style.background='var(--bg-2)';">
                </div>
                <h3>{rel.title}</h3>
                <div class="m">
                  {relTime > 0 && (
                    <span style="display:inline-flex; align-items:center; gap:4px;">
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="12" cy="13" r="8"/><path d="M12 9v4l3 2M9 2h6"/></svg>
                      {relTime} min
                    </span>
                  )}
                  {relTime > 0 && relDiet && <span class="dot"></span>}
                  {relDiet && <span>{relDiet}</span>}
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}
  </div>

  <footer class="rb-footer">
    <div class="container row">
      <div class="brand">
        <img class="app-ico" src="/app-icon.png" alt="">
        RecipeBox AI
      </div>
      <div class="links">
        <a href="mailto:hello@recipeboxai.app">Support</a>
        <a href="/privacy/">Privacy</a>
        <a href="/terms/">Terms</a>
        <a href="https://twitter.com/RecipeBoxAI">Twitter</a>
      </div>
      <div class="copy">© 2026 RecipeBox AI</div>
    </div>
  </footer>

  <script type="application/json" id="rb-recipe-data" set:html={saveDataJson} />

  <!-- ─── Save modal ─── -->
  <div class="rb-modal-backdrop" id="rb-modal" hidden>
    <div class="rb-modal-card" role="dialog" aria-modal="true" aria-labelledby="rb-modal-title">
      <button class="rb-modal-close" id="rb-modal-close" aria-label="Close">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
      <div id="rb-modal-body"></div>
    </div>
  </div>

  <script>
    import { supabase, getSaveGate, saveSharedRecipeToLibrary, escapeHtml, type SharedSaveData } from '@/lib/account';

    const APP_STORE = 'https://apps.apple.com/gb/app/recipebox-ai/id6752560797';
    const shared = JSON.parse(document.getElementById('rb-recipe-data')?.textContent || 'null') as SharedSaveData | null;

    const saveBtn = document.getElementById('add-to-recipebox-btn') as HTMLButtonElement | null;
    const modal = document.getElementById('rb-modal') as HTMLElement;
    const modalBody = document.getElementById('rb-modal-body') as HTMLElement;

    function openModal(html: string) {
      modalBody.innerHTML = html;
      modal.hidden = false;
      document.body.style.overflow = 'hidden';
    }
    function closeModal() {
      modal.hidden = true;
      document.body.style.overflow = '';
    }
    document.getElementById('rb-modal-close')?.addEventListener('click', closeModal);
    modal?.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !modal.hidden) closeModal(); });
    modalBody?.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('[data-close]')) closeModal();
    });

    const idleBtnHtml = saveBtn?.innerHTML ?? '';
    function setBusy(busy: boolean) {
      if (!saveBtn) return;
      saveBtn.disabled = busy;
      saveBtn.innerHTML = busy ? '<span class="rb-btn-spinner"></span> Saving…' : idleBtnHtml;
    }

    function markSaved() {
      if (!saveBtn) return;
      saveBtn.disabled = true;
      saveBtn.classList.add('saved');
      saveBtn.innerHTML = `
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 7"/></svg>
        Saved to your library`;
    }

    const appleBadge = '<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.06 13.28c-.02-2.45 2-3.62 2.09-3.68-1.14-1.67-2.91-1.9-3.54-1.93-1.51-.15-2.94.89-3.71.89-.78 0-1.96-.86-3.22-.84-1.66.02-3.19.96-4.04 2.45-1.72 2.98-.44 7.4 1.24 9.82.82 1.18 1.8 2.52 3.06 2.47 1.23-.05 1.7-.8 3.19-.8 1.48 0 1.9.8 3.2.78 1.32-.02 2.15-1.2 2.96-2.39.93-1.37 1.32-2.71 1.34-2.78-.03-.01-2.57-.98-2.59-3.89zM14.6 6.06c.67-.81 1.13-1.94.99-3.06-.97.04-2.13.65-2.83 1.45-.62.71-1.18 1.86-1.03 2.96 1.09.09 2.2-.55 2.87-1.35z"/></svg>';

    function signInModal() {
      const next = encodeURIComponent(window.location.pathname);
      openModal(`
        <div class="rb-modal-eyebrow">Save to your RecipeBox</div>
        <h3 id="rb-modal-title">Sign in to save<br><em>this recipe.</em></h3>
        <p>Sign in with your RecipeBox AI account and this recipe lands in your library — on your phone, tablet, and here on the web.</p>
        <a class="rb-modal-btn primary" href="/login/?next=${next}">Sign in</a>
        <a class="rb-modal-btn secondary" href="${APP_STORE}">${appleBadge} New here? Get the app</a>`);
    }

    function upgradeModal(used: number, limit: number) {
      openModal(`
        <div class="rb-modal-eyebrow">Free plan limit</div>
        <h3 id="rb-modal-title">Your RecipeBox<br><em>is full.</em></h3>
        <p>You've saved <b>${used} of ${limit}</b> recipes on the free plan. Upgrade to Pro for unlimited recipes, AI transformations, and more.</p>
        <a class="rb-modal-btn primary" href="${APP_STORE}">${appleBadge} Upgrade in the app</a>
        <p class="rb-modal-hint">Upgrading on the web is coming soon.</p>`);
    }

    function savedModal(newId: string, title: string) {
      openModal(`
        <div class="rb-modal-eyebrow">Saved</div>
        <h3 id="rb-modal-title">It's in your<br><em>library.</em></h3>
        <p>“${escapeHtml(title)}” is now in your RecipeBox — it syncs to all your devices automatically.</p>
        <a class="rb-modal-btn primary" href="/my/recipes/view/?id=${encodeURIComponent(newId)}">View recipe</a>
        <a class="rb-modal-btn secondary" href="/my/recipes/">Go to My Recipes</a>`);
    }

    function errorModal(message: string) {
      openModal(`
        <div class="rb-modal-eyebrow">Something went wrong</div>
        <h3 id="rb-modal-title">Couldn't save<br><em>this recipe.</em></h3>
        <p>${escapeHtml(message)}</p>
        <button class="rb-modal-btn secondary" data-close>Close and try again</button>`);
    }

    async function onSave() {
      if (!shared) return;
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) {
        signInModal();
        return;
      }
      setBusy(true);
      try {
        const gate = await getSaveGate(session.user.id);
        if (!gate.allowed) {
          setBusy(false);
          upgradeModal(gate.used, gate.limit);
          return;
        }
        const newId = await saveSharedRecipeToLibrary(session.user.id, shared);
        markSaved();
        savedModal(newId, shared.title);
      } catch (err) {
        setBusy(false);
        errorModal(err instanceof Error ? err.message : 'Please try again.');
      }
    }

    saveBtn?.addEventListener('click', onSave);
  </script>

  <script is:inline define:vars={{ baseServings: recipe.servings }}>
    (function () {
      // Servings stepper with quantity scaling
      const numEl = document.getElementById('servings-num');
      const bar = document.getElementById('servings-bar');
      let current = baseServings;

      function format(n) {
        if (!isFinite(n)) return '';
        const rounded = Math.round(n * 100) / 100;
        return Number.isInteger(rounded) ? String(rounded) : rounded.toFixed(2).replace(/0+$/, '').replace(/\.$/, '');
      }

      function applyScale() {
        const scale = current / baseServings;
        numEl.textContent = String(current);
        document.querySelectorAll('.qty').forEach((el) => {
          const base = parseFloat(el.dataset.baseAmount);
          if (!isNaN(base) && base > 0) {
            const scaled = base * scale;
            const unit = el.dataset.unit || '';
            el.textContent = format(scaled) + (unit ? ' ' + unit : '');
          }
        });
      }

      if (bar) {
        bar.addEventListener('click', (e) => {
          const btn = e.target.closest('button[data-step]');
          if (!btn) return;
          const step = parseInt(btn.dataset.step, 10);
          current = Math.max(1, current + step);
          applyScale();
        });
      }

      // Ingredient check toggle
      document.querySelectorAll('[data-check]').forEach((btn) => {
        btn.addEventListener('click', () => {
          btn.classList.toggle('on');
          btn.closest('li')?.classList.toggle('done');
        });
      });

      // Step done toggle
      document.querySelectorAll('#step-list li').forEach((li) => {
        li.addEventListener('click', () => li.classList.toggle('done'));
        li.style.cursor = 'pointer';
      });
    })();
  </script>
</BaseLayout>

