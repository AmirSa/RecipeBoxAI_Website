---
import BaseLayout from '@layouts/BaseLayout.astro';
import { supabase } from '../../lib/supabase';

// Fetch all published recipes from Supabase
const { data: recipes, error } = await supabase
  .from('shared_recipes')
  .select('id, slug, title, description, prep_time, cook_time, servings, calories, tags, auto_tags, image_url, is_featured, view_count')
  .eq('is_published', true)
  .order('is_featured', { ascending: false })
  .order('view_count', { ascending: false });

if (error) {
  console.error('Error fetching recipes:', error);
}

const recipeList = recipes || [];
---

<BaseLayout title="All Recipes" description="Browse all recipes in RecipeBox AI">
  <nav class="top-nav">
    <a href="/" class="back-button">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Home
    </a>
    <span class="nav-title">All Recipes</span>
    <div></div>
  </nav>
  
  <div class="container">
    <h1 class="page-title">All Recipes</h1>
    <p class="page-subtitle">Browse our collection of {recipeList.length} delicious recipes</p>
    
    <div class="recipes-grid">
      {recipeList.map((recipe) => {
        // Get tags from object values and auto_tags array
        const tagValues = Object.values(recipe.tags || {});
        const allTags = [...tagValues, ...(recipe.auto_tags || [])].slice(0, 3);
        
        return (
          <a href={`/recipes/${recipe.slug}`} class="recipe-card">
            <div class="recipe-image-container">
              <img 
                src={recipe.image_url || '/images/recipe-placeholder.jpg'} 
                alt={recipe.title} 
                class="recipe-image" 
                loading="lazy" 
              />
              {recipe.is_featured && <span class="featured-badge">⭐ Featured</span>}
            </div>
            <div class="recipe-content">
              <h2 class="recipe-title">{recipe.title}</h2>
              <p class="recipe-description">{recipe.description || ''}</p>
              <div class="recipe-meta">
                <span class="meta-item">⏱️ {recipe.prep_time + recipe.cook_time}m</span>
                <span class="meta-item">👥 {recipe.servings} servings</span>
                <span class="meta-item">🔥 {recipe.calories} cal</span>
              </div>
              <div class="recipe-tags">
                {allTags.map((tag: string) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
          </a>
        );
      })}
    </div>
    
    {recipeList.length === 0 && (
      <div class="empty-state">
        <p>No recipes found. Check back soon!</p>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .top-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 2rem;
    background: white;
    border-bottom: 1px solid #eee;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  
  .back-button {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #333;
    text-decoration: none;
    font-size: 0.95rem;
  }
  
  .back-button svg {
    width: 20px;
    height: 20px;
  }
  
  .nav-title {
    font-weight: 600;
    font-size: 1rem;
    color: #333;
  }
  
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }
  
  .page-title {
    font-size: 2rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 0.5rem;
  }
  
  .page-subtitle {
    color: #666;
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }
  
  .recipes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  
  .recipe-card {
    background: white;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  
  .recipe-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
  }
  
  .recipe-image-container {
    width: 100%;
    height: 200px;
    overflow: hidden;
  }
  
  .recipe-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }
  
  .recipe-card:hover .recipe-image {
    transform: scale(1.05);
  }
  
  .recipe-content {
    padding: 1.25rem;
  }
  
  .recipe-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 0.5rem;
  }
  
  .recipe-description {
    color: #666;
    font-size: 0.9rem;
    line-height: 1.5;
    margin-bottom: 0.75rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .recipe-meta {
    display: flex;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }
  
  .meta-item {
    font-size: 0.8rem;
    color: #888;
  }
  
  .recipe-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  
  .tag {
    background: #f5f5f5;
    color: #666;
    padding: 0.25rem 0.6rem;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 500;
  }
  
  .recipe-image-container {
    position: relative;
  }
  
  .featured-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
    color: white;
    padding: 0.35rem 0.75rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
  }
  
  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    color: #666;
    font-size: 1.1rem;
  }
  
  @media (max-width: 600px) {
    .container {
      padding: 1rem;
    }
    
    .recipes-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
