---
import BaseLayout from '@layouts/BaseLayout.astro';
import NavAccount from '@components/NavAccount.astro';
import { fetchAllPublishedRecipes } from '../../lib/supabase';

const recipes = await fetchAllPublishedRecipes<Record<string, any>>(
  'id, slug, title, description, prep_time, cook_time, servings, calories, tags, auto_tags, image_url, is_featured, view_count',
);
recipes.sort((a, b) =>
  (Number(!!b.is_featured) - Number(!!a.is_featured)) || ((b.view_count || 0) - (a.view_count || 0)),
);

type Tags = { mealType?: string; cuisine?: string; diet?: string };

const recipeList = (recipes || []).map((r) => {
  const tags = (r.tags || {}) as Tags;
  return {
    slug: r.slug,
    title: r.title,
    description: r.description || '',
    totalTime: (r.prep_time || 0) + (r.cook_time || 0),
    servings: r.servings,
    calories: r.calories,
    mealType: tags.mealType || '',
    cuisine:  tags.cuisine  || '',
    diet:     tags.diet     || 'Standard',
    image: r.image_url || '',
    isFeatured: !!r.is_featured,
  };
});

const totalCount = recipeList.length;

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'RecipeBox AI Recipes',
  description: 'Browse all recipes in RecipeBox AI - your AI-powered recipe assistant',
  numberOfItems: totalCount,
  itemListElement: recipeList.slice(0, 50).map((r, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `https://recipeboxai.app/recipes/${r.slug}/`,
    name: r.title,
  })),
};
---

<BaseLayout title="Recipes" description="Browse our hand-curated collection of recipes — Italian, Korean, French, weeknight quick, weekend slow. Tap any recipe to add it straight to your RecipeBox.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,800&family=Inter+Tight:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

  <!-- ─── Nav ─── -->
  <nav class="rb-nav">
    <div class="container inner">
      <a class="brand" href="/">
        <img class="app-ico" src="/app-icon.png" alt="">
        RecipeBox AI
      </a>
      <ul>
        <li><a href="/#features">Features</a></li>
        <li><a class="current" href="/recipes/">Recipes</a></li>
        <li><a href="/my/recipes/">My Recipes</a></li>
        <li><a href="/my/cookbooks/">Cookbooks</a></li>
        <li><a href="/#reviews">Reviews</a></li>
      </ul>
      <a class="download" id="nav-download" href="https://apps.apple.com/gb/app/recipebox-ai/id6752560797">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.06 13.28c-.02-2.45 2-3.62 2.09-3.68-1.14-1.67-2.91-1.9-3.54-1.93-1.51-.15-2.94.89-3.71.89-.78 0-1.96-.86-3.22-.84-1.66.02-3.19.96-4.04 2.45-1.72 2.98-.44 7.4 1.24 9.82.82 1.18 1.8 2.52 3.06 2.47 1.23-.05 1.7-.8 3.19-.8 1.48 0 1.9.8 3.2.78 1.32-.02 2.15-1.2 2.96-2.39.93-1.37 1.32-2.71 1.34-2.78-.03-.01-2.57-.98-2.59-3.89zM14.6 6.06c.67-.81 1.13-1.94.99-3.06-.97.04-2.13.65-2.83 1.45-.62.71-1.18 1.86-1.03 2.96 1.09.09 2.2-.55 2.87-1.35z"/></svg>
        Download
      </a>
      <NavAccount />
    </div>
  </nav>

  <div class="container">
    <div class="crumb">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <span style="color: var(--ink);">Recipes</span>
    </div>

    <header class="page-head">
      <div class="left">
        <h1 class="display">Every recipe.<br><em>One place.</em></h1>
        <p class="lead">Browse our hand-curated collection — Italian, Korean, French, weeknight quick, weekend slow. Tap any recipe to add it straight to your RecipeBox.</p>
      </div>
      <div class="right">
        <div class="count">{totalCount.toLocaleString()}</div>
        <div class="count-label">Recipes in collection</div>
      </div>
    </header>

    <div class="layout">

      <aside class="filters" id="filters"></aside>

      <main class="results">
        <div class="featured">
          <div class="copy">
            <div class="eyebrow">Powered by AI</div>
            <h2>Can't find what you're looking for?</h2>
            <p>Tell our AI what's in your fridge — or your mood, your goal, your dietary needs — and we'll generate the perfect recipe just for you.</p>
            <div class="row">
              <a class="chip ai" href="https://apps.apple.com/gb/app/recipebox-ai/id6752560797">+ Generate a recipe</a>
              <span class="chip">chicken thigh</span>
              <span class="chip">rice</span>
              <span class="chip">ginger</span>
            </div>
          </div>
          <div class="photo">
            <img src="https://images.unsplash.com/photo-1490645935967-10de6ba17061?w=900&q=80&auto=format&fit=crop" alt="" loading="lazy">
          </div>
        </div>

        <div class="toolbar">
          <div class="showing">Showing <b id="showing-count">{totalCount.toLocaleString()}</b> of <b id="total-showing">{totalCount.toLocaleString()}</b> recipes</div>
          <div class="right">
            <div class="search-wrap">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
              <input type="search" id="search" placeholder="Search recipes…" autocomplete="off">
            </div>
            <span class="sort-label">Sort</span>
            <select class="sort-select" id="sort">
              <option value="Recommended">Recommended</option>
              <option value="Newest">Newest</option>
              <option value="Prep Time">Prep Time</option>
              <option value="Calories">Calories</option>
            </select>
            <div class="view-toggle" id="view-toggle">
              <button class="on" data-view="grid">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
                Grid
              </button>
              <button data-view="list">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M8 6h13M8 12h13M8 18h13M4 6h.01M4 12h.01M4 18h.01"/></svg>
                List
              </button>
            </div>
          </div>
        </div>

        <div class="grid" id="grid"></div>

        <div class="pagination" id="pagination"></div>
      </main>
    </div>
  </div>

  <footer class="rb-footer">
    <div class="container row">
      <div class="brand">
        <img class="app-ico" src="/app-icon.png" alt="">
        RecipeBox AI
      </div>
      <div class="links">
        <a href="mailto:hello@recipeboxai.app">Support</a>
        <a href="/privacy/">Privacy</a>
        <a href="/terms/">Terms</a>
        <a href="https://twitter.com/RecipeBoxAI">Twitter</a>
      </div>
      <div class="copy">© 2026 RecipeBox AI</div>
    </div>
  </footer>

  <script define:vars={{ recipeList }}>
    window.__RECIPES__ = recipeList;
  </script>

  <script is:inline>
    (function() {
      const PAGE_SIZE = 12;
      const FILTERS = [
        { name: 'meal',    label: 'Meal type', opts: ['All', 'Breakfast', 'Lunch', 'Dinner', 'Dessert', 'Snacks'], default: 'All' },
        { name: 'diet',    label: 'Dietary',   opts: ['All', 'Vegetarian', 'Vegan', 'Gluten-Free', 'Healthy'], default: 'All' },
        { name: 'cuisine', label: 'Cuisine',   opts: ['All', 'Italian', 'Mexican', 'Asian', 'American', 'Indian', 'French', 'Mediterranean', 'Korean', 'Japanese', 'Thai', 'British', 'Moroccan', 'Middle Eastern'], default: 'All' },
        { name: 'time',    label: 'Prep time', opts: ['Any', 'Under 15 min', 'Under 30 min', 'Under 60 min'], default: 'Any' },
        { name: 'cals',    label: 'Calories',  opts: ['Any', 'Under 300', 'Under 500', 'Under 700'], default: 'Any' },
      ];
      const state = {
        meal: 'All', diet: 'All', cuisine: 'All', time: 'Any', cals: 'Any',
        search: '', sort: 'Recommended', view: 'grid', page: 1,
        saved: new Set(JSON.parse(localStorage.getItem('rb-saved') || '[]')),
        all: window.__RECIPES__ || [],
      };
      const ICON = {
        heart: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>',
        heartFill: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>',
        timer: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" width="13" height="13"><circle cx="12" cy="13" r="8"/><path d="M12 9v4l3 2M9 2h6"/></svg>',
        x: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>',
        arrow: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>',
      };

      function escapeHtml(s) {
        return (s || '').replace(/[&<>"']/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]));
      }
      function dietClassName(d) { return (d || '').toLowerCase().replace(/[^a-z]/g, ''); }
      function hasAnyFilter() { return state.meal !== 'All' || state.diet !== 'All' || state.cuisine !== 'All' || state.time !== 'Any' || state.cals !== 'Any'; }

      function applyFilters() {
        let list = state.all.slice();
        if (state.search) {
          const q = state.search.toLowerCase();
          list = list.filter(r =>
            (r.title && r.title.toLowerCase().includes(q)) ||
            (r.description && r.description.toLowerCase().includes(q))
          );
        }
        if (state.meal !== 'All')    list = list.filter(r => r.mealType === state.meal);
        if (state.diet !== 'All')    list = list.filter(r => r.diet === state.diet);
        if (state.cuisine !== 'All') list = list.filter(r => r.cuisine === state.cuisine);
        if (state.time !== 'Any') {
          const cap = state.time === 'Under 15 min' ? 15 : state.time === 'Under 30 min' ? 30 : 60;
          list = list.filter(r => r.totalTime && r.totalTime <= cap);
        }
        if (state.cals !== 'Any') {
          const cap = state.cals === 'Under 300' ? 300 : state.cals === 'Under 500' ? 500 : 700;
          list = list.filter(r => r.calories && r.calories <= cap);
        }
        if (state.sort === 'Prep Time') list.sort((a, b) => (a.totalTime || 9999) - (b.totalTime || 9999));
        else if (state.sort === 'Calories') list.sort((a, b) => (a.calories || 9999) - (b.calories || 9999));
        else if (state.sort === 'Newest') list.reverse();
        return list;
      }

      function renderFilters() {
        const aside = document.getElementById('filters');
        aside.innerHTML = FILTERS.map(f => {
          const cur = state[f.name];
          const active = cur !== f.default;
          return `
            <div class="filter-group">
              <h3>${f.label}<button class="clear ${active ? 'show' : ''}" data-clear="${f.name}">Clear</button></h3>
              <div class="pill-row">
                ${f.opts.map(o => `<button class="pill ${cur === o ? 'active' : ''}" data-filter="${f.name}" data-value="${o}">${o}</button>`).join('')}
              </div>
            </div>`;
        }).join('') + `<button class="clear-all ${hasAnyFilter() ? 'show' : ''}" id="clear-all">${ICON.x} Clear all filters</button>`;
      }

      function renderCard(r) {
        const dietCls = dietClassName(r.diet);
        const showDiet = r.diet && r.diet !== 'Standard' && r.diet !== '';
        const isSaved = state.saved.has(r.slug);
        const placeholder = `https://via.placeholder.com/600x400/e9e6df/0a0a0a?text=${encodeURIComponent((r.title || 'Recipe').slice(0,24))}`;
        const img = r.image || placeholder;
        return `
          <a class="card" href="/recipes/${r.slug}/">
            <div class="img-wrap">
              <img src="${img}" alt="${escapeHtml(r.title)}" loading="lazy" onerror="this.src='${placeholder}'">
              <button class="save ${isSaved ? 'on' : ''}" data-save="${r.slug}" aria-label="Save recipe">${isSaved ? ICON.heartFill : ICON.heart}</button>
              ${r.cuisine ? `<div class="src-tag">${escapeHtml(r.cuisine)}</div>` : ''}
            </div>
            <div class="body">
              <h3>${escapeHtml(r.title)}</h3>
              <div class="meta-row">
                ${r.totalTime ? `<span style="display:inline-flex;align-items:center;gap:4px;">${ICON.timer} ${r.totalTime} min</span>` : ''}
                ${r.totalTime && r.calories ? '<span class="dot"></span>' : ''}
                ${r.calories ? `<span>${r.calories} kcal</span>` : ''}
              </div>
              ${showDiet ? `<div class="tags"><span class="tag diet-${dietCls}">${escapeHtml(r.diet)}</span></div>` : ''}
            </div>
          </a>`;
      }

      function renderResults() {
        const filtered = applyFilters();
        const totalPages = Math.max(1, Math.ceil(filtered.length / PAGE_SIZE));
        if (state.page > totalPages) state.page = totalPages;
        const start = (state.page - 1) * PAGE_SIZE;
        const slice = filtered.slice(start, start + PAGE_SIZE);

        document.getElementById('showing-count').textContent = filtered.length.toLocaleString();
        document.getElementById('total-showing').textContent = state.all.length.toLocaleString();

        const grid = document.getElementById('grid');
        grid.className = 'grid' + (state.view === 'list' ? ' list' : '');
        if (slice.length === 0) {
          grid.innerHTML = `<div class="state-card"><h3>No recipes match these filters</h3><p>Try clearing some filters or changing your search.</p></div>`;
        } else {
          grid.innerHTML = slice.map(renderCard).join('');
        }
        renderPagination(totalPages);
      }

      function renderPagination(totalPages) {
        const pag = document.getElementById('pagination');
        if (totalPages <= 1) { pag.innerHTML = ''; return; }
        const p = state.page;
        const pages = [];
        pages.push(1);
        if (p > 3) pages.push('…');
        for (let i = Math.max(2, p - 1); i <= Math.min(totalPages - 1, p + 1); i++) pages.push(i);
        if (p < totalPages - 2) pages.push('…');
        if (totalPages > 1) pages.push(totalPages);
        pag.innerHTML = `
          <button data-page="prev" ${p === 1 ? 'disabled' : ''}>← Prev</button>
          ${pages.map(n => n === '…'
            ? `<button class="gap" disabled>…</button>`
            : `<button class="${n === p ? 'on' : ''}" data-page="${n}">${n}</button>`).join('')}
          <button data-page="next" ${p === totalPages ? 'disabled' : ''}>Next ${ICON.arrow}</button>`;
      }

      function wire() {
        document.getElementById('filters').addEventListener('click', e => {
          const pill = e.target.closest('[data-filter]');
          if (pill) { state[pill.dataset.filter] = pill.dataset.value; state.page = 1; renderFilters(); renderResults(); return; }
          const clr = e.target.closest('[data-clear]');
          if (clr) { const f = FILTERS.find(x => x.name === clr.dataset.clear); state[clr.dataset.clear] = f.default; state.page = 1; renderFilters(); renderResults(); return; }
          if (e.target.closest('#clear-all')) { FILTERS.forEach(f => state[f.name] = f.default); state.page = 1; renderFilters(); renderResults(); }
        });
        document.getElementById('grid').addEventListener('click', e => {
          const save = e.target.closest('[data-save]');
          if (!save) return;
          e.preventDefault(); e.stopPropagation();
          const slug = save.dataset.save;
          if (state.saved.has(slug)) state.saved.delete(slug); else state.saved.add(slug);
          localStorage.setItem('rb-saved', JSON.stringify([...state.saved]));
          save.classList.toggle('on');
          save.innerHTML = state.saved.has(slug) ? ICON.heartFill : ICON.heart;
        });
        document.getElementById('pagination').addEventListener('click', e => {
          const btn = e.target.closest('button[data-page]');
          if (!btn || btn.disabled) return;
          const v = btn.dataset.page;
          const totalPages = Math.max(1, Math.ceil(applyFilters().length / PAGE_SIZE));
          if (v === 'prev') state.page = Math.max(1, state.page - 1);
          else if (v === 'next') state.page = Math.min(totalPages, state.page + 1);
          else state.page = parseInt(v, 10);
          renderResults();
          window.scrollTo({ top: document.querySelector('main.results').offsetTop - 80, behavior: 'smooth' });
        });
        let t;
        document.getElementById('search').addEventListener('input', e => {
          clearTimeout(t);
          t = setTimeout(() => { state.search = e.target.value.trim(); state.page = 1; renderResults(); }, 200);
        });
        document.getElementById('sort').addEventListener('change', e => { state.sort = e.target.value; state.page = 1; renderResults(); });
        document.getElementById('view-toggle').addEventListener('click', e => {
          const btn = e.target.closest('button[data-view]');
          if (!btn) return;
          state.view = btn.dataset.view;
          document.querySelectorAll('#view-toggle button').forEach(b => b.classList.toggle('on', b === btn));
          renderResults();
        });
      }

      renderFilters();
      renderResults();
      wire();
    })();
  </script>
</BaseLayout>

<style is:global>
  :root {
    --bg: #f0eee9;
    --bg-2: #e9e6df;
    --ink: #0a0a0a;
    --ink-2: #2a2a2c;
    --muted: #6e6e73;
    --line: rgba(10,10,10,0.08);
    --line-2: rgba(10,10,10,0.04);
    --serif: "Fraunces", Georgia, serif;
    --sans: "Inter Tight", -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
  }
  html, body { margin: 0; padding: 0; background: var(--bg); color: var(--ink); font-family: var(--sans); line-height: 1.45; }
  *, *::before, *::after { box-sizing: border-box; }
  body { -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility; }
  ::selection { background: #0a0a0a; color: #fff; }
  img { display: block; max-width: 100%; }
  a { color: inherit; text-decoration: none; }
  button { font: inherit; cursor: pointer; }

  .container { max-width: 1440px; margin: 0 auto; padding: 0 56px; }
  .display { font-family: var(--serif); font-weight: 400; font-variation-settings: "opsz" 144; line-height: 0.96; letter-spacing: -0.035em; text-wrap: balance; }
  .display em { font-style: italic; font-weight: 400; }
  .lead { font-family: var(--sans); font-size: 19px; line-height: 1.45; color: var(--ink-2); letter-spacing: -0.01em; text-wrap: pretty; }

  /* Nav */
  nav.rb-nav { position: sticky; top: 0; z-index: 50; backdrop-filter: saturate(180%) blur(14px); -webkit-backdrop-filter: saturate(180%) blur(14px); background: color-mix(in srgb, var(--bg) 86%, transparent); border-bottom: 1px solid var(--line-2); }
  nav.rb-nav .inner { display: flex; align-items: center; justify-content: space-between; height: 64px; }
  nav.rb-nav .brand { display: flex; align-items: center; gap: 10px; font-weight: 700; letter-spacing: -0.02em; font-size: 17px; color: var(--ink); }
  nav.rb-nav .brand .app-ico { width: 30px; height: 30px; border-radius: 7px; box-shadow: 0 1px 2px rgba(0,0,0,0.18); }
  nav.rb-nav ul { list-style: none; padding: 0; margin: 0; display: flex; gap: 28px; }
  nav.rb-nav ul a { font-size: 14px; font-weight: 500; color: var(--ink-2); }
  nav.rb-nav ul a.current, nav.rb-nav ul a:hover { color: var(--ink); }
  nav.rb-nav .download { height: 38px; padding: 0 16px; border-radius: 999px; background: #0a0a0a; color: #fff; font-size: 13px; font-weight: 600; display: inline-flex; align-items: center; gap: 8px; }

  /* Crumb + Header */
  .crumb { padding: 24px 0 0; font-size: 13px; color: var(--muted); display: flex; gap: 8px; align-items: center; }
  .crumb a:hover { color: var(--ink); }
  .crumb .sep { opacity: 0.5; }
  header.page-head { padding: 22px 0 36px; display: flex; justify-content: space-between; align-items: end; gap: 40px; flex-wrap: wrap; }
  header.page-head .left { max-width: 720px; }
  header.page-head h1 { font-size: 96px; margin: 0; }
  header.page-head .lead { margin-top: 16px; max-width: 50ch; }
  header.page-head .right { display: flex; flex-direction: column; gap: 8px; align-items: end; }
  header.page-head .count { font-family: var(--serif); font-size: 56px; font-weight: 500; letter-spacing: -0.03em; line-height: 1; font-variant-numeric: tabular-nums; }
  header.page-head .count-label { font-size: 12px; font-weight: 600; letter-spacing: 1.4px; text-transform: uppercase; color: var(--muted); }

  /* Layout */
  .layout { display: grid; grid-template-columns: 280px 1fr; gap: 56px; padding-bottom: 96px; }
  aside.filters { position: sticky; top: 88px; align-self: start; max-height: calc(100vh - 100px); overflow-y: auto; padding-right: 8px; }
  aside.filters::-webkit-scrollbar { width: 6px; }
  aside.filters::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.12); border-radius: 3px; }
  .filter-group { padding: 22px 0; border-bottom: 1px solid var(--line); }
  .filter-group:first-child { padding-top: 0; }
  .filter-group:last-child { border-bottom: 0; }
  .filter-group h3 { font-family: var(--sans); font-size: 11px; font-weight: 700; letter-spacing: 1.4px; text-transform: uppercase; color: var(--ink); margin: 0 0 14px; display: flex; justify-content: space-between; align-items: center; }
  .filter-group h3 .clear { font-size: 11px; letter-spacing: 0.4px; text-transform: none; color: var(--muted); font-weight: 500; cursor: pointer; background: none; border: 0; padding: 0; display: none; }
  .filter-group h3 .clear.show { display: inline; }
